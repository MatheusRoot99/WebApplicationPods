@model WebApplicationPods.Models.ProdutoListagemViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/home-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="home-index">

    <!-- Topbar (filtros/ordenação estilo mobile app) -->
    <div class="topbar container-fluid">
        <div class="topbar-inner container px-0">
            <button class="topbar-btn" type="button"
                    data-bs-toggle="collapse" data-bs-target="#filtersCollapse"
                    aria-expanded="false" aria-controls="filtersCollapse">
                <i class="fa-solid fa-sliders"></i>
                <span>Filtrar</span>
            </button>

            <div class="topbar-select">
                <label for="Filtros_OrdenarPor" class="form-label m-0">Ordenar por</label>
                <select id="Filtros_OrdenarPor" name="Filtros.OrdenarPor" class="form-select form-select-sm">
                    @foreach (var kv in Model.Filtros.OpcoesOrdenacao)
                    {
                        <option value="@kv.Key" selected="@(Model.Filtros.OrdenarPor == kv.Key)">
                            @kv.Value
                        </option>
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Hero -->
    <section class="hero-section text-center text-white mb-3">
        <div class="container">
            <h1 class="display-6 fw-bold mb-1">Bem-vindo à PodsPlatform</h1>
            <p class="lead fs-6 mb-0">Os melhores pods eletrônicos do mercado!</p>
        </div>
    </section>

    <!-- Filtros (collapse no mobile) -->
    <div class="container mb-3">
        <div class="collapse d-lg-block" id="filtersCollapse">
            <form asp-action="Index" method="get" class="filters-card card border-0 p-3 mb-3" id="filtersForm">
                <div class="row g-3">
                    <div class="col-12 col-md-6 col-lg-3">
                        <label asp-for="Filtros.Categoria" class="form-label">Categoria</label>
                        <select asp-for="Filtros.Categoria" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.CategoriasDisponiveis))">
                            <option value="">Todas Categorias</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label asp-for="Filtros.Sabor" class="form-label">Sabor</label>
                        <select asp-for="Filtros.Sabor" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.SaboresDisponiveis))">
                            <option value="">Todos Sabores</option>
                        </select>
                    </div>

                    <div class="col-6 col-lg-2">
                        <label asp-for="Filtros.PrecoMin" class="form-label">Preço mín</label>
                        <input asp-for="Filtros.PrecoMin" type="number" step="0.01" min="0" class="form-control" placeholder="R$">
                    </div>

                    <div class="col-6 col-lg-2">
                        <label asp-for="Filtros.PrecoMax" class="form-label">Preço máx</label>
                        <input asp-for="Filtros.PrecoMax" type="number" step="0.01" min="0" class="form-control" placeholder="R$">
                    </div>

                    <div class="col-12 col-lg-2 d-none d-lg-block">
                        <label asp-for="Filtros.OrdenarPor" class="form-label">Ordenar por</label>
                        <select asp-for="Filtros.OrdenarPor" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.OpcoesOrdenacao, "Key", "Value"))">
                        </select>
                    </div>

                    <div class="col-12">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" asp-for="Filtros.ApenasPromocoes" id="ckPromo">
                                    <label class="form-check-label" for="ckPromo">Promoções</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" asp-for="Filtros.ApenasEstoque" id="ckEstoque">
                                    <label class="form-check-label" for="ckEstoque">Em estoque</label>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-filter me-1"></i> Filtrar
                                </button>
                                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i> Limpar
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- Grade de Produtos (2 colunas no mobile) -->
    <div class="container mb-4">
        @if (Model.Produtos != null && Model.Produtos.Any())
        {
            <div class="product-grid">
                @foreach (var produto in Model.Produtos)
                {
                    var temPromo = produto.EmPromocao && produto.PrecoPromocional.HasValue;
                    var precoBase = temPromo ? produto.PrecoPromocional!.Value : produto.Preco;
                    <article class="produto-card h-100">
                        <!-- Capa (clique leva aos detalhes) -->
                        <a asp-controller="Produto" asp-action="DetalhesProdutos" asp-route-id="@produto.Id"
                           class="thumb-link" aria-label="@produto.Nome">
                            <div class="product-thumb">
                                @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                                {
                                    <img src="@Url.Content(produto.ImagemUrl)" alt="@produto.Nome" />
                                }
                                else
                                {
                                    <div class="no-image">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }

                                @if (produto.Estoque <= 0)
                                {
                                    <span class="badge badge-top-right bg-danger">ESGOTADO</span>
                                }
                                else if (produto.EmPromocao)
                                {
                                    <span class="badge badge-top-right bg-success">PROMOÇÃO</span>
                                }
                            </div>
                        </a>

                        <!-- Conteúdo -->
                        <div class="card-body">
                            <a asp-controller="Produto" asp-action="DetalhesProdutos" asp-route-id="@produto.Id"
                               class="stretched-link text-decoration-none">
                                <h6 class="title text-truncate-2">@produto.Nome</h6>
                            </a>

                            <div class="specs small text-muted">
                                <span><i class="fa-solid fa-smoking me-1"></i>@produto.Puffs puffs</span>
                                <span>•</span>
                                <span><i class="fa-solid fa-battery-three-quarters me-1"></i>@produto.CapacidadeBateria mAh</span>
                            </div>

                            <div class="price-line">
                                @if (temPromo)
                                {
                                    <span class="old">@produto.Preco.ToString("C")</span>
                                    <span class="current">@precoBase.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="current">@precoBase.ToString("C")</span>
                                }
                            </div>
                        </div>
                        <!-- Ação rápida (POST direto p/ AdicionarItem) -->
                        <form asp-controller="Carrinho" asp-action="AdicionarItem" method="post" class="quick-add-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="produtoId" value="@produto.Id" />
                            <input type="hidden" name="quantidade" value="1" />
                            <input type="hidden" name="sabor" value="" />
                            <input type="hidden" name="observacoes" value="" />

                            <button type="submit"
                                    class="quick-add @(produto.Estoque <= 0 ? "disabled" : "")"
                                    @(produto.Estoque <= 0 ? "disabled" : null)
                                    aria-disabled="@(produto.Estoque <= 0)"
                                    title="Adicionar ao carrinho"
                                    aria-label="Adicionar @produto.Nome ao carrinho">

                                <!-- ícone normal -->
                                <i class="fa-solid fa-cart-plus qa-icon" aria-hidden="true"></i>
                                <!-- spinner (fica escondido até loading) -->
                                <i class="fa-solid fa-spinner fa-spin qa-spin" aria-hidden="true"></i>
                                <!-- check (fica escondido até sucesso) -->
                                <i class="fa-solid fa-check qa-done" aria-hidden="true"></i>

                            </button>
                        </form>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info text-center py-4">
                <i class="fas fa-info-circle me-2"></i>
                Nenhum produto encontrado com os filtros selecionados.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
          // ---- Ordenação & filtros (mantidos) ----
          const topbarSelect = document.getElementById('Filtros_OrdenarPor');
          const form = document.getElementById('filtersForm');

          if (topbarSelect && form) {
            topbarSelect.addEventListener('change', function () {
              const formSelect = form.querySelector('[name="Filtros.OrdenarPor"]');
              if (formSelect) formSelect.value = this.value;
              form.submit();
            });
          }
          if (form) {
            const filterElements = form.querySelectorAll('select, input[type="number"], input[type="checkbox"]');
            filterElements.forEach(el => {
              if (el.id !== 'Filtros_OrdenarPor') {
                el.addEventListener('change', () => form.submit());
              }
            });
          }
          const filtersCollapse = document.getElementById('filtersCollapse');
          if (filtersCollapse) {
            const syncCollapse = () => {
              if (window.innerWidth >= 992) filtersCollapse.classList.add('show');
              else filtersCollapse.classList.remove('show');
            };
            syncCollapse();
            window.addEventListener('resize', syncCollapse);
          }

          // ---- QUICK ADD via AJAX ----
          function getAntiForgeryTokenFromForm(f) {
            return f.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
          }

          async function postQuickAdd(formEl) {
            const url = formEl.getAttribute('action') || '/Carrinho/AdicionarItem';
            const token = getAntiForgeryTokenFromForm(formEl);

            const body = new URLSearchParams(new FormData(formEl));
            const resp = await fetch(url, {
              method: 'POST',
              headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token
              },
              body,
              credentials: 'same-origin'
            });
            if (!resp.ok) throw new Error('Falha na requisição');
            return await resp.json(); // { ok, count, nome } | { ok:false, error }
          }

          // SUBMIT dos botões de adicionar rápido
          document.querySelectorAll('.quick-add-form').forEach(formEl => {
            formEl.addEventListener('submit', async function (e) {
              e.preventDefault();
              const btn = formEl.querySelector('.quick-add');
              if (!btn || btn.classList.contains('disabled')) return;

              // estado: loading
              btn.classList.add('is-loading');
              btn.setAttribute('aria-busy', 'true');
              btn.disabled = true;

              // micro-toast preso ao card
              let tip = formEl.parentElement.querySelector('.quick-toast');
              if (!tip) {
                tip = document.createElement('div');
                tip.className = 'quick-toast';
                formEl.parentElement.appendChild(tip);
              }

              try {
                const result = await postQuickAdd(formEl);
                if (result.ok) {
                  if (typeof result.count !== 'undefined' && window.updateCartBadges) {
                    window.updateCartBadges(result.count);
                  } else {
                    const qtd = parseInt(formEl.querySelector('input[name="quantidade"]')?.value || '1', 10) || 1;
                    window.bumpCartCount && window.bumpCartCount(qtd, true);
                  }
                  window.cartMarkUnseen && window.cartMarkUnseen();

                  tip.textContent = 'Adicionado';
                  tip.classList.add('show');

                  btn.classList.remove('is-loading');
                  btn.classList.add('is-done');

                  window.showToast && window.showToast(`${result.nome || 'Item'} adicionado ao carrinho!`, true);

                  setTimeout(() => {
                    tip.classList.remove('show');
                    btn.classList.remove('is-done');
                  }, 900);
                } else {
                  tip.textContent = 'Erro';
                  tip.classList.add('show');
                  setTimeout(() => tip.classList.remove('show'), 900);
                  window.showToast && window.showToast(result.error || 'Não foi possível adicionar ao carrinho.', false);
                }
              } catch {
                tip.textContent = 'Falha de rede';
                tip.classList.add('show');
                setTimeout(() => tip.classList.remove('show'), 1100);
                window.showToast && window.showToast('Erro de rede ao adicionar ao carrinho.', false);
              } finally {
                btn.classList.remove('is-loading');
                btn.removeAttribute('aria-busy');
                btn.disabled = false;
              }
            });
          });

          // ---- sincroniza contador ao abrir a Home ----
          (async function syncCountOnLoad(){
            try {
              const r = await fetch('/Carrinho/Count', { cache: 'no-store', credentials: 'same-origin' });
              if (!r.ok) return;
              const data = await r.json();
              if (typeof data.count !== 'undefined' && window.updateCartBadges) window.updateCartBadges(data.count);
            } catch {}
          })();
        });
    </script>
}

