@model List<ProdutoModel>

<!-- Hero Section -->
<div class="hero-section bg-light p-5 mb-5 text-center text-white" style="background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);">
    <div class="container">
        <h1 class="display-4 fw-bold">Bem-vindo à PodsPlatform</h1>
        <p class="lead fs-4">Os melhores pods eletrônicos do mercado!</p>
    </div>
</div>

<!-- Produtos em Destaque -->
<div class="container mb-5">
    <h2 class="mb-4 text-center fw-bold">🔥 Produtos em Destaque</h2>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var produto in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 produto-card hover-shadow">
                        <img src="@produto" class="card-img-top img-fluid rounded-top" alt="@produto.Nome" style="object-fit: cover; height: 200px;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">@produto.Nome</h5>
                            <p class="card-text text-muted small flex-grow-1">@produto.Descricao</p>
                            <p class="text-success fw-bold fs-5 mb-3">R$ @produto.Preco</p>
                            <a asp-controller="Carrinho" asp-action="Adicionar" asp-route-produtoId="@produto.Id"
                               class="btn btn-primary w-100 mt-auto">Adicionar ao Carrinho</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-muted">Nenhum produto em destaque no momento.</p>
            </div>
        }
    </div>
</div>

<!-- Estilo extra opcional -->
<style>
    .produto-card:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
    }

    @("@media (max-width: 576px)") {
        .hero-section

    {
        padding: 3rem 1rem;
    }

    .hero-section h1 {
        font-size: 2rem;
    }

    .hero-section p {
        font-size: 1.1rem;
    }

    }
</style>
