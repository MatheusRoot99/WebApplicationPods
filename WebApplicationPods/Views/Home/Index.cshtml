@model WebApplicationPods.Models.ProdutoListagemViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/home-index.css" asp-append-version="true" />
}

<div class="home-index">

    <!-- Hero -->
    <section class="hero-section text-center text-white mb-4">
        <div class="container">
            <h1 class="display-4 fw-bold">Bem-vindo à PodsPlatform</h1>
            <p class="lead fs-5 mb-0">Os melhores pods eletrônicos do mercado!</p>
        </div>
    </section>

    <!-- Filtros e Ordenação -->
    <div class="container mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2 filters-toolbar">
            <h5 class="mb-0 fw-bold">Buscar produtos</h5>
            <!-- Toggle dos filtros no mobile -->
            <button class="filters-toggle d-lg-none" type="button"
                    data-bs-toggle="collapse" data-bs-target="#filtersCollapse"
                    aria-expanded="false" aria-controls="filtersCollapse">
                <i class="fas fa-sliders-h"></i> Filtros e Ordenação
            </button>
        </div>

        <div class="collapse d-lg-block" id="filtersCollapse">
            <form asp-action="Index" method="get" class="filters-card card border-0 p-3 mb-3">
                <div class="row g-3">
                    <!-- Categoria -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label asp-for="Filtros.Categoria" class="form-label">Categoria</label>
                        <select asp-for="Filtros.Categoria" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.CategoriasDisponiveis))">
                            <option value="">Todas Categorias</option>
                        </select>
                    </div>

                    <!-- Sabor -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label asp-for="Filtros.Sabor" class="form-label">Sabor</label>
                        <select asp-for="Filtros.Sabor" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.SaboresDisponiveis))">
                            <option value="">Todos Sabores</option>
                        </select>
                    </div>

                    <!-- Preço Mín -->
                    <div class="col-6 col-lg-2">
                        <label asp-for="Filtros.PrecoMin" class="form-label">Preço mín</label>
                        <input asp-for="Filtros.PrecoMin" type="number" step="0.01" min="0" class="form-control" placeholder="R$">
                    </div>

                    <!-- Preço Máx -->
                    <div class="col-6 col-lg-2">
                        <label asp-for="Filtros.PrecoMax" class="form-label">Preço máx</label>
                        <input asp-for="Filtros.PrecoMax" type="number" step="0.01" min="0" class="form-control" placeholder="R$">
                    </div>

                    <!-- Ordenar por -->
                    <div class="col-12 col-lg-2">
                        <label asp-for="Filtros.OrdenarPor" class="form-label">Ordenar por</label>
                        <select asp-for="Filtros.OrdenarPor" class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.OpcoesOrdenacao, "Key", "Value"))">
                        </select>
                    </div>

                    <!-- Checkboxes + Botões -->
                    <div class="col-12">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" asp-for="Filtros.ApenasPromocoes" id="ckPromo">
                                    <label class="form-check-label" for="ckPromo">Promoções</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" asp-for="Filtros.ApenasEstoque" id="ckEstoque">
                                    <label class="form-check-label" for="ckEstoque">Em estoque</label>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-filter me-1"></i> Filtrar
                                </button>
                                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i> Limpar
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- Lista de Produtos -->
    <div class="container mb-5">
        <div class="row g-4">
            @if (Model.Produtos != null && Model.Produtos.Any())
            {
                @foreach (var produto in Model.Produtos)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 produto-card">
                            <!-- Imagem + badge -->
                            <div class="product-thumb">
                                @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                                {
                                    <a asp-controller="Produto" asp-action="DetalhesProdutos" asp-route-id="@produto.Id" class="d-block">
                                        <img src="@Url.Content(produto.ImagemUrl)" alt="@produto.Nome" />
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Produto" asp-action="DetalhesProdutos" asp-route-id="@produto.Id" class="d-flex align-items-center justify-content-center" style="height:100%; background:#f3f4f6;">
                                        <i class="fas fa-image fa-2x text-secondary"></i>
                                    </a>
                                }

                                @if (produto.Estoque <= 0)
                                {
                                    <span class="badge bg-danger badge-top-right">ESGOTADO</span>
                                }
                                else if (produto.EmPromocao)
                                {
                                    <span class="badge bg-success badge-top-right">PROMOÇÃO</span>
                                }
                            </div>

                            <div class="card-body d-flex flex-column">
                                <a asp-controller="Produto" asp-action="DetalhesProdutos" asp-route-id="@produto.Id" class="text-decoration-none">
                                    <h5 class="card-title mb-1">@produto.Nome</h5>
                                </a>

                                <p class="card-text text-muted small flex-grow-1">
                                    <i class="fas fa-smoking me-1"></i>@produto.Puffs puffs &nbsp;&nbsp;
                                    <i class="fas fa-battery-three-quarters me-1"></i>@produto.CapacidadeBateria mAh
                                </p>

                                <!-- Preços -->
                                <div class="price-line mb-2">
                                    @{
                                        var temPromo = produto.EmPromocao && produto.PrecoPromocional.HasValue;
                                        var precoBase = temPromo ? produto.PrecoPromocional.Value : produto.Preco;
                                    }
                                    @if (temPromo)
                                    {
                                        <span class="old">@produto.Preco.ToString("C")</span>
                                        <span class="current fs-5 ms-2">@precoBase.ToString("C")</span>
                                    }
                                    else
                                    {
                                        <span class="current fs-5">@precoBase.ToString("C")</span>
                                    }
                                </div>

                                <!-- Parcelamento -->
                                <p class="small text-muted mb-3">
                                    2x de @((precoBase / 2).ToString("C")) sem juros<br />
                                    ou @((precoBase * 0.9m).ToString("C")) à vista (10% OFF)
                                </p>

                                <!-- Comprar -->
                                <a asp-controller="Carrinho" asp-action="Adicionar" asp-route-produtoId="@produto.Id"
                                   class="btn btn-primary btn-buy w-100 mt-auto @(produto.Estoque <= 0 ? "disabled" : "")">
                                    @(produto.Estoque <= 0 ? "ESGOTADO" : "COMPRAR")
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info text-center py-4">
                        <i class="fas fa-info-circle me-2"></i>
                        Nenhum produto encontrado com os filtros selecionados.
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function(){
            // Auto-submit ao trocar ordenação
            const selOrdenar = document.getElementById('Filtros_OrdenarPor');
            if (selOrdenar) {
                selOrdenar.addEventListener('change', function(){
                    const form = this.closest('form');
                    form && form.submit();
                });
            }
        });
    </script>
}
