@model WebApplicationPods.Models.ProdutoListagemViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="home-index">

    <div class="topbar container-fluid">
        <div class="topbar-inner container px-0">
            <button class="topbar-btn" type="button"
                    data-bs-toggle="collapse" data-bs-target="#filtersCollapse"
                    aria-expanded="false" aria-controls="filtersCollapse">
                <i class="fa-solid fa-sliders"></i>
                <span>Filtrar</span>
            </button>

            <div class="topbar-select">
                <label for="Filtros_OrdenarPor" class="form-label m-0">Ordenar por</label>
                <select id="Filtros_OrdenarPor" name="OrdenarPor" class="form-select form-select-sm">
                    @foreach (var kv in Model.Filtros.OpcoesOrdenacao)
                    {
                        <option value="@kv.Key" selected="@(Model.Filtros.OrdenarPor == kv.Key)">
                            @kv.Value
                        </option>
                    }
                </select>
            </div>
        </div>
    </div>

    <section class="hero-section text-center text-white mb-3">
        <div class="container">
            <h1 class="display-6 fw-bold mb-1">
                Bem-vindo à @(Model.Loja?.Nome ?? "nossa loja")
            </h1>
            <p class="lead fs-6 mb-0">Os melhores produtos do mercado!</p>
        </div>
    </section>

    <div class="container mb-3">
        <div class="collapse d-lg-block" id="filtersCollapse">
            <form asp-area="" asp-action="Index" method="get" class="filters-card card border-0 p-3 mb-3" id="filtersForm">
                <div class="row g-3 align-items-end">

                    <div class="col-12 col-lg-4">
                        <label class="form-label">Buscar</label>
                        <input name="Termo"
                               value="@(Model.Filtros.Termo ?? "")"
                               class="form-control"
                               placeholder="Ex: Heineken, Pod, Whisky..." />
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">Categoria</label>
                        <select name="Categoria"
                                class="form-select"
                                asp-items="@(new SelectList(Model.Filtros.CategoriasDisponiveis, Model.Filtros.Categoria))">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Filtros.Categoria))">Todas Categorias</option>
                        </select>
                    </div>

                    <div class="col-6 col-lg-2">
                        <label class="form-label">Preço mín</label>
                        <input name="PrecoMin"
                               value="@(Model.Filtros.PrecoMin?.ToString() ?? "")"
                               type="number"
                               step="0.01"
                               min="0"
                               class="form-control"
                               placeholder="R$" />
                    </div>

                    <div class="col-6 col-lg-2">
                        <label class="form-label">Preço máx</label>
                        <input name="PrecoMax"
                               value="@(Model.Filtros.PrecoMax?.ToString() ?? "")"
                               type="number"
                               step="0.01"
                               min="0"
                               class="form-control"
                               placeholder="R$" />
                    </div>

                    <div class="col-12 col-lg-1 d-none d-lg-block">
                        <label class="form-label">Ord.</label>
                        <select name="OrdenarPor" class="form-select">
                            @foreach (var kv in Model.Filtros.OpcoesOrdenacao)
                            {
                                if (Model.Filtros.OrdenarPor == kv.Key)
                                {
                                    <option value="@kv.Key" selected="selected">@kv.Value</option>
                                }
                                else
                                {
                                    <option value="@kv.Key">@kv.Value</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="ApenasPromocoes"
                                           value="true"
                                           @(Model.Filtros.ApenasPromocoes ? "checked" : "")
                                           id="ckPromo">
                                    <label class="form-check-label" for="ckPromo">Promoções</label>
                                </div>

                                <div class="form-check form-check-inline">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="ApenasEstoque"
                                           value="true"
                                           @(Model.Filtros.ApenasEstoque ? "checked" : "")
                                           id="ckEstoque">
                                    <label class="form-check-label" for="ckEstoque">Em estoque</label>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-filter me-1"></i> Filtrar
                                </button>
                                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i> Limpar
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <div class="container mb-4">
        @if (Model.Produtos != null && Model.Produtos.Any())
        {
            <div class="product-grid">
                @foreach (var produto in Model.Produtos)
                {
                    var promoOk = produto.EmPromocao
                    && produto.PrecoPromocional.HasValue
                    && produto.PrecoPromocional.Value > 0
                    && produto.PrecoPromocional.Value < produto.Preco;

                    var precoAtual = promoOk ? produto.PrecoPromocional!.Value : produto.Preco;

                    var exigeSelecaoDeSabor =
                    produto.SaboresQuantidadesList != null &&
                    produto.SaboresQuantidadesList.Any(s => s.Quantidade > 0);

                    <article class="produto-card h-100">
                        <a asp-area=""
                           asp-controller="Produto"
                           asp-action="Detalhes"
                           asp-route-id="@produto.Id"
                           class="thumb-link"
                           aria-label="@produto.Nome">
                            <div class="product-thumb">
                                @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                                {
                                    <img src="@Url.Content(produto.ImagemUrl)" alt="@produto.Nome" />
                                }
                                else
                                {
                                    <div class="no-image">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }

                                @if (produto.Estoque <= 0)
                                {
                                    <span class="badge badge-top-right bg-danger">ESGOTADO</span>
                                }
                                else if (promoOk)
                                {
                                    <span class="badge badge-top-right bg-success">PROMOÇÃO</span>
                                }
                            </div>
                        </a>

                        <div class="card-body">
                            <a asp-area=""
                               asp-controller="Produto"
                               asp-action="Detalhes"
                               asp-route-id="@produto.Id"
                               class="text-decoration-none">
                                <h6 class="title text-truncate-2">@produto.Nome</h6>
                            </a>

                            @{
                                bool puffOk = produto.PodPuffs > 0;
                                bool batOk = int.TryParse(produto.PodCapacidadeBateria, out var bat) && bat > 0;
                                bool temSpecsPod = puffOk || batOk;

                                bool volumeOk = produto.BebidaVolumeMl.HasValue && produto.BebidaVolumeMl.Value > 0;

                                bool teorOk = false;
                                string teorTxt = "";
                                if (produto.BebidaTeorAlcoolico.HasValue && produto.BebidaTeorAlcoolico.Value > 0)
                                {
                                    teorOk = true;
                                    teorTxt = produto.BebidaTeorAlcoolico.Value.ToString("0.##") + "%";
                                }

                                bool embalagemOk = produto.BebidaEmbalagem.HasValue &&
                                produto.BebidaEmbalagem.Value != WebApplicationPods.Enum.BebidaEmbalagemTipo.NaoInformado;

                                bool qtdEmbOk = produto.BebidaQtdPorEmbalagem.HasValue &&
                                produto.BebidaQtdPorEmbalagem.Value > 0;

                                string embalagemTxt = "";
                                if (embalagemOk)
                                {
                                    embalagemTxt = produto.BebidaEmbalagem!.Value switch
                                    {
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Unidade => "Unidade",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Lata => "Lata",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.LongNeck => "Long Neck",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Garrafa => "Garrafa",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Fardo => "Fardo",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Caixa => "Caixa",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Pack => "Pack",
                                        _ => ""
                                    };
                                }

                                string embalagemResumo = "";
                                if (embalagemOk)
                                {
                                    var emb = produto.BebidaEmbalagem!.Value;
                                    bool embMultipla =
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Fardo ||
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Caixa ||
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Pack;

                                    if (embMultipla && qtdEmbOk)
                                        embalagemResumo = $"{embalagemTxt} {produto.BebidaQtdPorEmbalagem}un";
                                    else
                                        embalagemResumo = embalagemTxt;
                                }

                                bool temSpecsBebida = volumeOk || teorOk || !string.IsNullOrWhiteSpace(embalagemResumo);
                                bool pareceBebida = temSpecsBebida || !string.IsNullOrWhiteSpace(produto.BebidaTipo);
                            }

                            @if (temSpecsPod)
                            {
                                <div class="specs small text-muted">
                                    @if (puffOk)
                                    {
                                        <span><i class="fa-solid fa-smoking"></i>@produto.PodPuffs puffs</span>
                                    }

                                    @if (puffOk && batOk)
                                    {
                                        <span>•</span>
                                    }

                                    @if (batOk)
                                    {
                                        <span><i class="fa-solid fa-battery-three-quarters"></i>@bat mAh</span>
                                    }
                                </div>
                            }
                            else if (pareceBebida)
                            {
                                <div class="specs small text-muted">
                                    @if (volumeOk)
                                    {
                                        <span><i class="fa-solid fa-glass-water"></i>@produto.BebidaVolumeMl ml</span>
                                    }

                                    @if (volumeOk && teorOk)
                                    {
                                        <span>•</span>
                                    }

                                    @if (teorOk)
                                    {
                                        <span><i class="fa-solid fa-percent"></i>@teorTxt</span>
                                    }

                                    @if ((volumeOk || teorOk) && !string.IsNullOrWhiteSpace(embalagemResumo))
                                    {
                                        <span>•</span>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(embalagemResumo))
                                    {
                                        <span><i class="fa-solid fa-box"></i>@embalagemResumo</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="specs small text-muted"></div>
                            }

                            <div class="price-line">
                                @if (promoOk)
                                {
                                    <span class="old">@produto.Preco.ToString("C")</span>
                                }
                                <span class="current">@precoAtual.ToString("C")</span>
                            </div>

                            @if (produto.Estoque > 0)
                            {
                                if (exigeSelecaoDeSabor)
                                {
                                    <div class="quick-add-form">
                                        <a asp-area=""
                                           asp-controller="Produto"
                                           asp-action="Detalhes"
                                           asp-route-id="@produto.Id"
                                           class="quick-add text-decoration-none"
                                           title="Escolher sabor"
                                           aria-label="Escolher sabor de @produto.Nome">
                                            <i class="fa-solid fa-list-check" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <form asp-controller="Carrinho"
                                          asp-action="AdicionarItem"
                                          method="post"
                                          class="quick-add-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="produtoId" value="@produto.Id" />
                                        <input type="hidden" name="quantidade" value="1" />
                                        <input type="hidden" name="sabor" value="" />
                                        <input type="hidden" name="observacoes" value="" />
                                        <input type="hidden" name="buyNow" value="false" />

                                        <button type="submit"
                                                class="quick-add"
                                                data-product-id="@produto.Id"
                                                title="Adicionar ao carrinho"
                                                aria-label="Adicionar @produto.Nome ao carrinho">
                                            <i class="fa-solid fa-cart-plus qa-icon" aria-hidden="true"></i>
                                            <i class="fa-solid fa-spinner fa-spin qa-spin" aria-hidden="true"></i>
                                            <i class="fa-solid fa-check qa-done" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <div class="quick-add-form">
                                    <button type="button"
                                            class="quick-add disabled"
                                            disabled
                                            title="Produto esgotado">
                                        <i class="fa-solid fa-ban" aria-hidden="true"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info text-center">
                <i class="fas fa-box-open"></i>
                Nenhum produto encontrado. Tente ajustar os filtros para encontrar o que procura.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const ADDED_PRODUCTS_KEY = 'home_added_products';

            function getAddedProducts() {
                try {
                    const raw = localStorage.getItem(ADDED_PRODUCTS_KEY);
                    const parsed = raw ? JSON.parse(raw) : [];
                    return Array.isArray(parsed) ? parsed.map(String) : [];
                } catch {
                    return [];
                }
            }

            function saveAddedProducts(items) {
                localStorage.setItem(ADDED_PRODUCTS_KEY, JSON.stringify(items));
            }

            function addAddedProduct(productId) {
                if (!productId) return;
                const items = getAddedProducts();
                const id = String(productId);
                if (!items.includes(id)) {
                    items.push(id);
                    saveAddedProducts(items);
                }
            }

            function setButtonVisualState(btn, state) {
                if (!btn) return;

                const icon = btn.querySelector('.qa-icon');
                const spin = btn.querySelector('.qa-spin');
                const done = btn.querySelector('.qa-done');

                btn.classList.remove('is-loading', 'is-success');

                if (state === 'loading') {
                    btn.classList.add('is-loading');
                    btn.dataset.added = 'false';
                    if (icon) icon.style.display = 'none';
                    if (spin) spin.style.display = 'inline-block';
                    if (done) done.style.display = 'none';
                    return;
                }

                if (state === 'success') {
                    btn.classList.add('is-success');
                    btn.dataset.added = 'true';
                    if (icon) icon.style.display = 'none';
                    if (spin) spin.style.display = 'none';
                    if (done) done.style.display = 'inline-block';
                    return;
                }

                btn.dataset.added = 'false';
                if (icon) icon.style.display = 'inline-block';
                if (spin) spin.style.display = 'none';
                if (done) done.style.display = 'none';
            }

            function restoreAddedButtons() {
                const items = getAddedProducts();

                document.querySelectorAll('button.quick-add[data-product-id]').forEach(function (btn) {
                    const id = String(btn.dataset.productId || '');
                    if (items.includes(id)) {
                        setButtonVisualState(btn, 'success');
                    } else {
                        setButtonVisualState(btn, 'default');
                    }
                });
            }

            function updateCartBadges(count) {
                if (typeof window.updateCartCount === 'function') {
                    window.updateCartCount(count);
                    return;
                }

                document.querySelectorAll('[data-cart-count], .cart-count, #cartCount').forEach(function (el) {
                    el.textContent = count;
                    el.classList.add('cart-badge-animation');
                    setTimeout(() => el.classList.remove('cart-badge-animation'), 300);
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                const topbarSelect = document.getElementById('Filtros_OrdenarPor');
                const filtersForm = document.getElementById('filtersForm');

                if (topbarSelect && filtersForm) {
                    topbarSelect.addEventListener('change', function () {
                        const formSelect = filtersForm.querySelector('[name="OrdenarPor"]');
                        if (formSelect) formSelect.value = this.value;
                        filtersForm.submit();
                    });
                }

                if (filtersForm) {
                    const filterElements = filtersForm.querySelectorAll('select, input[type="number"], input[type="checkbox"]');
                    filterElements.forEach(el => {
                        if (el.id !== 'Filtros_OrdenarPor') {
                            el.addEventListener('change', () => filtersForm.submit());
                        }
                    });
                }

                restoreAddedButtons();
            });

            window.addEventListener('pageshow', restoreAddedButtons);

            document.addEventListener('submit', async function (e) {
                const formEl = e.target;

                if (!formEl.matches('form.quick-add-form')) return;

                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation();

                const btn = formEl.querySelector('.quick-add');
                if (!btn || btn.disabled || btn.classList.contains('disabled')) return;

                const productId = btn.dataset.productId;
                setButtonVisualState(btn, 'loading');

                try {
                    const response = await fetch(formEl.action, {
                        method: 'POST',
                        body: new FormData(formEl),
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Erro ao adicionar');
                    }

                    const data = await response.json();

                    if (!data || data.ok !== true) {
                        throw new Error((data && data.error) ? data.error : 'Erro ao adicionar');
                    }

                    addAddedProduct(productId);
                    setButtonVisualState(btn, 'success');

                    if (typeof data.count !== 'undefined') {
                        updateCartBadges(data.count);
                    }
                } catch (err) {
                    console.error(err);
                    setButtonVisualState(btn, 'default');
                    alert('Não foi possível adicionar o produto ao carrinho.');
                }
            }, true);
        })();
    </script>
}