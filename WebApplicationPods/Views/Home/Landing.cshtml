@{
    ViewData["Title"] = "Plataforma multi-loja";

    // ✅ Landing limpa (sem sidebar/topbar/bottomnav)
    ViewData["HideChrome"] = true;
    ViewData["BodyClass"] = "landing-page";

    // ✅ monta links com a MESMA porta do ambiente
    var scheme = Context.Request.Scheme;
    var port = Context.Request.Host.Port;
    var portPart = port.HasValue ? $":{port.Value}" : "";

    var adminUrl = $"{scheme}://admin.lvh.me{portPart}/";
    var painelUrl = $"{scheme}://painel.lvh.me{portPart}/";
    var lojaUrl = $"{scheme}://loja-1.lvh.me{portPart}/";

    // ✅ fallback: se você não estiver usando lvh.me, pelo menos não quebra
    // (opcional) se quiser, pode usar o host atual e só trocar subdomínio.
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

    @* TESTE: se isso aqui não ficar vermelho, a section Styles não está sendo renderizada *@
    <style>
        .__landing_css_test {
            color: #d00 !important;
            font-weight: 800;
        }
    </style>
}

<div class="landing-wrapper container py-4 py-md-5">

    <div class="row g-4 align-items-center">
        <!-- HERO -->
        <div class="col-12 col-lg-6">
            <div class="hero-badge mb-3">
                <span class="hero-pill">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i>
                    SaaS de conveniência multi-loja
                </span>
            </div>

            <h1 class="hero-title mb-3">
                Centralize suas lojas em um único painel.
            </h1>

            <p class="hero-subtitle mb-4">
                Cada lojista com seu próprio subdomínio, catálogo, pedidos e configurações.
                Você administra tudo em um painel único.
            </p>

            <div class="hero-actions mb-4 d-flex flex-wrap gap-2">
                <a href="@adminUrl" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-user-shield me-2"></i>
                    Admin
                </a>

                <a href="@painelUrl" class="btn btn-outline-primary btn-lg">
                    <i class="fa-solid fa-store me-2"></i>
                    Lojista
                </a>

                <a href="@lojaUrl" class="btn btn-outline-secondary btn-lg" target="_blank" rel="noopener">
                    <i class="fa-solid fa-cart-shopping me-2"></i>
                    Abrir Loja (ex.)
                </a>

                <a href="#como-funciona" class="btn btn-link btn-lg text-decoration-none">
                    <i class="fa-solid fa-circle-question me-2"></i>
                    Como funciona
                </a>
            </div>

            <div class="hero-hint small text-muted">
                Exemplo de loja:
                <code>@lojaUrl</code>
                <br />
                Em desenvolvimento: <strong>lojas ilimitadas</strong>, faturamento unificado e muito mais.
            </div>

            <div class="mt-3 __landing_css_test">
                (teste css) se este texto NÃO estiver vermelho, o CSS não carregou.
            </div>
        </div>

        <!-- CARD DIREITA -->
        <div class="col-12 col-lg-6">
            <div class="hero-card shadow-sm">
                <div class="hero-card-header">
                    <span class="hero-card-icon">
                        <i class="fa-solid fa-diagram-project"></i>
                    </span>
                    <div>
                        <h2 class="hero-card-title">Como os subdomínios funcionam?</h2>
                        <p class="hero-card-subtitle">
                            O endereço define automaticamente qual loja o cliente está acessando.
                        </p>
                    </div>
                </div>

                <ul class="hero-steps list-unstyled mb-3">
                    <li>
                        <span class="step-badge">1</span>
                        <div>
                            <strong>Admin cria a loja</strong>
                            <small>Ex.: subdomínio <code>loja-1</code> cadastrado no painel admin.</small>
                        </div>
                    </li>
                    <li>
                        <span class="step-badge">2</span>
                        <div>
                            <strong>Vincula um lojista</strong>
                            <small>O usuário recebe acesso ao painel do lojista daquela loja.</small>
                        </div>
                    </li>
                    <li>
                        <span class="step-badge">3</span>
                        <div>
                            <strong>Clientes acessam pelo link</strong>
                            <small>
                                Ex.: <code>@lojaUrl</code> – o sistema resolve a loja automaticamente.
                            </small>
                        </div>
                    </li>
                </ul>

                <div class="hero-card-footer">
                    <i class="fa-solid fa-lightbulb me-2"></i>
                    <span>
                        Em desenvolvimento use:
                        <code>admin.lvh.me:PORTA</code>, <code>painel.lvh.me:PORTA</code>, <code>loja-1.lvh.me:PORTA</code>.
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- BLOCO "como funciona" -->
    <div id="como-funciona" class="row g-3 mt-4 mt-md-5">
        <div class="col-12 col-md-4">
            <div class="landing-feature">
                <div class="landing-feature-icon">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <h3>Admin central</h3>
                <p>Crie lojas, defina planos, gerencie lojistas e acompanhe o uso da plataforma.</p>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="landing-feature">
                <div class="landing-feature-icon">
                    <i class="fa-solid fa-store"></i>
                </div>
                <h3>Painel do lojista</h3>
                <p>Cada lojista gerencia produtos, estoque, pedidos e configurações da própria loja.</p>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="landing-feature">
                <div class="landing-feature-icon">
                    <i class="fa-solid fa-cart-shopping"></i>
                </div>
                <h3>Experiência do cliente</h3>
                <p>O cliente acessa o subdomínio da loja e já cai no catálogo correto, sem confusão.</p>
            </div>
        </div>
    </div>
</div>
