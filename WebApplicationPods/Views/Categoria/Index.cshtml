@using WebApplicationPods.Models
@model IEnumerable<CategoriaModel>

@{
    ViewData["Title"] = "Gerenciamento de Categorias";
}

@section Styles {
    <link rel="stylesheet" href="~/css/categories-admin.css" asp-append-version="true" />
}

<div class="container-fluid px-3 px-md-4 categories-admin">

    <div class="page-head d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 mb-4">
        <h1 class="m-0">
            <i class="fas fa-tags me-2"></i>@ViewData["Title"]
        </h1>
        <a asp-action="Criar" class="btn btn-primary btn-lg w-100 w-md-auto">
            <i class="fas fa-plus-circle me-2"></i>Nova Categoria
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header brand-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
            <h5 class="m-0">
                <i class="fas fa-list me-2"></i>Lista de Categorias
            </h5>

            <div class="search-wrap">
                <div class="input-group input-group-sm">
                    <input type="text" id="searchInput" class="form-control" placeholder="Pesquisar...">
                    <button class="btn btn-outline-secondary" type="button">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">

            @if (TempData["MensagemSucesso"] is string ok && !string.IsNullOrWhiteSpace(ok))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @ok
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["MensagemErro"] is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @err
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- table-wrap garante rolagem horizontal no mobile -->
            <div class="table-wrap table-responsive">
                <table class="table table-hover table-striped align-middle" id="categoriasTable">
                    <thead class="table-light">
                        <tr>
                            <th width="30%">Nome</th>
                            <th width="50%">Descrição</th>
                            <th width="20%" class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyCategorias">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Nome">
                                    <div class="d-flex align-items-center">
                                        <span class="icon-category me-2 me-md-3">
                                            <i class="fas fa-tag"></i>
                                        </span>
                                        <strong>@item.Nome</strong>
                                    </div>
                                </td>
                                <td data-label="Descrição">
                                    @if (!string.IsNullOrEmpty(item.Descricao))
                                    {
                                        <span class="text-muted">@item.Descricao</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sem descrição</span>
                                    }
                                </td>
                                <td class="text-end" data-label="Ações">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Editar" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Excluir" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger" data-bs-toggle="tooltip" title="Excluir">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>

        <div class="card-footer bg-white">
            <div class="row align-items-center">
                <div class="col-12 col-md-6 mb-2 mb-md-0">
                    <p class="mb-0 text-muted">
                        Mostrando <strong>@Model.Count()</strong> categorias
                    </p>
                </div>
                <div class="col-12 col-md-6">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm justify-content-start justify-content-md-end mb-0">
                            <li class="page-item disabled"><span class="page-link">Anterior</span></li>
                            <li class="page-item active"><span class="page-link">1</span></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item"><a class="page-link" href="#">Próxima</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // tooltips
            $('[data-bs-toggle="tooltip"]').tooltip({ trigger: 'hover focus' });

            // filtro client-side
            $('#searchInput').on('keyup', function () {
                const value = $(this).val().toLowerCase();
                $('#categoriasTable tbody tr').each(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // toasts em mobile no lugar de tooltip
            if (window.matchMedia('(max-width: 768px)').matches) {
                $('[data-bs-toggle="tooltip"]').tooltip('dispose').on('click', function (e) {
                    e.preventDefault();
                    const title = this.getAttribute('title');
                    if (!title) return;
                    const toast = $(`
                      <div class="toast show position-fixed bottom-0 start-50 translate-middle-x mb-3" role="alert">
                        <div class="toast-body bg-primary text-white rounded">${title}</div>
                      </div>`);
                    $('body').append(toast);
                    setTimeout(() => toast.remove(), 1800);
                });
            }

            // feedback em botões (touch)
            $('.btn-outline-primary, .btn-outline-danger')
              .on('touchstart', function(){ $(this).addClass('active-scale'); })
              .on('touchend touchcancel', function(){ $(this).removeClass('active-scale'); });
        });
    </script>
}
