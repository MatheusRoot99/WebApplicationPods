@using WebApplicationPods.Models
@model CategoriaModel

@{
    // Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Excluir Categoria";
}

@section Styles {
    <link rel="stylesheet" href="~/css/categories-admin.css" asp-append-version="true" />
}

<div class="container-fluid px-3 px-md-4 py-3 categories-form">
    <div class="card shadow-sm">
        <div class="card-header danger-header">
            <h4 class="mb-0">
                <i class="fas fa-trash-alt me-2"></i>@ViewData["Title"]
            </h4>
        </div>

        <div class="card-body">
            <h5 class="mb-3">Você tem certeza que deseja excluir esta categoria?</h5>

            <dl class="row dl">
                <dt class="col-sm-3">Nome:</dt>
                <dd class="col-sm-9">@Model.Nome</dd>

                <dt class="col-sm-3">Descrição:</dt>
                <dd class="col-sm-9">@Model.Descricao</dd>
            </dl>

            <form asp-action="Excluir" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Confirmar Exclusão
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
