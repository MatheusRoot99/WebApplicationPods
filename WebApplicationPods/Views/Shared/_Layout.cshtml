@using System.Text.Json

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pods Eletrônicos</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Estilos gerais -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />

    <!-- Estilos específicos do layout -->
    <style>
       
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar (Desktop) -->
        <div class="bg-dark border-right d-none d-lg-block" id="sidebar-wrapper">
            <div class="sidebar-heading text-white py-4">
                <i class="fas fa-smoking me-2"></i><span class="fw-bold">Pods Eletrônicos</span>
            </div>
            <div class="list-group list-group-flush">
                <!-- NAVEGAÇÃO -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">NAVEGAÇÃO</div>
                    <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-tachometer-alt me-2"></i> Painel
                    </a>
                </div>

                <!-- CLIENTE -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">CLIENTE</div>
                    <a asp-controller="Produto" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-store me-2"></i> Catálogo
                    </a>
                    <a asp-controller="Carrinho" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-shopping-cart me-2"></i> Carrinho
                    </a>
                </div>

                <!-- LOJISTA -->
                @if (User.IsInRole("Lojista"))
                {
                    <div class="sidebar-section">
                        <div class="sidebar-section-title">LOJISTA</div>
                        <a asp-controller="Pedido" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-clipboard-list me-2"></i> Pedidos
                        </a>
                        <a asp-controller="Estoque" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-boxes me-2"></i> Estoque
                        </a>
                        <a asp-controller="Relatorio" asp-action="Vendas" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-chart-line me-2"></i> Relatórios
                        </a>
                    </div>
                }

                <!-- ADMIN -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section">
                        <div class="sidebar-section-title">ADMIN</div>
                        <a asp-controller="Produto" asp-action="Gerenciar" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-box-open me-2"></i> Gerenciar Produtos
                        </a>
                        <a asp-controller="Categoria" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-tags me-2"></i> Categorias
                        </a>
                        <a asp-controller="Usuario" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-users-cog me-2"></i> Usuários
                        </a>
                    </div>
                }

                <!-- USUÁRIO -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">USUÁRIO</div>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Cliente" asp-action="Perfil" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-user-circle me-2"></i> Perfil
                        </a>
                        <a asp-controller="Cliente" asp-action="Logout" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-sign-out-alt me-2"></i> Sair
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Cliente" asp-action="Login" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-sign-in-alt me-2"></i> Login
                        </a>
                        <a asp-controller="Cliente" asp-action="Register" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-user-plus me-2"></i> Registrar
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper">
            <!-- Top Navigation -->
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
                <div class="container-fluid">
                    <!-- Menu Mobile Toggle -->
                    <button class="btn btn-sm btn-dark d-lg-none"
                            id="mobile-menu-toggle"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#mobileMenu"
                            aria-controls="mobileMenu">
                        <i class="fas fa-bars"></i> Menu
                    </button>

                    <!-- Breadcrumb -->
                    <div class="d-none d-md-block ms-3">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i></a>
                                </li>
                                @if (ViewContext.RouteData.Values["controller"]?.ToString() != "Home")
                                {
                                    <li class="breadcrumb-item">
                                        <a asp-controller="@ViewContext.RouteData.Values["controller"]" asp-action="Index">
                                            @ViewContext.RouteData.Values["controller"]
                                        </a>
                                    </li>
                                }
                            </ol>
                        </nav>
                    </div>

                    <div class="navbar-collapse">
                        <ul class="navbar-nav ms-auto">
                            <!-- Carrinho (desktop; esconde no mobile para evitar duplicar com bottom nav) -->
                            @if (!User.IsInRole("Admin") && !User.IsInRole("Lojista"))
                            {
                                <li class="nav-item d-none d-lg-block">
                                    <a class="nav-link cart-link" asp-controller="Carrinho" asp-action="Index">
                                        <span class="cart-wrap position-relative d-inline-flex align-items-center">
                                            <i class="fas fa-shopping-cart fs-5"></i>
                                            <span id="cart-badge"
                                                  class="badge rounded-pill bg-danger position-absolute translate-middle"
                                                  style="top:-10%; left:90%;">
                                                @await Component.InvokeAsync("CarrinhoResumo")
                                                <span class="visually-hidden">itens no carrinho</span>
                                            </span>
                                        </span>
                                    </a>
                                </li>
                            }

                            <!-- Notificações (lojista) -->
                            @if (User.IsInRole("Lojista"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarNotifications" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-bell"></i>
                                        <span class="badge bg-danger">3</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><h6 class="dropdown-header">Novos pedidos</h6></li>
                                        <li><a class="dropdown-item" href="#"><i class="fas fa-receipt me-2"></i>Pedido #1234</a></li>
                                        <li><a class="dropdown-item" href="#"><i class="fas fa-receipt me-2"></i>Pedido #1235</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="#"><i class="fas fa-list me-2"></i>Ver todos</a></li>
                                    </ul>
                                </li>
                            }

                            <!-- Usuário -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>
                                    <span class="d-none d-sm-inline">@(User.Identity.IsAuthenticated? User.Identity.Name : "Conta")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Perfil"><i class="fas fa-user me-2"></i>Perfil</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i>Sair</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Login"><i class="fas fa-sign-in-alt me-2"></i>Login</a></li>
                                        <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Register"><i class="fas fa-user-plus me-2"></i>Registrar</a></li>
                                    }
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <!-- Main Content -->
            <div class="container-fluid px-4 py-3">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Menu Mobile Offcanvas -->
    <div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="mobileMenuLabel">
                <i class="fas fa-smoking me-2"></i><span class="fw-bold">Pods Eletrônicos</span>
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="list-group list-group-flush">
                <!-- NAVEGAÇÃO -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">NAVEGAÇÃO</div>
                    <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-tachometer-alt me-2"></i> Painel
                    </a>
                </div>

                <!-- CLIENTE -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">CLIENTE</div>
                    <a asp-controller="Produto" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-store me-2"></i> Catálogo
                    </a>
                    <a asp-controller="Carrinho" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="fas fa-shopping-cart me-2"></i> Carrinho
                    </a>
                </div>

                <!-- LOJISTA -->
                @if (User.IsInRole("Lojista"))
                {
                    <div class="sidebar-section">
                        <div class="sidebar-section-title">LOJISTA</div>
                        <a asp-controller="Pedido" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-clipboard-list me-2"></i> Pedidos
                        </a>
                        <a asp-controller="Estoque" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-boxes me-2"></i> Estoque
                        </a>
                        <a asp-controller="Relatorio" asp-action="Vendas" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-chart-line me-2"></i> Relatórios
                        </a>
                    </div>
                }

                <!-- ADMIN -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section">
                        <div class="sidebar-section-title">ADMIN</div>
                        <a asp-controller="Produto" asp-action="Gerenciar" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-box-open me-2"></i> Gerenciar Produtos
                        </a>
                        <a asp-controller="Categoria" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-tags me-2"></i> Categorias
                        </a>
                        <a asp-controller="Usuario" asp-action="Index" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-users-cog me-2"></i> Usuários
                        </a>
                    </div>
                }

                <!-- USUÁRIO -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">USUÁRIO</div>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Cliente" asp-action="Perfil" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-user-circle me-2"></i> Perfil
                        </a>
                        <a asp-controller="Cliente" asp-action="Logout" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-sign-out-alt me-2"></i> Sair
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Cliente" asp-action="Login" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-sign-in-alt me-2"></i> Login
                        </a>
                        <a asp-controller="Cliente" asp-action="Register" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="fas fa-user-plus me-2"></i> Registrar
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Navigation (mobile-only) -->
    @{
        var c = ViewContext.RouteData.Values["controller"]?.ToString();
        var a = ViewContext.RouteData.Values["action"]?.ToString();
        Func<string, string, string> IsActive = (ctrl, act) =>
        (string.Equals(c, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == null || string.Equals(a, act, StringComparison.OrdinalIgnoreCase))) ? "active" : "";
    }
    <nav class="mobile-bottom-nav d-lg-none" aria-label="Navegação inferior">
        <a class="mbn-item @IsActive("Home", "Index")" asp-controller="Home" asp-action="Index" aria-label="Início">
            <i class="fa-solid fa-house"></i>
            <span class="mbn-label">Início</span>
        </a>

        @* <a class="mbn-item @IsActive("Produto", "Index")" asp-controller="Produto" asp-action="Index" aria-label="Catálogo">
            <i class="fa-solid fa-heart"></i>
            <span class="mbn-label">Favoritos</span>
        </a> *@

        <a class="mbn-item @IsActive("Carrinho","Index")" asp-controller="Carrinho" asp-action="Index" aria-label="Carrinho">
            <i class="fa-solid fa-cart-shopping"></i>
            <span id="cart-badge-mobile" class="mbn-badge">
                @await Component.InvokeAsync("CarrinhoResumo") ?? 0
            </span>
            <span class="mbn-label">Carrinho</span>
        </a>

        @* <a class="mbn-item @IsActive("Pedido", "Index")" asp-controller="Pedido" asp-action="Index" aria-label="Pedidos">
            <i class="fa-solid fa-clipboard-list"></i>
            <span class="mbn-label">Pedidos</span>
        </a> *@

        @if (User.Identity.IsAuthenticated)
        {
            <a class="mbn-item @IsActive("Cliente", "Perfil")" asp-controller="Cliente" asp-action="Perfil" aria-label="Perfil">
                <i class="fa-solid fa-user"></i>
                <span class="mbn-label">Perfil</span>
            </a>
        }
        else
        {
            <a class="mbn-item @IsActive("Cliente", "Login")" asp-controller="Cliente" asp-action="Login" aria-label="Entrar">
                <i class="fa-solid fa-user"></i>
                <span class="mbn-label">Entrar</span>
            </a>
        }
    </nav>

    <!-- Toast container (notificações) -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index:1080">
        <div id="appToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="appToastBody"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/jquery.mask.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script src="~/js/sabores.js" asp-append-version="true"></script>

    <script>
        (function () {
          // Normaliza números dos badges (desktop e mobile)
          function normalizeBadge(id) {
            const el = document.getElementById(id);
            if (!el) return;
            const raw = (el.textContent || '').trim();
            const num = (raw.match(/\d+/) || ['0'])[0];
            el.textContent = num;
          }
          normalizeBadge('cart-badge');
          normalizeBadge('cart-badge-mobile');

          // Toast via TempData
          const sucesso = @Html.Raw(JsonSerializer.Serialize(TempData["Sucesso"] ?? ""));
          const erro    = @Html.Raw(JsonSerializer.Serialize(TempData["Erro"] ?? ""));
          if (sucesso || erro) {
            const toastEl = document.getElementById('appToast');
            const bodyEl  = document.getElementById('appToastBody');
            if (toastEl && bodyEl) {
              const ok = !!sucesso;
              bodyEl.textContent = ok ? sucesso : erro;
              toastEl.classList.toggle('bg-success', ok);
              toastEl.classList.toggle('bg-danger', !ok);
              new bootstrap.Toast(toastEl, { delay: 2500 }).show();

              // anima badge do mobile se relacionado ao carrinho
              const msg = (sucesso || erro || '').toString();
              if (/(carrinho|adicionado|atualizada|removido)/i.test(msg)) {
                const b = document.getElementById('cart-badge-mobile');
                if (b) { b.classList.remove('mbn-badge-bump'); void b.offsetWidth; b.classList.add('mbn-badge-bump'); }
              }
            }
          }

          // Fechar offcanvas ao clicar em um link
          document.querySelectorAll('#mobileMenu .list-group-item').forEach(item => {
            item.addEventListener('click', function () {
              const off = bootstrap.Offcanvas.getInstance(document.getElementById('mobileMenu'));
              off && off.hide();
            });
          });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
