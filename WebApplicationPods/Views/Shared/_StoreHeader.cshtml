@using WebApplicationPods.Models
@{
    // tenta pegar do ViewData/ViewBag; se não tiver, deixa null e aplica fallback controlado
    var hdr = (StoreHeaderViewModel?)ViewData["StoreHeader"]
              ?? (StoreHeaderViewModel?)ViewBag.StoreHeader;

    // URL absoluta para compartilhar
    var baseUrl = $"{Context.Request?.Scheme}://{Context.Request?.Host}";
    var pathBase = (Context.Request?.PathBase.HasValue == true) ? Context.Request.PathBase.Value : "";
    var defaultShareUrl = baseUrl + (string.IsNullOrWhiteSpace(pathBase) ? "/" : pathBase);

    // Fallbacks quando não há loja (www/localhost)
    var nome = !string.IsNullOrWhiteSpace(hdr?.Nome) ? hdr!.Nome : "Pods Eletrônicos";
    var logoUrl = string.IsNullOrWhiteSpace(hdr?.LogoUrl) ? null : hdr!.LogoUrl;
    var abertoAgora = hdr?.AbertoAgora ?? false;

    // Texto horário
    string textoHorario =
        hdr?.FechaAs.HasValue == true
            ? $"Aberto até {hdr!.FechaAs!.Value.Hours:D2}h{hdr.FechaAs.Value.Minutes:D2}"
            : (abertoAgora ? "Aberto agora" : "Fechado");

    string urlCompartilhar = !string.IsNullOrWhiteSpace(hdr?.UrlParaCompartilhar)
        ? hdr!.UrlParaCompartilhar!
        : defaultShareUrl;

    var mensagem = hdr?.MensagemStatus;
    var perfilUrl = hdr?.PerfilDaLojaUrl;
}

<div class="storebar">
    <div class="storebar-top">
        <div class="storebar-brand">
            <div class="storebar-logo">
                @if (!string.IsNullOrWhiteSpace(logoUrl))
                {
                    <img src="@logoUrl" alt="Logo do estabelecimento" />
                }
                else
                {
                    <div class="storebar-logo-fallback">
                        <i class="fas fa-store"></i>
                    </div>
                }
            </div>
            <div class="storebar-name">@nome</div>
        </div>

        <div class="storebar-actions">
            <button class="storebar-share" type="button"
                    data-share-title="@nome"
                    data-share-url="@urlCompartilhar">
                <i class="fas fa-share-nodes" aria-hidden="true"></i>
                <span class="visually-hidden">Compartilhar</span>
            </button>
        </div>
    </div>

    <div class="storebar-bottom">
        <div class="storebar-meta">
            <span class="badge-status @(abertoAgora ? "open" : "closed")">
                @(abertoAgora ? "Aberto" : "Fechado")
            </span>
            <span class="dot">•</span>
            <span>@textoHorario</span>

            @* Mensagem opcional *@
            @if (!string.IsNullOrWhiteSpace(mensagem))
            {
                <span class="dot">•</span>
                <span>@mensagem</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(perfilUrl))
        {
            <a href="@perfilUrl" class="storebar-link">Perfil da loja</a>
        }
    </div>
</div>

<script>
    (function () {
        // Compartilhar (Web Share API + fallback)
        const btn = document.querySelector('.storebar-share');
        if (!btn) return;

        btn.addEventListener('click', async () => {
            const title = btn.getAttribute('data-share-title') || document.title;
            const url = btn.getAttribute('data-share-url') || window.location.href;

            if (navigator.share) {
                try {
                    await navigator.share({ title, url });
                } catch(e) {
                    // cancelado/erro
                }
            } else {
                try {
                    await navigator.clipboard.writeText(url);
                    toast('Link copiado!');
                } catch {
                    window.prompt('Copie o link:', url);
                }
            }
        });

        // Toast simples
        function toast(msg) {
            const el = document.createElement('div');
            el.className = 'storebar-toast';
            el.textContent = msg;
            document.body.appendChild(el);
            setTimeout(() => el.classList.add('show'));
            setTimeout(() => { el.classList.remove('show'); el.remove(); }, 2500);
        }
    })();
</script>
