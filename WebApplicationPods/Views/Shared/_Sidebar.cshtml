@using WebApplicationPods.Infra
@* Sidebar (Desktop) *@
@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isLojista = User.IsInRole("Lojista");
}

<div class="bg-dark border-right d-none d-lg-block" id="sidebar-wrapper">
    <div class="sidebar-heading text-white py-4">
        <i class="fas fa-smoking me-2"></i><span class="fw-bold">Pods Eletrônicos</span>
    </div>

    <div class="list-group list-group-flush">

        <!-- NAVEGAÇÃO -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">NAVEGAÇÃO</div>

            <!-- FORÇA o site público -->
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="list-group-item list-group-item-action bg-dark text-white">
                <i class="fas fa-tachometer-alt me-2"></i> Home
            </a>
        </div>

        <!-- CLIENTE -->
        @if (!isAdmin && !isLojista)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">CLIENTE</div>

                <!-- FORÇA o site público -->
                <a asp-area="" asp-controller="Carrinho" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-shopping-cart me-2"></i> Carrinho
                </a>
            </div>
        }

        <!-- LOJISTA -->
        @if (isLojista)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">LOJISTA</div>


                <a asp-area="PainelLojista" asp-controller="Dashboard" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-gauge me-2"></i> Dashboard
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="PedidosAdmin" asp-action="Relatorio"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-chart-line me-2"></i> Relatórios
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Estoque" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-boxes me-2"></i> Estoque
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="PedidosAdmin" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-clipboard-list me-2"></i> Pedidos
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Categoria" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-tags me-2"></i> Categorias
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Produto" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-box-open me-2"></i> Gerenciar Produtos
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="PaymentConfig" asp-action="Edit" asp-route-provider="Stripe"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-credit-card me-2"></i> Configurações de Pagamento
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Loja" asp-action="Editar"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-store me-2"></i> Configurações da Loja
                </a>
            </div>
        }

        <!-- ADMIN -->
        @if (isAdmin)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">ADMIN</div>

                <a asp-area="@AppAreas.Admin" asp-controller="Dashboard" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-gauge me-2"></i> Dashboard
                </a>

                <a asp-area="@AppAreas.Admin" asp-controller="Lojas" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-store me-2"></i> Lojas
                </a>

                <a asp-area="@AppAreas.Admin" asp-controller="Lojistas" asp-action="Index"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-users me-2"></i> Usuários (Lojistas)
                </a>
            </div>
        }

        <!-- USUÁRIO -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">USUÁRIO</div>

            @if (isAuth)
            {
                <!-- FORÇA o site público -->
                <a asp-area="" asp-controller="Cliente" asp-action="Perfil"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-user-circle me-2"></i> Perfil
                </a>

                <form asp-area="" asp-controller="Conta" asp-action="Logout" method="post" class="list-group-item bg-dark">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link text-white p-0">
                        <i class="fas fa-sign-out-alt me-2"></i> Sair
                    </button>
                </form>
            }
            else
            {
                <!-- FORÇA o site público -->
                <a asp-area="" asp-controller="Conta" asp-action="Login"
                   class="list-group-item list-group-item-action bg-dark text-white">
                    <i class="fas fa-sign-in-alt me-2"></i> Login
                </a>
            }
        </div>

    </div>
</div>
