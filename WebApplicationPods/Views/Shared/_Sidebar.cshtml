@using WebApplicationPods.Infra

@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isLojista = User.IsInRole("Lojista");

    string currentArea = (ViewContext.RouteData.Values["area"]?.ToString() ?? "");
    string currentCtrl = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "");

    string Active(string area, string controller)
    {
        bool sameArea = string.Equals(currentArea ?? "", area ?? "", StringComparison.OrdinalIgnoreCase);
        bool sameCtrl = string.Equals(currentCtrl ?? "", controller ?? "", StringComparison.OrdinalIgnoreCase);
        return (sameArea && sameCtrl) ? "is-active" : "";
    }

    var isProdutoMenuOpen =
        string.Equals(currentArea ?? "", AppAreas.Lojista ?? "", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentCtrl ?? "", "Produto", StringComparison.OrdinalIgnoreCase);

    var produtoCollapseShow = isProdutoMenuOpen ? "show" : "";
    var produtoExpanded = isProdutoMenuOpen ? "true" : "false";
}

<div class="border-right d-none d-lg-block" id="sidebar-wrapper">
    <div class="sidebar-heading">
        <div class="sidebar-brand">
            <div class="brand-badge">
                <i class="fas fa-store"></i>
            </div>
            <div class="d-flex flex-column">
                <div class="brand-title">Conveniência</div>
                <div class="brand-subtitle">Painel</div>
            </div>
        </div>
    </div>

    <div class="list-group list-group-flush">

        <!-- NAVEGAÇÃO -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Navegação</div>

            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="list-group-item list-group-item-action @Active("", "Home")">
                <i class="fas fa-house"></i> Home
            </a>
        </div>

        <!-- CLIENTE -->
        @if (!isAdmin && !isLojista)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">Cliente</div>

                <a asp-area="" asp-controller="Carrinho" asp-action="Index"
                   class="list-group-item list-group-item-action @Active("", "Carrinho")">
                    <i class="fas fa-shopping-cart"></i> Carrinho
                </a>
            </div>
        }

        <!-- LOJISTA -->
        @if (isLojista)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">Lojista</div>

                <a asp-area="PainelLojista" asp-controller="Dashboard" asp-action="Index"
                   class="list-group-item list-group-item-action @Active("PainelLojista", "Dashboard")">
                    <i class="fas fa-gauge"></i> Dashboard
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="PedidosAdmin" asp-action="Relatorio"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "PedidosAdmin")">
                    <i class="fas fa-chart-line"></i> Relatórios
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Estoque" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "Estoque")">
                    <i class="fas fa-boxes"></i> Estoque
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="PedidosAdmin" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "PedidosAdmin")">
                    <i class="fas fa-clipboard-list"></i> Pedidos
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Categoria" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "Categoria")">
                    <i class="fas fa-tags"></i> Categorias
                </a>

                <!-- Produtos (submenu) -->
                <a class="list-group-item list-group-item-action nav-parent @(isProdutoMenuOpen ? "has-sub-active" : "")"
                   data-bs-toggle="collapse"
                   href="#menuProdutos"
                   role="button"
                   aria-expanded="@produtoExpanded"
                   aria-controls="menuProdutos">
                    <span class="d-flex align-items-center gap-2">
                        <i class="fas fa-box-open"></i> Produtos
                    </span>
                    <i class="fas fa-chevron-down chev"></i>
                </a>

                <div class="collapse @produtoCollapseShow" id="menuProdutos">
                    <div class="nav-sub">
                        <a class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "Produto")"
                           asp-area="@AppAreas.Lojista" asp-controller="Produto" asp-action="Index">
                            <i class="fas fa-list"></i> Catálogo
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-area="@AppAreas.Lojista" asp-controller="Produto" asp-action="CriarPadrao">
                            <i class="fas fa-plus"></i> Novo Padrão
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-area="@AppAreas.Lojista" asp-controller="Produto" asp-action="CriarBebida">
                            <i class="fas fa-wine-bottle"></i> Nova Bebida
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-area="@AppAreas.Lojista" asp-controller="Produto" asp-action="CriarPod">
                            <i class="fas fa-smoking"></i> Novo Pod
                        </a>
                    </div>
                </div>

                <a asp-area="@AppAreas.Lojista" asp-controller="PaymentConfig" asp-action="Edit" asp-route-provider="Stripe"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "PaymentConfig")">
                    <i class="fas fa-credit-card"></i> Pagamento
                </a>

                <a asp-area="@AppAreas.Lojista" asp-controller="Loja" asp-action="Editar"
                   class="list-group-item list-group-item-action @Active(AppAreas.Lojista, "Loja")">
                    <i class="fas fa-store"></i> Configurações da Loja
                </a>
            </div>
        }

        <!-- ADMIN -->
        @if (isAdmin)
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">Admin</div>

                <a asp-area="@AppAreas.Admin" asp-controller="Dashboard" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Admin, "Dashboard")">
                    <i class="fas fa-gauge"></i> Dashboard
                </a>

                <a asp-area="@AppAreas.Admin" asp-controller="Lojas" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Admin, "Lojas")">
                    <i class="fas fa-store"></i> Lojas
                </a>

                <a asp-area="@AppAreas.Admin" asp-controller="Lojistas" asp-action="Index"
                   class="list-group-item list-group-item-action @Active(AppAreas.Admin, "Lojistas")">
                    <i class="fas fa-users"></i> Usuários (Lojistas)
                </a>
            </div>
        }

        <!-- USUÁRIO -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">Usuário</div>

            @if (isAuth)
            {
                <a asp-area="" asp-controller="Cliente" asp-action="Perfil"
                   class="list-group-item list-group-item-action @Active("", "Cliente")">
                    <i class="fas fa-user-circle"></i> Perfil
                </a>

                <form asp-area="" asp-controller="Conta" asp-action="Logout" method="post"
                      class="list-group-item list-group-item-action">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-btn">
                        <i class="fas fa-sign-out-alt"></i> Sair
                    </button>
                </form>
            }
            else
            {
                <a asp-area="" asp-controller="Conta" asp-action="Login"
                   class="list-group-item list-group-item-action @Active("", "Conta")">
                    <i class="fas fa-sign-in-alt"></i> Login
                </a>
            }
        </div>

    </div>
</div>
