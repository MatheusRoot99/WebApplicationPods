@using WebApplicationPods.Infra
@* Bottom Navigation (mobile-only) *@
<link rel="stylesheet" href="~/css/_BottomNav.css" asp-append-version="true" />

@{
    var c = ViewContext.RouteData.Values["controller"]?.ToString();
    var a = ViewContext.RouteData.Values["action"]?.ToString();
    var area = ViewContext.RouteData.Values["area"]?.ToString();

    Func<string, string, string?, string> IsActive = (ctrl, act, ar) =>
        (string.Equals(c, ctrl, StringComparison.OrdinalIgnoreCase) &&
         (act == null || string.Equals(a, act, StringComparison.OrdinalIgnoreCase)) &&
         (string.Equals(area ?? "", ar ?? "", StringComparison.OrdinalIgnoreCase)))
        ? "active" : "";

    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isLojista = User.IsInRole("Lojista");
}

<nav class="mobile-bottom-nav d-lg-none" aria-label="Navegação inferior">
    <!-- Início -->
    <a class="mbn-item @IsActive("Home", "Index", null)"
       asp-controller="Home"
       asp-action="Index"
       aria-label="Início">
        <span class="mbn-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
                <path d="M3 10.5L12 3l9 7.5" />
                <path d="M5.5 9.5V20h5.5v-5h2v5H18.5V9.5" />
            </svg>
        </span>
        <span class="mbn-label">Início</span>
    </a>

    <!-- Pedidos -->
    @if (isLojista)
    {
        <a class="mbn-item @IsActive("PedidosAdmin", "Index", AppAreas.Lojista)"
           asp-area="@AppAreas.Lojista"
           asp-controller="PedidosAdmin"
           asp-action="Index"
           aria-label="Pedidos">
            <span class="mbn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 6.5h12" />
                    <path d="M8 12h12" />
                    <path d="M8 17.5h12" />
                    <path d="M4 6.5h.01" />
                    <path d="M4 12h.01" />
                    <path d="M4 17.5h.01" />
                </svg>
            </span>
            <span class="mbn-label">Pedidos</span>
        </a>
    }
    else
    {
        <a class="mbn-item @IsActive("Pedido", "Ultimo", null)"
           asp-controller="Pedido"
           asp-action="Ultimo"
           aria-label="Pedidos">
            <span class="mbn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 6.5h12" />
                    <path d="M8 12h12" />
                    <path d="M8 17.5h12" />
                    <path d="M4 6.5h.01" />
                    <path d="M4 12h.01" />
                    <path d="M4 17.5h.01" />
                </svg>
            </span>
            <span class="mbn-label">Pedidos</span>
        </a>
    }

    <!-- Carrinho -->
    <a class="mbn-item @IsActive("Carrinho", "Index", null)"
       asp-controller="Carrinho"
       asp-action="Index"
       aria-label="Carrinho">
        <span class="mbn-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
                <path d="M3.5 5H5.2c.6 0 .9.2 1.1.9l.5 2.1m0 0L8 14.5c.1.7.5 1 1.2 1h8.7c.7 0 1.1-.3 1.3-.9L21 8H6.8Z" />
                <path d="M10 19.5a1 1 0 1 1 0 .01" />
                <path d="M17.5 19.5a1 1 0 1 1 0 .01" />
            </svg>
        </span>
        <span id="cart-badge-mobile-bottom" class="mbn-badge js-cart-badge">0</span>
        <span id="cart-new-dot" class="mbn-dot visually-hidden"></span>
        <span class="mbn-label">Carrinho</span>
    </a>

    <!-- Perfil/Entrar -->
    @if (isAuth && !isAdmin && !isLojista)
    {
        <a class="mbn-item mbn-item--auth @IsActive("Cliente", "Perfil", null)"
           asp-controller="Cliente"
           asp-action="Perfil"
           aria-label="Perfil">
            <span class="mbn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
                    <path d="M4.5 20a7.5 7.5 0 0 1 15 0" />
                </svg>
            </span>
            <span class="mbn-label">Perfil</span>
        </a>
    }
    else
    {
        <a class="mbn-item mbn-item--auth @IsActive("Conta", "Login", null)"
           asp-controller="Conta"
           asp-action="Login"
           aria-label="Entrar">
            <span class="mbn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
                    <path d="M4.5 20a7.5 7.5 0 0 1 15 0" />
                </svg>
            </span>
            <span class="mbn-label">Entrar</span>
        </a>
    }
</nav>