@* Bottom Navigation (mobile-only) *@
<link rel="stylesheet" href="~/css/_BottomNav.css" asp-append-version="true" />

@{
    var c = ViewContext.RouteData.Values["controller"]?.ToString();
    var a = ViewContext.RouteData.Values["action"]?.ToString();
    Func<string, string, string> IsActive = (ctrl, act) =>
        (string.Equals(c, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == null || string.Equals(a, act, StringComparison.OrdinalIgnoreCase))) ? "active" : "";

    var isAuth = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isLojista = User.IsInRole("Lojista");
}

<nav class="mobile-bottom-nav d-lg-none" aria-label="Navegação inferior">
    <!-- Início -->
    <a class="mbn-item @IsActive("Home", "Index")"
       asp-controller="Home" asp-action="Index" aria-label="Início">
        <i class="fa-solid fa-house"></i>
        <span class="mbn-label">Início</span>
    </a>

    <!-- Pedidos -->
    <a class="mbn-item @IsActive("Pedido", "Ultimo")"
       asp-controller="Pedido" asp-action="Ultimo" aria-label="Pedidos">
        <i class="fa-solid fa-list"></i>
        <span class="mbn-label">Pedidos</span>
    </a>

    <!-- Carrinho -->
    <a class="mbn-item @IsActive("Carrinho", "Index")"
       asp-controller="Carrinho" asp-action="Index" aria-label="Carrinho">
        <i class="fa-solid fa-cart-shopping"></i>

        <!-- badge numérico (já existia) -->
        <span id="cart-badge-mobile-bottom" class="mbn-badge js-cart-badge">0</span>

        <!-- dot persistente -->
        <span id="cart-new-dot" class="mbn-dot visually-hidden"></span>

        <span class="mbn-label">Carrinho</span>
    </a>

    <!-- Perfil/Entrar -->
    @* REMOVIDO: Perfil/Entrar na nav mobile *@
    @if (isAuth && !isAdmin && !isLojista)
    {
        <a class="mbn-item mbn-item--auth @IsActive("Cliente", "Perfil")"
           asp-controller="Cliente" asp-action="Perfil" aria-label="Perfil">
            <i class="fa-solid fa-user"></i>
            <span class="mbn-label">Perfil</span>
        </a>
    }
    else
    {
        <a class="mbn-item mbn-item--auth @IsActive("Conta", "Login")"
           asp-controller="Conta" asp-action="Login" aria-label="Entrar">
            <i class="fa-solid fa-user"></i>
            <span class="mbn-label">Entrar</span>
        </a>
    }
</nav>
