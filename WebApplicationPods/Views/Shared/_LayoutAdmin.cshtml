@using Microsoft.AspNetCore.Identity
@using WebApplicationPods.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var userName = User?.Identity?.IsAuthenticated == true
        ? (User.Identity!.Name ?? "Admin")
        : "Admin";

    var isAdmin = User.IsInRole("Admin");

    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Painel Administrativo</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="admin-shell">
        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="brand">
                <div class="brand-logo">
                    <i class="fa-solid fa-store"></i>
                </div>
                <div class="brand-text">
                    <span>Pods Eletrônicos</span>
                    <span>Painel Administrativo</span>
                </div>
            </div>

            <div class="admin-user">
                <div class="admin-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div>
                    <div class="admin-user-name">@userName</div>
                    <div class="admin-user-role">@((isAdmin ? "Admin" : "Usuário"))</div>
                </div>
            </div>

            <div class="admin-menu-title">Menu principal</div>
            <ul class="admin-menu">
                <li>
                    <a asp-area="Admin"
                       asp-controller="Dashboard"
                       asp-action="Index"
                       class="@(currentController == "Dashboard" ? "active" : "")">
                        <i class="fa-solid fa-gauge"></i> Dashboard
                    </a>
                </li>

                <li>
                    <a asp-area="Admin"
                       asp-controller="Lojas"
                       asp-action="Index"
                       class="@(currentController == "Lojas" ? "active" : "")">
                        <i class="fa-solid fa-store"></i> Lojas
                    </a>
                </li>

                <li>
                    <a asp-area="Admin"
                       asp-controller="Lojistas"
                       asp-action="Index"
                       class="@(currentController == "Lojistas" ? "active" : "")">
                        <i class="fa-solid fa-users"></i> Usuários (Lojistas)
                    </a>
                </li>
            </ul>

            <div class="admin-sidebar-footer">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Conta" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-light w-100 btn-sm" type="submit">
                            <i class="fa-solid fa-arrow-right-from-bracket me-1"></i>
                            Sair da conta
                        </button>
                    </form>
                }
            </div>
        </aside>

        <!-- MAIN -->
        <div class="admin-main">
            <header class="admin-topbar">
                <div class="d-flex w-100 align-items-center justify-content-between gap-3 flex-wrap">
                    <div class="admin-topbar-title">
                        @ViewData["Title"]
                    </div>

                    @if (isAdmin)
                    {
                        <div>
                            @await Component.InvokeAsync("AdminLojaPicker")
                        </div>
                    }
                </div>
            </header>

            <main class="admin-main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
