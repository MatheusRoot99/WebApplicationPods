@using WebApplicationPods.Models
@model IEnumerable<ProdutoModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Catálogo de Pods Eletrônicos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/produtos-index.css" asp-append-version="true" />
}

<div class="container-fluid px-0 produtos-page">
    <!-- Header -->
    <header class="gradient-header py-4 mb-4 shadow">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center text-center text-md-start">
                <div class="mb-3 mb-md-0">
                    <h1 class="display-6 text-white fw-bold mb-1">@ViewData["Title"]</h1>
                    <p class="text-white-50 mb-0">Gerencie seu inventário de pods eletrônicos</p>
                </div>
                <a asp-action="Criar" class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i> Novo Produto
                </a>
            </div>
        </div>
    </header>

    <!-- Flash messages -->
    <div class="container container-full-lg">
        @await Html.PartialAsync("_Flash")
    </div>

    <!-- CONTEÚDO (100% largura no desktop) -->
    <div id="pageRoot" class="container-fluid px-0 page-has-bottom-nav">
        @if (!Model.Any())
        {
            <div class="container">
                <div class="alert alert-info shadow-sm text-center">
                    Nenhum produto cadastrado. Clique em <b>Novo Produto</b> para começar.
                </div>
            </div>
        }
        else
        {
            <!-- Barra de busca -->
            <div class="container-fluid px-3 px-xl-4 mb-4">
                <div class="row g-3 align-items-center">
                    <div class="col-lg-8 col-xl-6">
                        <div class="search-box input-group rounded-pill shadow-sm">
                            <span class="input-group-text bg-white border-0 ps-4"><i class="fas fa-search"></i></span>
                            <input type="text" class="form-control border-0" id="searchInput" placeholder="Pesquisar por nome, categoria, sabor...">
                        </div>
                    </div>
                    <div class="col-lg-4 col-xl-6 text-lg-end text-center">
                        <button class="btn btn-outline-primary rounded-pill filter-btn active" data-filter="all">Todos</button>
                    </div>
                </div>
            </div>

            <!-- Tabela Desktop (full width) -->
            <div class="d-none d-lg-block">
                <div class="container-fluid px-3 px-xl-4">
                    <div class="table-responsive rounded-3 shadow-sm">
                        <table class="table table-hover align-middle mb-0 produtos-table">
                            <thead class="table-light">
                                <tr class="text-center">
                                    <th class="ps-4 text-start col-produto">Produto</th>
                                    <th class="col-preco">Preço</th>
                                    <th class="col-promocao">Promoção</th>
                                    <th class="col-categoria">Categoria</th>
                                    <th class="col-estoque">Estoque</th>
                                    <th class="col-sabores">Sabores (estoque)</th>
                                    <th class="col-puffs">Puffs</th>
                                    <th class="col-bateria">Bateria</th>
                                    <th class="col-cadastro">Cadastro</th>
                                    <th class="col-ativo">Ativo</th>
                                    <th class="text-end pe-4 col-acoes">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var statusClass = item.Ativo ? "" : "table-secondary opacity-75";
                                    var estoqueClass = item.Estoque <= 5 ? "text-warning" : "text-dark";
                                    var sabores = (item.SaboresQuantidadesList ?? new List<ProdutoModel.SaborQuantidade>())
                                    .Where(sq => sq.Quantidade >= 0)
                                    .OrderByDescending(sq => sq.Quantidade)
                                    .ToList();

                                    var topChips = sabores.Take(4).ToList();
                                    var hiddenChips = sabores.Skip(4).ToList();
                                    var temMais = hiddenChips.Any();
                                    var popoverText = string.Join(", ", hiddenChips.Select(sq => $"{sq.Sabor} ({sq.Quantidade})"));

                                    <tr class="@statusClass">
                                        <!-- Produto -->
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="product-img-container me-3">
                                                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                                    {
                                                        <img src="@item.ImagemUrl" alt="Imagem @item.Nome" class="product-img rounded-3 shadow-sm" loading="lazy">
                                                    }
                                                    else
                                                    {
                                                        <div class="product-img-placeholder rounded-3 shadow-sm">
                                                            <i class="fas fa-box"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="text-truncate">
                                                    <div class="fw-bold">@item.Nome</div>
                                                    <small class="text-muted">ID: @item.Id</small>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Preço -->
                                        <td class="text-center">
                                            @if (item.PrecoPromocional.HasValue && item.PrecoPromocional < item.Preco)
                                            {
                                                <span class="price-old">@item.Preco.ToString("C")</span>
                                            }
                                            else
                                            {
                                                <span class="price-normal">@item.Preco.ToString("C")</span>
                                            }
                                        </td>

                                        <!-- Promoção -->
                                        <td class="text-center">
                                            @if (item.PrecoPromocional.HasValue && item.PrecoPromocional < item.Preco)
                                            {
                                                var desconto = Math.Round((1 - (item.PrecoPromocional.Value / item.Preco)) * 100);
                                                <span class="price-new">@item.PrecoPromocional.Value.ToString("C")</span>
                                                <span class="discount-badge">-@desconto%</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>

                                        <!-- Categoria -->
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark rounded-pill px-3 py-2">@item.Categoria?.Nome</span>
                                        </td>

                                        <!-- Estoque -->
                                        <td class="text-center">
                                            <div class="d-flex flex-column align-items-center">
                                                <div class="progress w-100" style="height: 10px;">
                                                    <div class="progress-bar @(item.Estoque > 5 ? "bg-success" : "bg-warning")"
                                                         role="progressbar"
                                                         style="width: @(Math.Min(item.Estoque * 10, 100))%">
                                                    </div>
                                                </div>
                                                <div class="mt-1">
                                                    <span class="badge bg-light text-dark border">
                                                        <i class="fas fa-box me-1"></i>
                                                        <span class="fw-bold @estoqueClass">@item.Estoque</span>
                                                    </span>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Sabores -->
                                        <td>
                                            @if (topChips.Any())
                                            {
                                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                                    @foreach (var s in topChips)
                                                    {
                                                        <span class="badge flavor-chip">
                                                            <span class="chip-dot"></span>
                                                            @s.Sabor
                                                            <span class="chip-qty">(@s.Quantidade)</span>
                                                        </span>
                                                    }
                                                    @if (temMais)
                                                    {
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary rounded-pill"
                                                                data-bs-toggle="popover"
                                                                data-bs-placement="top"
                                                                data-bs-trigger="focus"
                                                                title="Mais sabores"
                                                                data-bs-content="@popoverText">
                                                            +@hiddenChips.Count
                                                        </button>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>

                                        <td class="text-center">@item.Puffs</td>
                                        <td class="text-center">@item.CapacidadeBateria mAh</td>
                                        <td class="text-center">@item.DataCadastro.ToShortDateString()</td>

                                        <!-- Ativo -->
                                        <td class="text-center">
                                            <span class="badge @(item.Ativo ? "bg-success" : "bg-secondary") px-3 py-2 rounded-pill">
                                                @(item.Ativo ? "Sim" : "Não")
                                            </span>
                                        </td>

                                        <!-- Ações -->
                                        <td class="text-end pe-4">
                                            <div class="btn-group">
                                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-primary btn-action">
                                                    <i class="fas fa-edit me-1"></i> Editar
                                                </a>
                                                <a asp-action="Excluir" asp-route-id="@item.Id" class="btn btn-outline-danger btn-action">
                                                    <i class="fas fa-trash-alt me-1"></i> Excluir
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Cards Mobile -->
            <div class="container-fluid px-3 px-xl-4 d-lg-none">
                <div class="row row-cols-1 row-cols-md-2 g-4">
                    @foreach (var item in Model)
                    {
                        var saboresMob = (item.SaboresQuantidadesList ?? new List<ProdutoModel.SaborQuantidade>())
                        .Where(sq => sq.Quantidade >= 0)
                        .OrderByDescending(sq => sq.Quantidade)
                        .Take(6)
                        .Select(sq => $"{sq.Sabor} ({sq.Quantidade})")
                        .ToList();

                        <div class="col">
                            <div class="card product-card h-100 shadow-sm">
                                <div class="card-body">
                                    <div class="text-center mb-3">
                                        <div class="product-img-container mx-auto mb-2">
                                            @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                            {
                                                <img src="@item.ImagemUrl" alt="@item.Nome" class="product-img rounded-3 shadow-sm" loading="lazy">
                                            }
                                            else
                                            {
                                                <div class="product-img-placeholder rounded-3 shadow-sm">
                                                    <i class="fas fa-box"></i>
                                                </div>
                                            }
                                        </div>
                                        <h5 class="card-title fw-bold mb-1">@item.Nome</h5>
                                        <div class="small text-muted">ID: @item.Id</div>
                                    </div>

                                    <div class="text-center mb-3">
                                        @if (item.PrecoPromocional.HasValue && item.PrecoPromocional < item.Preco)
                                        {
                                            <div class="mb-1"><span class="price-old">@item.Preco.ToString("C")</span></div>
                                            <div>
                                                <span class="price-new">@item.PrecoPromocional.Value.ToString("C")</span>
                                                @{
                                                    var desconto = Math.Round((1 - (item.PrecoPromocional.Value / item.Preco)) * 100);
                                                }
                                                <span class="discount-badge">-@desconto%</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="fw-bold text-primary fs-5">@item.Preco.ToString("C")</div>
                                        }
                                    </div>

                                    <div class="row g-2">
                                        <div class="col-6"><span class="text-muted small">Categoria</span><div>@item.Categoria?.Nome</div></div>
                                        <div class="col-6"><span class="text-muted small">Estoque</span><div class="fw-bold">@item.Estoque</div></div>
                                        <div class="col-6"><span class="text-muted small">Puffs</span><div>@item.Puffs</div></div>
                                        <div class="col-6"><span class="text-muted small">Bateria</span><div>@item.CapacidadeBateria mAh</div></div>
                                    </div>

                                    <div class="mt-3">
                                        <span class="text-muted small d-block mb-1">Sabores</span>
                                        <div class="d-flex flex-wrap gap-2">
                                            @if (saboresMob.Any())
                                            {
                                                @foreach (var s in saboresMob)
                                                {
                                                    <span class="badge flavor-chip">@s</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-3">
                                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-primary btn-action">
                                            <i class="fas fa-edit"></i> Editar
                                        </a>
                                        <a asp-action="Excluir" asp-route-id="@item.Id" class="btn btn-danger btn-action">
                                            <i class="fas fa-trash-alt"></i> Excluir
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Tooltips / Popovers
        $(function () {
          $('[data-bs-toggle="tooltip"]').tooltip();
          $('[data-bs-toggle="popover"]').popover();
        });

        // Filtros e busca
        $(document).ready(function () {
          $('.filter-btn').click(function () {
            $('.filter-btn').removeClass('active');
            $(this).addClass('active');

            const filter = $(this).data('filter');
            $('tbody tr, .product-card').hide();

            if (filter === 'all') {
              $('tbody tr, .product-card').show();
            } else if (filter === 'in-stock') {
              $('tbody tr').filter(function () {
                return parseInt($(this).find('td:eq(4) .badge .fw-bold').text() || '0') > 0
              }).show();
              $('.product-card').filter(function () {
                return $(this).find('.fw-bold:contains("Estoque")').text().match(/\d+/)
              }).show();
            } else if (filter === 'low-stock') {
              $('tbody tr').filter(function () {
                return parseInt($(this).find('td:eq(4) .badge .fw-bold').text() || '0') <= 5
              }).show();
            } else if (filter === 'active') {
              $('tbody tr').filter(function () { return !$(this).hasClass('table-secondary') }).show();
            }
          });

          $('#searchInput').on('input', function () {
            const t = $(this).val().toLowerCase();
            $('tbody tr, .product-card').each(function () {
              const txt = $(this).text().toLowerCase();
              $(this).toggle(txt.includes(t));
            });
          });
        });

        // Define --mbn-height quando existir bottom-nav fixa
        document.addEventListener('DOMContentLoaded', () => {
          const nav = document.querySelector('.mobile-bottom-nav, .bottom-nav, .mbn, .navbar-fixed-bottom');
          const root = document.documentElement;
          function setMbnHeight(){
            const h = nav ? nav.offsetHeight : 68;
            root.style.setProperty('--mbn-height', h + 'px');
          }
          setMbnHeight();
          window.addEventListener('resize', setMbnHeight);
          if (nav && 'ResizeObserver' in window){
            new ResizeObserver(setMbnHeight).observe(nav);
          }
        });
    </script>
}
