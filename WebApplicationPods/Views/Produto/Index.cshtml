@using WebApplicationPods.Models
@model IEnumerable<ProdutoModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Catálogo de Produtos";

    // ===== helpers locais =====
    int EstoqueTotal(ProdutoModel p)
    {
        var variacoesAtivas = (p.Variacoes ?? new List<ProdutoVariacaoModel>()).Where(v => v.Ativo).ToList();
        if (variacoesAtivas.Any())
            return variacoesAtivas.Sum(v => v.Estoque * v.Multiplicador); // ✅ igual ao Form
        return p.Estoque;
    }

    decimal PrecoBase(ProdutoModel p)
    {
        var variacoesAtivas = (p.Variacoes ?? new List<ProdutoVariacaoModel>()).Where(v => v.Ativo).ToList();
        if (variacoesAtivas.Any()) return variacoesAtivas.Min(v => v.Preco);
        return p.Preco;
    }

    decimal? PromoValida(ProdutoModel p)
    {
        var variacoesAtivas = (p.Variacoes ?? new List<ProdutoVariacaoModel>()).Where(v => v.Ativo).ToList();
        if (variacoesAtivas.Any())
        {
            var promos = variacoesAtivas
                .Where(v => v.PrecoPromocional.HasValue && v.PrecoPromocional.Value > 0 && v.PrecoPromocional.Value < v.Preco)
                .Select(v => v.PrecoPromocional!.Value)
                .ToList();

            return promos.Any() ? promos.Min() : (decimal?)null;
        }

        if (p.PrecoPromocional.HasValue && p.PrecoPromocional.Value > 0 && p.PrecoPromocional.Value < p.Preco)
            return p.PrecoPromocional.Value;

        return null;
    }

    // ===== stats (baseado no Model atual) =====
    var total = Model?.Count() ?? 0;
    var emEstoque = Model?.Count(p => EstoqueTotal(p) > 0) ?? 0;
    var baixoEstoque = Model?.Count(p =>
    {
        var e = EstoqueTotal(p);
        return e > 0 && e <= 5;
    }) ?? 0;
    var ativos = Model?.Count(p => p.Ativo) ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/produtos-index.css" asp-append-version="true" />
}

<div class="container-fluid px-0 produtos-page">
    <!-- Header -->
    <header class="gradient-header py-4 mb-4 shadow">
        <div class="container container-full-lg">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center text-center text-md-start gap-3">
                <div>
                    <h1 class="display-6 text-white fw-bold mb-1">@ViewData["Title"]</h1>
                    <p class="text-white-50 mb-0">Gerencie seu inventário</p>
                </div>
                <a asp-action="CriarPadrao" class="btn btn-primary">Novo Padrão</a>
                <a asp-action="CriarBebida" class="btn btn-danger">Nova Bebida</a>
                <a asp-action="CriarPod" class="btn btn-purple">Novo Pod</a>
            </div>
        </div>
    </header>

    <!-- Flash messages -->
    <div class="container container-full-lg">
        @await Html.PartialAsync("_Flash")
    </div>

    <div id="pageRoot" class="container container-full-lg page-has-bottom-nav">

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info shadow-sm text-center">
                Nenhum produto cadastrado. Clique em <b>Novo Produto</b> para começar.
            </div>
        }
        else
        {
            <!-- STATS (Figma) -->
            <div class="stats-grid">
                <div class="stats-card total">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="label">Total de Produtos</div>
                            <div class="value">@total</div>
                        </div>
                        <div class="icon">
                            <i class="fas fa-box"></i>
                        </div>
                    </div>
                </div>

                <div class="stats-card instock">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="label">Em Estoque</div>
                            <div class="value">@emEstoque</div>
                        </div>
                        <div class="icon">
                            <i class="fas fa-check"></i>
                        </div>
                    </div>
                </div>

                <div class="stats-card low">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="label">Baixo Estoque</div>
                            <div class="value">@baixoEstoque</div>
                        </div>
                        <div class="icon">
                            <i class="fas fa-triangle-exclamation"></i>
                        </div>
                    </div>
                </div>

                <div class="stats-card active">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="label">Produtos Ativos</div>
                            <div class="value">@ativos</div>
                        </div>
                        <div class="icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BUSCA + FILTROS + TOGGLE -->
            <div class="filters-card">
                <div class="row g-3 align-items-center">
                    <div class="col-lg-6">
                        <div class="search-box input-group">
                            <span class="input-group-text bg-white border-0 ps-4">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text" class="form-control border-0" id="searchInput"
                                   placeholder="Pesquisar por nome, categoria, sabor...">
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="d-flex flex-wrap gap-2 justify-content-lg-center justify-content-start">
                            <button class="btn filter-btn active" type="button" data-filter="all">Todos</button>
                            <button class="btn filter-btn" type="button" data-filter="in-stock">Em estoque</button>
                            <button class="btn filter-btn" type="button" data-filter="low-stock">Baixo estoque</button>
                            <button class="btn filter-btn" type="button" data-filter="active">Ativos</button>
                        </div>
                    </div>

                    <div class="col-lg-2 text-lg-end">
                        <div class="view-toggle" role="group" aria-label="Visualização">
                            <button type="button" class="view-btn" id="btnGrid" title="Grade">
                                <i class="fas fa-table-cells"></i>
                            </button>
                            <button type="button" class="view-btn active" id="btnTable" title="Tabela">
                                <i class="fas fa-list"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TABELA -->
            <div id="viewTable" class="table-shell">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 produtos-table">
                        <thead class="table-light">
                            <tr class="text-center">
                                <th class="ps-4 text-start col-produto">Produto</th>
                                <th class="col-preco">Preço</th>
                                <th class="col-promocao">Promoção</th>
                                <th class="col-categoria">Categoria</th>
                                <th class="col-estoque">Estoque</th>
                                <th class="col-sabores text-start">Sabores</th>
                                <th class="col-cadastro">Cadastro</th>
                                <th class="col-ativo">Ativo</th>
                                <th class="text-end pe-4 col-acoes">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var statusClass = item.Ativo ? "" : "row-inativo";

                                var variacoesAtivas = (item.Variacoes ?? new List<ProdutoVariacaoModel>())
                                .Where(v => v.Ativo)
                                .ToList();
                                var temVariacoes = variacoesAtivas.Any();

                                var estoqueTotal = EstoqueTotal(item);
                                var precoBase = PrecoBase(item);
                                var promoValida = PromoValida(item);

                                var estoqueClass = estoqueTotal <= 5 ? "text-warning" : "text-dark";

                                // LEGADO (chips com quantidade)
                                var saboresLegacy = (item.SaboresQuantidadesList ?? new List<ProdutoModel.SaborQuantidade>())
                                .Where(sq => !string.IsNullOrWhiteSpace(sq.Sabor))
                                .OrderByDescending(sq => sq.Quantidade)
                                .ThenBy(sq => sq.Sabor)
                                .ToList();

                                // NOVO (produto simples: string Sabor)
                                var saborSimples = (item.Sabor ?? "").Trim();

                                var topChips = saboresLegacy.Take(4).ToList();
                                var hiddenChips = saboresLegacy.Skip(4).ToList();
                                var temMais = hiddenChips.Any();
                                var popoverText = string.Join(", ", hiddenChips.Select(sq => $"{sq.Sabor} ({sq.Quantidade})"));

                                <tr class="@statusClass js-item"
                                    data-estoque="@estoqueTotal"
                                    data-ativo="@(item.Ativo ? "1" : "0")">
                                    <!-- Produto -->
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="product-img-container me-3">
                                                @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                                {
                                                    <img src="@item.ImagemUrl" alt="Imagem @item.Nome" class="product-img" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="product-img-placeholder">
                                                        <i class="fas fa-box"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div class="text-truncate">
                                                <div class="fw-bold">@item.Nome</div>
                                                <small class="text-muted">ID: @item.Id</small>
                                                @if (temVariacoes)
                                                {
                                                    <div class="small text-muted">Variações: @variacoesAtivas.Count</div>
                                                }
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Preço -->
                                    <td class="text-center">
                                        @if (promoValida.HasValue)
                                        {
                                            <span class="price-old">@precoBase.ToString("C")</span>
                                        }
                                        else
                                        {
                                            <span class="price-normal">@precoBase.ToString("C")</span>
                                        }
                                    </td>

                                    <!-- Promo -->
                                    <td class="text-center">
                                        @if (promoValida.HasValue)
                                        {
                                            var desconto = Math.Round((1 - (promoValida.Value / precoBase)) * 100);
                                            <span class="price-new">@promoValida.Value.ToString("C")</span>
                                            <span class="discount-badge">-@desconto%</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>

                                    <!-- Categoria -->
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                                            @item.Categoria?.Nome
                                        </span>
                                    </td>

                                    <!-- Estoque -->
                                    <td class="text-center">
                                        <div class="d-flex flex-column align-items-center">
                                            <div class="progress w-100" style="height: 10px; max-width: 140px;">
                                                <div class="progress-bar @(estoqueTotal > 5 ? "bg-success" : "bg-warning")"
                                                     role="progressbar"
                                                     style="width: @(Math.Min(estoqueTotal * 10, 100))%"></div>
                                            </div>
                                            <div class="mt-1">
                                                <span class="badge bg-light text-dark border">
                                                    <i class="fas fa-box me-1"></i>
                                                    <span class="fw-bold @estoqueClass">@estoqueTotal</span>
                                                </span>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Sabores -->
                                    <td class="text-start">
                                        @* 1) Se tem sabores LEGADO, mostra chips *@
                                        @if (topChips.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                                @foreach (var s in topChips)
                                                {
                                                    <span class="badge flavor-chip">
                                                        <span class="chip-dot"></span>
                                                        @s.Sabor <span class="chip-qty">(@s.Quantidade)</span>
                                                    </span>
                                                }

                                                @if (temMais)
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-secondary rounded-pill"
                                                            data-bs-toggle="popover"
                                                            data-bs-placement="top"
                                                            data-bs-trigger="focus"
                                                            title="Mais sabores"
                                                            data-bs-content="@popoverText">
                                                        +@hiddenChips.Count
                                                    </button>
                                                }
                                            </div>
                                        }
                                        @* 2) Senão, se tem Sabor simples, mostra ele *@
                                        else if (!string.IsNullOrWhiteSpace(saborSimples))
                                        {
                                            <span class="badge flavor-chip">
                                                <span class="chip-dot"></span>
                                                @saborSimples
                                            </span>
                                        }
                                        @* 3) Senão, traço *@
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>

                                    <!-- Cadastro -->
                                    <td class="text-center">@item.DataCadastro.ToShortDateString()</td>

                                    <!-- Ativo -->
                                    <td class="text-center">
                                        <span class="badge @(item.Ativo ? "bg-success" : "bg-secondary") px-3 py-2 rounded-pill">
                                            @(item.Ativo ? "Sim" : "Não")
                                        </span>
                                    </td>

                                    <!-- Ações -->
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="EditarSimples" asp-route-id="@item.Id" class="btn btn-outline-primary btn-action">
                                                <i class="fas fa-edit me-1"></i> Editar
                                            </a>
                                            <a asp-action="Excluir" asp-route-id="@item.Id" class="btn btn-outline-danger btn-action">
                                                <i class="fas fa-trash-alt me-1"></i> Excluir
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- GRADE (Cards) -->
            <div id="viewGrid" class="mt-3 d-none">
                <div class="cards-grid">
                    @foreach (var item in Model)
                    {
                        var variacoesAtivasMob = (item.Variacoes ?? new List<ProdutoVariacaoModel>())
                        .Where(v => v.Ativo)
                        .ToList();

                        var temVariacoesMob = variacoesAtivasMob.Any();

                        var estoqueTotalMob = EstoqueTotal(item);
                        var precoBaseMob = PrecoBase(item);
                        var promoValidaMob = PromoValida(item);

                        var saboresMob = (item.SaboresQuantidadesList ?? new List<ProdutoModel.SaborQuantidade>())
                        .Where(sq => !string.IsNullOrWhiteSpace(sq.Sabor))
                        .OrderByDescending(sq => sq.Quantidade)
                        .ThenBy(sq => sq.Sabor)
                        .Take(6)
                        .Select(sq => $"{sq.Sabor} ({sq.Quantidade})")
                        .ToList();

                        <div class="card product-card js-item"
                             data-estoque="@estoqueTotalMob"
                             data-ativo="@(item.Ativo ? "1" : "0")">
                            <div class="card-body">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="product-img-container">
                                        @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                        {
                                            <img src="@item.ImagemUrl" alt="@item.Nome" class="product-img" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="product-img-placeholder">
                                                <i class="fas fa-box"></i>
                                            </div>
                                        }
                                    </div>

                                    <div class="flex-grow-1">
                                        <div class="fw-bold">@item.Nome</div>
                                        <div class="small text-muted">ID: @item.Id</div>
                                        @if (temVariacoesMob)
                                        {
                                            <div class="small text-muted">Variações: @variacoesAtivasMob.Count</div>
                                        }
                                    </div>

                                    <div class="text-end">
                                        @if (promoValidaMob.HasValue)
                                        {
                                            <div class="price-old">@precoBaseMob.ToString("C")</div>
                                            <div class="d-flex align-items-center gap-2 justify-content-end">
                                                <div class="price-new">@promoValidaMob.Value.ToString("C")</div>
                                                @{
                                                    var d = Math.Round((1 - (promoValidaMob.Value / precoBaseMob)) * 100);
                                                }
                                                <span class="discount-badge">-@d%</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="price-normal">@precoBaseMob.ToString("C")</div>
                                        }
                                    </div>
                                </div>

                                <div class="row g-2 mt-3">
                                    <div class="col-6">
                                        <div class="small text-muted">Categoria</div>
                                        <div class="fw-semibold">@item.Categoria?.Nome</div>
                                    </div>
                                    <div class="col-6 text-end">
                                        <div class="small text-muted">Estoque</div>
                                        <div class="fw-bold">@estoqueTotalMob</div>
                                    </div>
                                    <div class="col-12">
                                        <div class="small text-muted">Cadastro</div>
                                        <div class="fw-semibold">@item.DataCadastro.ToShortDateString()</div>
                                    </div>
                                    <div class="col-12 mt-1">
                                        <div class="small text-muted mb-1">Sabores</div>
                                        <div class="d-flex flex-wrap gap-2">
                                            @if (saboresMob.Any())
                                            {
                                                @foreach (var s in saboresMob)
                                                {
                                                    <span class="badge flavor-chip">@s</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-3">
                                    <a asp-action="EditarSimples" asp-route-id="@item.Id" class="btn btn-outline-primary btn-action">
                                        <i class="fas fa-edit me-1"></i> Editar
                                    </a>
                                    <a asp-action="Excluir" asp-route-id="@item.Id" class="btn btn-outline-danger btn-action">
                                        <i class="fas fa-trash-alt me-1"></i> Excluir
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="results-count mt-3">
                Exibindo <span id="resultsCount">@total</span> de @total produtos
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Popovers (Bootstrap 5) - sem jQuery
            const popoverEls = Array.prototype.slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
            popoverEls.forEach(el => new bootstrap.Popover(el));

            const searchInput = document.getElementById('searchInput');
            const filterButtons = document.querySelectorAll('.filter-btn');
            const items = document.querySelectorAll('.js-item');
            const resultsCount = document.getElementById('resultsCount');

            const btnGrid = document.getElementById('btnGrid');
            const btnTable = document.getElementById('btnTable');
            const viewGrid = document.getElementById('viewGrid');
            const viewTable = document.getElementById('viewTable');

            let currentFilter = 'all';
            let currentTerm = '';

            function matchesFilter(el) {
                const estoque = parseInt(el.getAttribute('data-estoque') || '0', 10);
                const ativo = (el.getAttribute('data-ativo') || '0') === '1';

                if (currentFilter === 'all') return true;
                if (currentFilter === 'in-stock') return estoque > 0;
                if (currentFilter === 'low-stock') return estoque > 0 && estoque <= 5;
                if (currentFilter === 'active') return ativo;
                return true;
            }

            function matchesSearch(el) {
                if (!currentTerm) return true;
                return (el.textContent || '').toLowerCase().includes(currentTerm);
            }

            function applyAll() {
                let visible = 0;
                items.forEach(el => {
                    const show = matchesFilter(el) && matchesSearch(el);
                    el.style.display = show ? '' : 'none';
                    if (show) visible++;
                });
                if (resultsCount) resultsCount.textContent = String(visible);
            }

            // filtros
            filterButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.getAttribute('data-filter') || 'all';
                    applyAll();
                });
            });

            // busca
            if (searchInput) {
                searchInput.addEventListener('input', () => {
                    currentTerm = (searchInput.value || '').trim().toLowerCase();
                    applyAll();
                });
            }

            // toggle view
            function setView(mode) {
                if (!viewGrid || !viewTable) return;

                const isGrid = mode === 'grid';
                viewGrid.classList.toggle('d-none', !isGrid);
                viewTable.classList.toggle('d-none', isGrid);

                if (btnGrid) btnGrid.classList.toggle('active', isGrid);
                if (btnTable) btnTable.classList.toggle('active', !isGrid);

                try { localStorage.setItem('produtos_view', mode); } catch(e){}
            }

            if (btnGrid) btnGrid.addEventListener('click', () => setView('grid'));
            if (btnTable) btnTable.addEventListener('click', () => setView('table'));

            // restaura view
            try {
                const saved = localStorage.getItem('produtos_view');
                if (saved === 'grid' || saved === 'table') setView(saved);
            } catch(e){}

            // primeira aplicação
            applyAll();

            // Ajuste de altura p/ bottom-nav fixa, se existir
            const nav = document.querySelector('.mobile-bottom-nav, .bottom-nav, .mbn, .navbar-fixed-bottom');
            const root = document.documentElement;

            function setMbnHeight() {
                const h = nav ? nav.offsetHeight : 68;
                root.style.setProperty('--mbn-height', h + 'px');
            }
            setMbnHeight();
            window.addEventListener('resize', setMbnHeight);

            if (nav && 'ResizeObserver' in window) {
                new ResizeObserver(setMbnHeight).observe(nav);
            }
        });
    </script>
}
