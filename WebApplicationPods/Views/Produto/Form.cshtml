@using WebApplicationPods.Enum
@using WebApplicationPods.Models
@model WebApplicationPods.Models.ProdutoFormViewModel

@{
    var isEdit = Model?.Id.HasValue == true && Model.Id.Value > 0;

    var tipo = Model.TipoProduto;
    var isPadrao = tipo == ProdutoTipo.Padrao;
    var isPod = tipo == ProdutoTipo.PodVape;
    var isBebida = tipo == ProdutoTipo.BebidaAlcoolica;

    var lockType = isEdit;
}


<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="pf2">
    <div id="pf2ToastHost" class="pf2-toast-host"></div>

    <div class="pf2-wrap">
        <div class="pf2-header">
            <div class="pf2-title">
                <div class="pf2-icon">
                    <i class="fas fa-box-open"></i>
                </div>
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p class="pf2-sub">
                        @(isEdit ? $"Editando produto #{Model.Id}" : "Sistema unificado para cadastro de produtos de conveniência, pods eletrônicos, bebidas e muito mais")
                    </p>
                </div>
            </div>

            <div class="pf2-actions">
                <div class="pf2-chip">
                    <span>Estoque Total</span>
                    <strong id="totalStock">0</strong>
                    <span class="muted">un</span>
                </div>

                <a asp-action="Index" class="pf2-btn pf2-btn-ghost">
                    <i class="fas fa-arrow-left"></i>
                    Voltar
                </a>
            </div>
        </div>

        <div class="pf2-card pf2-progress">
            <div class="pf2-progress-top">
                <span class="muted">Progresso do cadastro</span>
                <span class="pf2-progress-pct" id="progressText">0%</span>
            </div>
            <div class="pf2-progress-track">
                <div class="pf2-progress-bar" id="progressBar" style="width:0%"></div>
            </div>
        </div>

        <form id="productForm"
              asp-action="@(isEdit ? "Editar" : "Criar")"
              asp-route-id="@(isEdit ? Model.Id : null)"
              method="post"
              enctype="multipart/form-data"
              novalidate>

            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagemUrl" />

            <!-- ✅ hidden REAL (vai pro banco) -->
            <input type="hidden" id="TipoProdutoHidden" name="TipoProduto" value="@((int)Model.TipoProduto)" />

            <!-- Tipo de Produto -->
            <div class="pf2-card pf2-type">
                <div class="pf2-card-head">
                    <div class="pf2-card-ico bg-blue"><i class="fas fa-mug-hot"></i></div>
                    <div>
                        <h2>Tipo de Produto</h2>
                        <p class="muted">Define regra de maioridade</p>
                    </div>
                </div>

                <div class="pf2-type-grid">
                    <label class="pf2-type-item @(isPadrao ? "is-selected" : "")" data-type="padrao">
                        <input type="radio" name="TipoProdutoUI" value="padrao"
                               @(isPadrao ? "checked" : "")
                               @(lockType ? "disabled" : "") />
                        <div class="pf2-type-icon text-blue"><i class="fas fa-box"></i></div>
                        <div class="pf2-type-txt">
                            <strong>Produto Padrão</strong>
                            <span class="muted">Conveniência em geral</span>
                        </div>
                    </label>

                    <label class="pf2-type-item @(isPod ? "is-selected" : "")" data-type="pod">
                        <input type="radio" name="TipoProdutoUI" value="pod"
                               @(isPod ? "checked" : "")
                               @(lockType ? "disabled" : "") />
                        <div class="pf2-type-icon text-purple"><i class="fas fa-bolt"></i></div>
                        <div class="pf2-type-txt">
                            <strong>Pod / Vape</strong>
                            <span class="muted">Cigarro eletrônico</span>
                        </div>
                    </label>

                    <label class="pf2-type-item @(isBebida ? "is-selected" : "")" data-type="bebida-alcoolica">
                        <input type="radio" name="TipoProdutoUI" value="bebida-alcoolica"
                               @(isBebida ? "checked" : "")
                               @(lockType ? "disabled" : "") />
                        <div class="pf2-type-icon text-red"><i class="fas fa-wine-bottle"></i></div>
                        <div class="pf2-type-txt">
                            <strong>Bebida Alcoólica</strong>
                            <span class="muted">Cerveja, vodka, etc.</span>
                        </div>
                    </label>
                </div>

                @if (lockType)
                {
                    <div class="pf2-help muted" style="margin-top:10px;">
                        <i class="fas fa-lock"></i>
                        Este produto foi criado como <strong>@Model.TipoProduto</strong> e não pode trocar o tipo no editar.
                    </div>
                }
            </div>

            <!-- Informações Básicas -->
            <div class="pf2-card">
                <div class="pf2-card-head">
                    <div class="pf2-card-ico"><i class="fas fa-file-alt"></i></div>
                    <div>
                        <h2>Informações Básicas</h2>
                        <p class="muted">Dados principais do produto</p>
                    </div>
                </div>

                <div class="pf2-grid">
                    <div class="pf2-field pf2-span-2">
                        <label>Nome do Produto *</label>
                        <div class="pf2-input">
                            <i class="fas fa-tag"></i>
                            <input asp-for="Nome" required maxlength="120"
                                   placeholder="Ex: Coca-Cola 2L, Pod Ice Mint 5000 puffs" />
                            <span class="pf2-ok" id="nomeOk"></span>
                        </div>
                        <span asp-validation-for="Nome" class="pf2-val"></span>
                    </div>

                    <div class="pf2-field pf2-span-2">
                        <label>Descrição Detalhada</label>
                        <textarea asp-for="Descricao" rows="3" maxlength="1000"
                                  placeholder="Descreva o produto, suas características e especificações"></textarea>
                        <div class="pf2-help"><span id="descCount">0</span>/1000 caracteres</div>
                    </div>

                    <div class="pf2-field">
                        <label>Categoria *</label>
                        <div class="pf2-input">
                            <i class="fas fa-layer-group"></i>
                            <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" required>
                                <option value="">Selecione uma categoria</option>
                            </select>
                            <span class="pf2-chevron"></span>
                        </div>
                        <span asp-validation-for="CategoriaId" class="pf2-val"></span>
                    </div>

                    <div class="pf2-field">
                        <label>Marca</label>
                        <div class="pf2-input">
                            <i class="fas fa-industry"></i>
                            <input asp-for="Marca" maxlength="80" placeholder="Ex: Coca-Cola, Elf Bar, Absolut" />
                        </div>
                    </div>

                    <div class="pf2-field">
                        <label>SKU (Código Interno)</label>
                        <div class="pf2-input">
                            <i class="fas fa-hashtag"></i>
                            <input asp-for="SKU" maxlength="80" placeholder="Ex: PROD-001" />
                        </div>
                    </div>

                    <div class="pf2-field">
                        <label>Código de Barras (EAN)</label>
                        <div class="pf2-input">
                            <i class="fas fa-barcode"></i>
                            <input asp-for="CodigoBarras" maxlength="80" placeholder="Ex: 7891234567890" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Imagem -->
            <div class="pf2-card">
                <div class="pf2-card-head">
                    <div class="pf2-card-ico"><i class="fas fa-image"></i></div>
                    <div>
                        <h2>Imagem do Produto</h2>
                        <p class="muted">Upload e pré-visualização</p>
                    </div>
                </div>

                <div class="pf2-img-grid">
                    <div class="pf2-field">
                        <label>Upload de imagem</label>
                        <div class="pf2-file">
                            <input type="file" id="imageUpload" name="ImagemUpload" accept="image/*" />
                            <div class="pf2-file-hint muted">Formatos: JPG/PNG (máx. 5MB)</div>
                        </div>
                    </div>

                    <div class="pf2-field">
                        <label>Pré-visualização</label>
                        <div class="pf2-preview" id="imagePreviewBox">
                            @if (!string.IsNullOrWhiteSpace(Model?.ImagemUrl))
                            {
                                <img src="@Model.ImagemUrl" alt="Preview" />
                                <button type="button" class="pf2-x" id="removeImage"><i class="fas fa-times"></i></button>
                            }
                            else
                            {
                                <div class="pf2-empty">
                                    <i class="fas fa-image"></i>
                                    <span class="muted">Nenhuma imagem selecionada</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status -->
            <div class="pf2-card">
                <div class="pf2-card-head">
                    <div class="pf2-card-ico"><i class="fas fa-shopping-cart"></i></div>
                    <div>
                        <h2>Status e Configurações</h2>
                        <p class="muted">Visibilidade e regras</p>
                    </div>
                </div>

                <div class="pf2-status-grid">
                    <label class="pf2-status">
                        <input type="checkbox" asp-for="Ativo" />
                        <div class="pf2-status-ico text-green"><i class="fas fa-check-circle"></i></div>
                        <div class="pf2-status-txt">
                            <strong>Produto Ativo</strong>
                            <span class="muted">Produto disponível para venda</span>
                        </div>
                    </label>

                    <label class="pf2-status">
                        <input type="checkbox" asp-for="EmPromocao" />
                        <div class="pf2-status-ico text-red"><i class="fas fa-tag"></i></div>
                        <div class="pf2-status-txt">
                            <strong>Em Promoção</strong>
                            <span class="muted">Produto com preço promocional</span>
                        </div>
                    </label>

                    <label class="pf2-status">
                        <input type="checkbox" asp-for="MaisVendido" />
                        <div class="pf2-status-ico text-blue"><i class="fas fa-chart-line"></i></div>
                        <div class="pf2-status-txt">
                            <strong>Mais Vendido</strong>
                            <span class="muted">Destaque na lista de produtos</span>
                        </div>
                    </label>

                    <label class="pf2-status" id="maioridadeCard">
                        <input type="checkbox" asp-for="RequerMaioridade" id="requerMaioridade" />
                        <div class="pf2-status-ico text-orange"><i class="fas fa-shield-alt"></i></div>
                        <div class="pf2-status-txt">
                            <strong>Requer Maioridade</strong>
                            <span class="muted" id="maioridadeHint">Venda apenas para maiores de 18 anos</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Variações -->
            <div class="pf2-card">
                <div class="pf2-vari-head">
                    <div>
                        <h2 class="pf2-vari-title"><i class="fas fa-sparkles"></i> Variações do Produto</h2>
                        <p class="muted">Variações permitem vender em diferentes quantidades (unidade, caixa, fardo, etc.)</p>
                    </div>

                    <div class="pf2-vari-actions">
                        <button type="button" id="addVariation" class="pf2-btn pf2-btn-primary">
                            <i class="fas fa-plus"></i>
                            Adicionar Variação
                        </button>
                    </div>
                </div>

                <div id="variationsList" class="pf2-vari-list">
                    @if (Model?.Variacoes != null && Model.Variacoes.Any())
                    {
                        for (var i = 0; i < Model.Variacoes.Count; i++)
                        {
                            var nomeVar = Model.Variacoes[i].Nome ?? "Unidade";
                            var isPadraoVar = nomeVar == "Unidade" || nomeVar == "Caixa" || nomeVar == "Fardo";
                            var isOutro = !isPadraoVar;

                            <div class="pf2-vari" data-index="@i">
                                <input type="hidden" name="Variacoes[@i].Id" value="@Model.Variacoes[i].Id" />
                                <input type="hidden" class="v-name-hidden" name="Variacoes[@i].Nome" value="@nomeVar" />

                                <div class="pf2-vari-top">
                                    <div class="pf2-vari-badge">
                                        <i class="fas fa-cubes"></i>
                                        <span>Variação</span>
                                        <strong class="v-badge">@nomeVar</strong>
                                    </div>

                                    <button type="button" class="pf2-iconbtn v-remove" title="Remover">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>

                                <div class="pf2-vari-grid">
                                    <div class="pf2-field">
                                        <label>Nome</label>
                                        <div class="pf2-row">
                                            <select class="v-name">
                                                <option value="Unidade" selected="@(nomeVar == "Unidade")">Unidade</option>
                                                <option value="Caixa" selected="@(nomeVar == "Caixa")">Caixa</option>
                                                <option value="Fardo" selected="@(nomeVar == "Fardo")">Fardo</option>
                                                <option value="Outro" selected="@(isOutro)">Outro</option>
                                            </select>

                                            <input type="text"
                                                   class="v-custom @(isOutro ? "" : "hidden")"
                                                   placeholder="Nome..."
                                                   value="@(isOutro? nomeVar : "")" />
                                        </div>
                                        <span class="pf2-val v-nome-val hidden">Informe o nome da variação.</span>
                                    </div>

                                    <!-- ✅ Multiplicador + Estoque lado a lado -->
                                    <div class="pf2-field pf2-inline2">
                                        <div class="pf2-inline2-col">
                                            <label>Multiplicador</label>
                                            <input type="number"
                                                   min="1"
                                                   class="v-mult"
                                                   name="Variacoes[@i].Multiplicador"
                                                   value="@(Model.Variacoes[i].Multiplicador < 1 ? 1 : Model.Variacoes[i].Multiplicador)" />
                                        </div>

                                        <div class="pf2-inline2-col">
                                            <label>Estoque</label>
                                            <input type="number"
                                                   min="0"
                                                   class="v-stock"
                                                   name="Variacoes[@i].Estoque"
                                                   value="@Model.Variacoes[i].Estoque" />
                                        </div>
                                    </div>

                                    <div class="pf2-field">
                                        <label>Preço *</label>
                                        <div class="pf2-money">
                                            <span>R$</span>
                                            <input type="text"
                                                   class="v-price"
                                                   name="Variacoes[@i].PrecoTexto"
                                                   value="@Model.Variacoes[i].PrecoTexto"
                                                   placeholder="0,00" />
                                        </div>
                                        <span class="pf2-val v-preco-val hidden">Informe o preço.</span>
                                    </div>

                                    <div class="pf2-field">
                                        <label>Promo</label>
                                        <div class="pf2-money">
                                            <span>R$</span>
                                            <input type="text"
                                                   class="v-promo"
                                                   name="Variacoes[@i].PrecoPromocionalTexto"
                                                   value="@Model.Variacoes[i].PrecoPromocionalTexto"
                                                   placeholder="0,00" />
                                        </div>
                                    </div>

                                    <div class="pf2-field pf2-switchfield">
                                        <label>Ativo</label>
                                        <div class="pf2-switch">
                                            <input type="checkbox"
                                                   class="v-active"
                                                   name="Variacoes[@i].Ativo"
                                                   value="true"
                                                   @(Model.Variacoes[i].Ativo ? "checked" : "") />
                                            <span></span>
                                        </div>
                                        <input type="hidden" name="Variacoes[@i].Ativo" value="false" />
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="pf2-vari" data-index="0">
                            <input type="hidden" name="Variacoes[0].Id" value="" />
                            <input type="hidden" class="v-name-hidden" name="Variacoes[0].Nome" value="Unidade" />

                            <div class="pf2-vari-top">
                                <div class="pf2-vari-badge">
                                    <i class="fas fa-cubes"></i>
                                    <span>Variação</span>
                                    <strong class="v-badge">Unidade</strong>
                                </div>

                                <button type="button" class="pf2-iconbtn v-remove" title="Remover">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>

                            <div class="pf2-vari-grid">
                                <div class="pf2-field">
                                    <label>Nome</label>
                                    <div class="pf2-row">
                                        <select class="v-name">
                                            <option value="Unidade" selected>Unidade</option>
                                            <option value="Caixa">Caixa</option>
                                            <option value="Fardo">Fardo</option>
                                            <option value="Outro">Outro</option>
                                        </select>

                                        <input type="text" class="v-custom hidden" placeholder="Nome..." value="" />
                                    </div>
                                    <span class="pf2-val v-nome-val hidden">Informe o nome da variação.</span>
                                </div>

                                <div class="pf2-field pf2-inline2">
                                    <div class="pf2-inline2-col">
                                        <label>Multiplicador</label>
                                        <input type="number" min="1" class="v-mult" name="Variacoes[0].Multiplicador" value="1" />
                                    </div>
                                    <div class="pf2-inline2-col">
                                        <label>Estoque</label>
                                        <input type="number" min="0" class="v-stock" name="Variacoes[0].Estoque" value="0" />
                                    </div>
                                </div>

                                <div class="pf2-field">
                                    <label>Preço *</label>
                                    <div class="pf2-money">
                                        <span>R$</span>
                                        <input type="text" class="v-price" name="Variacoes[0].PrecoTexto" placeholder="0,00" value="" />
                                    </div>
                                    <span class="pf2-val v-preco-val hidden">Informe o preço.</span>
                                </div>

                                <div class="pf2-field">
                                    <label>Promo</label>
                                    <div class="pf2-money">
                                        <span>R$</span>
                                        <input type="text" class="v-promo" name="Variacoes[0].PrecoPromocionalTexto" placeholder="0,00" value="" />
                                    </div>
                                </div>

                                <div class="pf2-field pf2-switchfield">
                                    <label>Ativo</label>
                                    <div class="pf2-switch">
                                        <input type="checkbox" class="v-active" name="Variacoes[0].Ativo" value="true" checked />
                                        <span></span>
                                    </div>
                                    <input type="hidden" name="Variacoes[0].Ativo" value="false" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="pf2-vari-footer">
                    <div class="pf2-totalbox">
                        <label>Estoque Total (unidades)</label>
                        <input type="text" id="totalStockInput" readonly value="0" />
                        <small class="muted">Calculado automaticamente: soma de (Estoque × Multiplicador) das variações ativas</small>
                    </div>

                    <button type="button" id="clearAllVariations" class="pf2-btn pf2-btn-danger">
                        <i class="fas fa-trash"></i>
                        Excluir Todas as Variações
                    </button>
                </div>
            </div>

            <div class="pf2-footer">
                <a asp-action="Index" class="pf2-btn pf2-btn-ghost big">
                    <i class="fas fa-times"></i>
                    Cancelar
                </a>

                <button type="submit" class="pf2-btn pf2-btn-primary big">
                    <i class="fas fa-save"></i>
                    Salvar Produto
                </button>
            </div>

        </form>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
<script src="~/js/produto-form.js" asp-append-version="true"></script>
