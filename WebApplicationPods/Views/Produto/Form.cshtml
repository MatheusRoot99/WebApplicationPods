@model WebApplicationPods.Models.ProdutoFormViewModel
@{
    var isEdit = Model?.Id.HasValue == true && Model.Id.Value > 0;
    ViewData["Title"] = isEdit ? "Editar Produto" : "Cadastro de Produto";
}

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="~/css/produto-form-tailwind.css" asp-append-version="true" />

<div class="pf-scope p-4 md:p-6">
    <!-- Full width -->
    <div class="pf-full">

        <!-- Header -->
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-8">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl flex items-center justify-center pf-iconbox">
                    <i class="fas fa-box-open text-2xl pf-icongrad"></i>
                </div>
                <div>
                    <h1 class="text-3xl font-bold gradient-text">@ViewData["Title"]</h1>
                    <p class="text-gray-400">
                        @(isEdit ? $"Editando produto #{Model.Id}" : "Preencha as informações para cadastrar um novo produto")
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-3 flex-wrap">
                <div class="stock-badge px-4 py-2 rounded-full">
                    <span class="text-sm text-gray-300">Estoque Total:</span>
                    <span class="ml-2 font-bold text-white" id="totalStock">0</span>
                    <span class="text-gray-400">unidades</span>
                </div>

                <a asp-action="Index"
                   class="px-5 py-2.5 rounded-lg border border-gray-700 text-gray-300 hover:bg-gray-800 transition flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i>
                    Voltar
                </a>
            </div>
        </div>

        <form id="productForm"
              asp-action="@(isEdit ? "Editar" : "Criar")"
              asp-route-id="@(isEdit ? Model.Id : null)"
              method="post"
              enctype="multipart/form-data"
              class="space-y-8"
              novalidate>

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagemUrl" />

            <!-- Card: Informações Básicas -->
            <div class="glass-card rounded-2xl p-6">
                <div class="flex items-center gap-3 mb-6">
                    <i class="fas fa-clipboard-list text-blue-400"></i>
                    <h2 class="text-xl font-semibold">Informações Básicas</h2>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                    <div class="lg:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Nome do Produto *</label>
                        <div class="relative">
                            <i class="fas fa-tag absolute input-icon"></i>
                            <input asp-for="Nome" required
                                   class="w-full pl-11 pr-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                   placeholder="Ex: Coca-Cola 2L" />
                        </div>
                        <span asp-validation-for="Nome" class="text-red-400 text-sm"></span>
                    </div>

                    <div class="lg:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Descrição</label>
                        <textarea asp-for="Descricao"
                                  class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white resize-none"
                                  rows="3"
                                  placeholder="Descreva detalhadamente o produto..."></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Categoria *</label>
                        <div class="relative">
                            <i class="fas fa-layer-group absolute input-icon"></i>
                            <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" required
                                    class="w-full pl-11 pr-10 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white appearance-none">
                                <option value="">Selecione...</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        </div>
                        <span asp-validation-for="CategoriaId" class="text-red-400 text-sm"></span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Marca</label>
                        <div class="relative">
                            <i class="fas fa-industry absolute input-icon"></i>
                            <input asp-for="Marca"
                                   class="w-full pl-11 pr-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                   placeholder="Marca do produto" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">SKU</label>
                        <div class="relative">
                            <i class="fas fa-hashtag absolute input-icon"></i>
                            <input asp-for="SKU"
                                   class="w-full pl-11 pr-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                   placeholder="Código SKU" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Código de Barras</label>
                        <div class="relative">
                            <i class="fas fa-barcode absolute input-icon"></i>
                            <input asp-for="CodigoBarras"
                                   class="w-full pl-11 pr-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                   placeholder="Código de barras" />
                        </div>
                    </div>

                    <!-- Imagem -->
                    <div class="lg:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Imagem do Produto</label>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <div>
                                <div class="image-preview rounded-xl p-6 text-center cursor-pointer transition" id="imagePreview">
                                    <input type="file" id="imageUpload" name="ImagemUpload" class="hidden" accept="image/*">
                                    <i class="fas fa-cloud-upload-alt text-4xl mb-3" style="color: #6b7280;"></i>
                                    <p class="text-gray-400">Clique para fazer upload</p>
                                    <p class="text-sm text-gray-500 mt-1">PNG, JPG até 5MB</p>
                                </div>
                            </div>

                            <div id="imageContainer" class="flex items-center justify-center">
                                @if (!string.IsNullOrWhiteSpace(Model?.ImagemUrl))
                                {
                                    <div class="relative">
                                        <img src="@Model.ImagemUrl" class="max-h-64 rounded-xl" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Switches -->
                <div class="mt-6 pt-6 border-t border-gray-800">
                    <div class="flex flex-wrap gap-6">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <div class="switch">
                                <input type="checkbox" asp-for="Ativo">
                                <span class="slider"></span>
                            </div>
                            <span class="text-gray-300">Ativo</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer">
                            <div class="switch">
                                <input type="checkbox" asp-for="EmPromocao">
                                <span class="slider"></span>
                            </div>
                            <span class="text-gray-300">Em Promoção</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer">
                            <div class="switch">
                                <input type="checkbox" asp-for="MaisVendido">
                                <span class="slider"></span>
                            </div>
                            <span class="text-gray-300">Mais Vendido</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer">
                            <div class="switch">
                                <input type="checkbox" asp-for="RequerMaioridade">
                                <span class="slider"></span>
                            </div>
                            <span class="text-gray-300">Requer Maioridade</span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Card: Variações -->
            <div class="glass-card rounded-2xl p-6">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-6">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-boxes text-purple-400"></i>
                        <div>
                            <h2 class="text-xl font-semibold">Variações</h2>
                            <p class="text-gray-400 text-sm">Estoque total = soma de (Estoque × Multiplicador)</p>
                        </div>
                    </div>

                    <button type="button"
                            id="addVariation"
                            class="px-5 py-2.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 transition flex items-center gap-2 border border-gray-700">
                        <i class="fas fa-plus"></i>
                        Adicionar Variação
                    </button>
                </div>

                <div class="overflow-x-auto rounded-xl border border-gray-800">
                    <table class="w-full">
                        <thead class="bg-gray-900">
                            <tr>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Nome</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Multiplicador</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Preço</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Promo</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Estoque</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Ativo</th>
                                <th class="py-3 px-4 text-left text-sm font-medium text-gray-300">Ação</th>
                            </tr>
                        </thead>

                        <tbody id="variationsTable" class="divide-y divide-gray-800">
                            @if (Model?.Variacoes != null && Model.Variacoes.Any())
                            {
                                for (var i = 0; i < Model.Variacoes.Count; i++)
                                {
                                    var nome = Model.Variacoes[i].Nome ?? "Unidade";
                                    var isPadrao = nome == "Unidade" || nome == "Caixa" || nome == "Fardo";
                                    var isOutro = !isPadrao;

                                    <tr class="variation-row bg-gray-900/50" data-index="@i">
                                        <td class="py-3 px-4">
                                            <input type="hidden" name="Variacoes[@i].Id" value="@Model.Variacoes[i].Id" />
                                            <input type="hidden" class="variation-name-hidden" name="Variacoes[@i].Nome" value="@nome" />

                                            <div class="flex gap-2">
                                                <select class="variation-name w-32 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white">
                                                    <option value="Unidade" selected="@(nome == "Unidade")">Unidade</option>
                                                    <option value="Caixa" selected="@(nome == "Caixa")">Caixa</option>
                                                    <option value="Fardo" selected="@(nome == "Fardo")">Fardo</option>
                                                    <option value="Outro" selected="@(isOutro)">Outro</option>
                                                </select>

                                                <input type="text"
                                                       class="variation-custom-name @(isOutro ? "" : "hidden") w-32 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                                       placeholder="Nome..."
                                                       value="@(isOutro? nome : "")">
                                            </div>
                                        </td>

                                        <td class="py-3 px-4">
                                            <input type="number"
                                                   min="1"
                                                   value="@(Model.Variacoes[i].Multiplicador < 1 ? 1 : Model.Variacoes[i].Multiplicador)"
                                                   class="variation-multiplier w-20 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                                   name="Variacoes[@i].Multiplicador">
                                        </td>

                                        <td class="py-3 px-4">
                                            <div class="relative">
                                                <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">R$</span>
                                                <input type="text"
                                                       value="@Model.Variacoes[i].PrecoTexto"
                                                       class="variation-price w-28 pl-8 pr-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                                       placeholder="0,00"
                                                       name="Variacoes[@i].PrecoTexto">
                                            </div>
                                        </td>

                                        <td class="py-3 px-4">
                                            <div class="relative">
                                                <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">R$</span>
                                                <input type="text"
                                                       value="@Model.Variacoes[i].PrecoPromocionalTexto"
                                                       class="variation-promo w-28 pl-8 pr-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                                       placeholder="0,00"
                                                       name="Variacoes[@i].PrecoPromocionalTexto">
                                            </div>
                                        </td>

                                        <td class="py-3 px-4">
                                            <input type="number"
                                                   min="0"
                                                   value="@Model.Variacoes[i].Estoque"
                                                   class="variation-stock w-20 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-white"
                                                   name="Variacoes[@i].Estoque">
                                        </td>

                                        <td class="py-3 px-4">
                                            <label class="flex items-center justify-center cursor-pointer">
                                                <div class="switch">
                                                    <input type="checkbox" class="variation-active" name="Variacoes[@i].Ativo" value="true" @(Model.Variacoes[i].Ativo ? "checked" : "")>
                                                    <span class="slider"></span>
                                                </div>
                                            </label>
                                            <input type="hidden" name="Variacoes[@i].Ativo" value="false">
                                        </td>

                                        <td class="py-3 px-4">
                                            <button type="button"
                                                    class="remove-variation remove-btn w-9 h-9 flex items-center justify-center rounded-lg border border-gray-700 text-red-400 hover:border-red-500">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <div id="noVariations" class="py-12 text-center hidden">
                        <i class="fas fa-box-open text-4xl mb-3 text-gray-600"></i>
                        <p class="text-gray-400">Nenhuma variação cadastrada</p>
                        <p class="text-sm text-gray-500 mt-1">Clique em "Adicionar Variação" para começar</p>
                    </div>
                </div>

                <!-- Linha: estoque total + excluir -->
                <div class="mt-6 flex flex-col lg:flex-row lg:items-end gap-4">
                    <div class="lg:w-[360px] w-full">
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Estoque Total (unidades)
                        </label>
                        <input type="text"
                               id="totalStockInput"
                               class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white font-bold"
                               readonly
                               value="0">
                        <p class="text-xs text-gray-500 mt-1">Calculado automaticamente</p>
                    </div>

                    <div class="flex-1 flex items-end justify-start lg:justify-end" style="position: relative;
        top: -20px;">
                        <button type="button"
                                id="clearAllVariations"
                                class="w-full lg:w-auto px-6 py-3 rounded-xl border border-red-900 text-red-400 hover:bg-red-900/20 transition flex items-center justify-center gap-2">
                            <i class="fas fa-trash"></i>
                            Excluir Todas as Variações
                        </button>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="mt-8 pt-6 border-t border-gray-800 flex flex-col md:flex-row gap-4 md:items-center md:justify-between">
                <a asp-action="Index"
                   class="w-full md:w-auto px-8 py-3.5 rounded-xl border border-gray-700 text-gray-300 hover:bg-gray-800 transition flex items-center justify-center gap-2 font-medium">
                    <i class="fas fa-times"></i>
                    Cancelar
                </a>

                <button type="submit"
                        class="w-full md:w-auto px-10 py-3.5 rounded-xl btn-primary text-white font-medium flex items-center justify-center gap-2">
                    <i class="fas fa-save"></i>
                    @(isEdit ? "Salvar Produto" : "Cadastrar Produto")
                </button>
            </div>

        </form>

        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/produto-form-tailwind.js" asp-append-version="true"></script>
    </div>
</div>
