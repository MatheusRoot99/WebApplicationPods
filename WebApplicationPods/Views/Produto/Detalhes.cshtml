@using System.Globalization
@using WebApplicationPods.Enum
@model WebApplicationPods.Models.ProdutoDetalhesViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model?.Produto?.Nome ?? "Produto";

    var produto = Model?.Produto;
    if (produto == null)
    {
        <div class="container py-5">
            <div class="alert alert-warning">Produto não encontrado.</div>
        </div>
        return;
    }

    var temPromocao = produto.PrecoPromocional.HasValue
        && produto.PrecoPromocional.Value > 0
        && produto.PrecoPromocional.Value < produto.Preco;

    var precoAtual = temPromocao ? produto.PrecoPromocional!.Value : produto.Preco;
    var precoPix = Math.Round(precoAtual * 0.95m, 2);

    var isPod = produto.TipoProduto == ProdutoTipo.PodVape;
    var isBebida = produto.TipoProduto == ProdutoTipo.BebidaAlcoolica;
    var isPadrao = !isPod && !isBebida;

    var totalSabores = Model?.SaboresDisponiveis?.Count ?? 0;
    var totalSaboresComEstoque = Model?.SaboresDisponiveis?.Count(s => s.Quantidade > 0) ?? 0;

    string tipoLabel = isPod ? "Pod" : isBebida ? "Bebida alcoólica" : "Produto";
    string disponibilidade = produto.Estoque > 0 ? "Em estoque" : "Esgotado";
    var desconto = temPromocao ? (int)Math.Round(100 - (precoAtual / produto.Preco * 100)) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/produto-detalhes.css" asp-append-version="true" />
}

<div id="product-data"
     data-stock="@produto.Estoque"
     data-is-out-of-stock="@(produto.Estoque <= 0 ? "true" : "false")"
     hidden></div>

<div class="pdp-page" itemscope itemtype="https://schema.org/Product">

    <div class="pdp-topbar">
        <a href="javascript:history.back()" class="pdp-back">
            <i class="fas fa-arrow-left"></i>
            <span>Voltar</span>
        </a>

        <div class="pdp-topbar-badges">
            <span class="pdp-chip pdp-chip-type">@tipoLabel</span>

            @if (produto.RequerMaioridade)
            {
                <span class="pdp-chip pdp-chip-age">
                    <i class="fas fa-ban"></i>
                    18+
                </span>
            }

            @if (produto.Estoque <= 0)
            {
                <span class="pdp-chip pdp-chip-out">Esgotado</span>
            }
            else if (temPromocao)
            {
                @* <span class="pdp-chip pdp-chip-promo">Promoção</span> *@
            }
            else
            {
                <span class="pdp-chip pdp-chip-in">Disponível</span>
            }
        </div>
    </div>

    <section class="pdp-hero">
        <div class="pdp-gallery-card">
            <div class="pdp-gallery-stage">
                @if (!string.IsNullOrWhiteSpace(produto.ImagemUrl))
                {
                    <img src="@Url.Content(produto.ImagemUrl)"
                         alt="@produto.Nome"
                         class="pdp-main-image"
                         width="900"
                         height="900"
                         loading="lazy"
                         decoding="async"
                         itemprop="image" />
                }
                else
                {
                    <div class="pdp-image-placeholder">
                        <i class="fas fa-image"></i>
                        <span>Imagem não disponível</span>
                    </div>
                }
            </div>

            <div class="pdp-trust-list">
                <div class="pdp-trust-item">
                    <i class="fas fa-shield-alt"></i>
                    <span>Segura</span>
                </div>

                <div class="pdp-trust-item">
                    <i class="fas fa-bolt"></i>
                    <span>Rápida</span>
                </div>

                @if (produto.Estoque > 0)
                {
                    <div class="pdp-trust-item">
                        <i class="fas fa-box-open"></i>
                        <span>Entrega</span>
                    </div>
                }
            </div>
        </div>

        <aside class="pdp-summary-card">
            <header class="pdp-header">
                <div class="pdp-header-main">
                    <h1 class="pdp-title" itemprop="name">@produto.Nome </h1>

                    <div class="pdp-subline">
                        @if (!string.IsNullOrWhiteSpace(produto.Marca))
                        {
                            <span class="pdp-brand">@produto.Marca</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.SKU))
                        {
                            <span class="pdp-meta">SKU: @produto.SKU</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.CodigoBarras))
                        {
                            <span class="pdp-meta">Cód. barras: @produto.CodigoBarras</span>
                        }
                    </div>
                </div>
            </header>

            <section class="pdp-price-box pdp-price-box--clean" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                <meta itemprop="priceCurrency" content="BRL" />
                <meta itemprop="price" content="@precoAtual.ToString(CultureInfo.InvariantCulture)" />
                <link itemprop="availability" href="https://schema.org/@(produto.Estoque > 0 ? "InStock" : "OutOfStock")" />

                <div class="pdp-price-top">
                    <div class="pdp-price-main">
                        @if (temPromocao)
                        {
                            <span class="pdp-old-price">@produto.Preco.ToString("C")</span>
                        }

                        <div class="pdp-price-line">
                            <span class="pdp-current-price">@precoAtual.ToString("C")</span>

                            @if (temPromocao)
                            {
                                <span class="pdp-discount-badge">
                                    <i class="fas fa-tag"></i>
                                    @desconto% OFF
                                </span>
                            }
                        </div>
                    </div>

                    <div class="pdp-stock-badge @(produto.Estoque > 0 ? "is-in" : "is-out")">
                        <i class="fas @(produto.Estoque > 0 ? "fa-check-circle" : "fa-times-circle")"></i>
                        <span>@disponibilidade</span>
                    </div>
                </div>
            </section>

            <section class="pdp-highlights">
                @* <div class="pdp-section-head">
                    <h3>Destaques</h3>
                </div> *@

                <div class="pdp-highlight-grid">
                    @if (isPod)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            @* <div class="pdp-info-card is-wide">
                                <span>Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div> *@
                        }

                        @if (produto.PodPuffs.HasValue)
                        {
                            @* <div class="pdp-info-card">
                                <span>Puffs</span>
                                <strong>@produto.PodPuffs.Value</strong>
                            </div> *@
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.PodCapacidadeBateria))
                        {
                            @* <div class="pdp-info-card">
                                <span>Bateria</span>
                                <strong>@produto.PodCapacidadeBateria</strong>
                            </div> *@
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.PodTipo))
                        {
                            <div class="pdp-info-card is-wide">
                                <span>Tipo</span>
                                <strong>@produto.PodTipo</strong>
                            </div>
                        }
                    }
                    else if (isBebida)
                    {
                        @if (produto.BebidaVolumeMl.HasValue)
                        {
                            <div class="pdp-info-card">
                                <span>Volume</span>
                                <strong>@produto.BebidaVolumeMl.Value ml</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.BebidaTipo))
                        {
                            <div class="pdp-info-card">
                                <span>Tipo</span>
                                <strong>@produto.BebidaTipo</strong>
                            </div>
                        }

                        @if (produto.BebidaTeorAlcoolico.HasValue)
                        {
                            <div class="pdp-info-card">
                                <span>Teor</span>
                                <strong>@produto.BebidaTeorAlcoolico.Value.ToString("0.##")%</strong>
                            </div>
                        }

                        @if (produto.BebidaQtdPorEmbalagem.HasValue && produto.BebidaQtdPorEmbalagem.Value > 0)
                        {
                            <div class="pdp-info-card">
                                <span>Embalagem</span>
                                <strong>@produto.BebidaQtdPorEmbalagem.Value un.</strong>
                            </div>
                        }
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="pdp-info-card is-wide">
                                <span>Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.Cor))
                        {
                            <div class="pdp-info-card">
                                <span>Cor</span>
                                <strong>@produto.Cor</strong>
                            </div>
                        }

                        <div class="pdp-info-card">
                            <span>Estoque</span>
                            <strong>@produto.Estoque unidade(s)</strong>
                        </div>
                    }
                </div>
            </section>

            @if (isPod && Model?.SaboresDisponiveis != null && Model.SaboresDisponiveis.Any())
            {
                <section class="pdp-flavors-box">
                    <div class="pdp-section-head">
                        <h3>Escolha o sabor</h3>
                        <small>@totalSaboresComEstoque de @totalSabores disponível(is)</small>
                    </div>

                    <fieldset class="pdp-flavors-fieldset">
                        <legend class="visually-hidden">Sabores disponíveis</legend>

                        <div class="pdp-flavors-grid">
                            @{
                                var idx = 0;
                            }

                            @foreach (var sabor in Model.SaboresDisponiveis)
                            {
                                var saborId = $"sabor-{idx++}";
                                var disabled = sabor.Quantidade <= 0;

                                <div class="pdp-flavor-item @(disabled ? "is-disabled" : "")">
                                    <input type="radio"
                                           name="flavor"
                                           id="@saborId"
                                           value="@sabor.Sabor"
                                           class="pdp-flavor-radio"
                                           data-estoque="@sabor.Quantidade"
                                           @(disabled ? "disabled" : null) />

                                    <label for="@saborId" class="pdp-flavor-label">
                                        <span class="pdp-flavor-name">@sabor.Sabor</span>
                                        <small>@(disabled ? "Esgotado" : $"{sabor.Quantidade} em estoque")</small>
                                    </label>
                                </div>
                            }
                        </div>
                    </fieldset>

                    <div class="pdp-flavor-stock" id="estoque-info" hidden>
                        <i class="fas fa-boxes"></i>
                        Estoque do sabor: <strong id="estoque-quantidade"></strong>
                    </div>
                </section>
            }

            <section class="pdp-buy-box">
                <div class="pdp-qty-wrap">
                    <label for="quantity" class="pdp-qty-label">Quantidade</label>

                    <div class="pdp-qty-control">
                        <button type="button" class="pdp-qty-btn minus" aria-label="Diminuir">-</button>

                        <input type="number"
                               id="quantity"
                               name="quantity"
                               value="1"
                               min="1"
                               max="@(produto.Estoque > 0 ? produto.Estoque : 1)"
                               class="pdp-qty-input" />

                        <button type="button" class="pdp-qty-btn plus" aria-label="Aumentar">+</button>
                    </div>
                </div>

                <form asp-controller="Carrinho" asp-action="AdicionarItem" method="post" id="addToCartForm" class="pdp-buy-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="produtoId" value="@produto.Id" />
                    <input type="hidden" name="quantidade" id="quantidadeHidden" value="1" />
                    <input type="hidden" name="sabor" id="saborSelecionado" value="" />
                    <input type="hidden" name="observacoes" id="observacoesProduto" value="" />

                    <div class="pdp-buy-actions">
                        <button type="submit"
                                class="pdp-btn pdp-btn-primary"
                                @(produto.Estoque <= 0 ? "disabled" : null)>
                            <i class="fas fa-shopping-cart"></i>
                            @(produto.Estoque <= 0 ? "Produto esgotado" : "Adicionar ao carrinho")
                        </button>

                        <button type="button"
                                class="pdp-btn pdp-btn-secondary"
                                @(produto.Estoque <= 0 ? "disabled" : null)>
                            <i class="fas fa-bolt"></i>
                            Comprar agora
                        </button>
                    </div>
                </form>

                @if (produto.RequerMaioridade)
                {
                   @*  <div class="pdp-age-alert">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>Produto destinado a maiores de 18 anos.</span>
                    </div> *@
                }
            </section>
        </aside>
    </section>

    @* <div class="pdp-mobile-bar">
        <div class="pdp-mobile-bar-inner">
            <div class="pdp-mobile-bar-price">
                <small>Preço</small>
                <strong>@precoAtual.ToString("C")</strong>
            </div>

            <button type="button"
                    class="pdp-btn pdp-btn-primary"
                    id="mobileAddToCartBtn"
                    @(produto.Estoque <= 0 ? "disabled" : null)>
                <i class="fas fa-shopping-cart"></i>
                Comprar
            </button>
        </div>
    </div> *@

    <section class="pdp-tabs-section">
        <div class="pdp-tabs-header" role="tablist">
            <button class="pdp-tab-btn active" type="button" data-tab="descricao">Descrição</button>
            <button class="pdp-tab-btn" type="button" data-tab="especificacoes">Especificações</button>
            <button class="pdp-tab-btn" type="button" data-tab="informacoes">Info</button>
        </div>

        <div class="pdp-tab-pane active" data-pane="descricao">
            <div class="pdp-content-card">
                <h3>Descrição</h3>
                <p>@(string.IsNullOrWhiteSpace(produto.Descricao) ? "Sem descrição cadastrada." : produto.Descricao)</p>
            </div>
        </div>

        <div class="pdp-tab-pane" data-pane="especificacoes">
            <div class="pdp-content-card">
                <h3>Especificações técnicas</h3>

                <div class="pdp-specs-grid">
                    <div class="pdp-spec-item">
                        <span>Nome</span>
                        <strong>@produto.Nome</strong>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(produto.Marca))
                    {
                        <div class="pdp-spec-item">
                            <span>Marca</span>
                            <strong>@produto.Marca</strong>
                        </div>
                    }

                    <div class="pdp-spec-item">
                        <span>Preço</span>
                        <strong>@precoAtual.ToString("C")</strong>
                    </div>

                    <div class="pdp-spec-item">
                        <span>Estoque</span>
                        <strong>@produto.Estoque unidade(s)</strong>
                    </div>

                    @if (isPod)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="pdp-spec-item">
                                <span>Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div>
                        }
                        @if (produto.PodPuffs.HasValue)
                        {
                            <div class="pdp-spec-item">
                                <span>Puffs</span>
                                <strong>@produto.PodPuffs.Value</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.PodCapacidadeBateria))
                        {
                            <div class="pdp-spec-item">
                                <span>Bateria</span>
                                <strong>@produto.PodCapacidadeBateria</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.PodTipo))
                        {
                            <div class="pdp-spec-item">
                                <span>Tipo do pod</span>
                                <strong>@produto.PodTipo</strong>
                            </div>
                        }
                    }

                    @if (isBebida)
                    {
                        @if (produto.BebidaVolumeMl.HasValue)
                        {
                            <div class="pdp-spec-item">
                                <span>Volume</span>
                                <strong>@produto.BebidaVolumeMl.Value ml</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.BebidaTipo))
                        {
                            <div class="pdp-spec-item">
                                <span>Tipo</span>
                                <strong>@produto.BebidaTipo</strong>
                            </div>
                        }
                        @if (produto.BebidaEmbalagem.HasValue)
                        {
                            <div class="pdp-spec-item">
                                <span>Embalagem</span>
                                <strong>@produto.BebidaEmbalagem.Value</strong>
                            </div>
                        }
                        @if (produto.BebidaQtdPorEmbalagem.HasValue)
                        {
                            <div class="pdp-spec-item">
                                <span>Qtd. embalagem</span>
                                <strong>@produto.BebidaQtdPorEmbalagem.Value</strong>
                            </div>
                        }
                        @if (produto.BebidaTeorAlcoolico.HasValue)
                        {
                            <div class="pdp-spec-item">
                                <span>Teor alcoólico</span>
                                <strong>@produto.BebidaTeorAlcoolico.Value.ToString("0.##")%</strong>
                            </div>
                        }
                    }

                    @if (isPadrao)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="pdp-spec-item">
                                <span>Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.Cor))
                        {
                            <div class="pdp-spec-item">
                                <span>Cor</span>
                                <strong>@produto.Cor</strong>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="pdp-tab-pane" data-pane="informacoes">
            <div class="pdp-content-card">
                <h3>Informações adicionais</h3>

                <ul class="pdp-info-list">
                    <li>Produto vendido por loja vinculada à plataforma.</li>
                    <li>Disponibilidade sujeita à atualização de estoque.</li>

                    @if (produto.RequerMaioridade)
                    {
                        <li>Venda permitida apenas para maiores de 18 anos.</li>
                    }

                    @if (isPod)
                    {
                        <li>Selecione o sabor antes de adicionar ao carrinho.</li>
                    }

                    @if (isBebida)
                    {
                        <li>Confira volume, embalagem e teor alcoólico antes da compra.</li>
                    }
                </ul>
            </div>
        </div>
    </section>

    @if (Model?.ProdutosRelacionados != null && Model.ProdutosRelacionados.Any())
    {
        <section class="pdp-related-section">
            <div class="pdp-related-head">
                <h2>Produtos relacionados</h2>
                <p>Outras opções que podem combinar com esta compra.</p>
            </div>

            <div class="pdp-related-grid">
                @foreach (var pr in Model.ProdutosRelacionados)
                {
                    var prTemPromo = pr.PrecoPromocional.HasValue && pr.PrecoPromocional.Value > 0 && pr.PrecoPromocional.Value < pr.Preco;
                    var prPreco = prTemPromo ? pr.PrecoPromocional!.Value : pr.Preco;

                    <article class="pdp-related-card">
                        <a asp-controller="Produto" asp-action="Detalhes" asp-route-id="@pr.Id" class="pdp-related-link">
                            <div class="pdp-related-image">
                                @if (!string.IsNullOrWhiteSpace(pr.ImagemUrl))
                                {
                                    <img src="@Url.Content(pr.ImagemUrl)" alt="@pr.Nome" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <div class="pdp-related-placeholder">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }

                                @if (prTemPromo)
                                {
                                    <span class="pdp-related-ribbon">Promo</span>
                                }
                            </div>

                            <div class="pdp-related-body">
                                <h3>@pr.Nome</h3>

                                <div class="pdp-related-price">
                                    @if (prTemPromo)
                                    {
                                        <span class="old">@pr.Preco.ToString("C")</span>
                                    }

                                    <span class="new">@prPreco.ToString("C")</span>
                                </div>

                                <div class="pdp-related-status @(pr.Estoque > 0 ? "is-in" : "is-out")">
                                    @(pr.Estoque > 0 ? "Em estoque" : "Esgotado")
                                </div>
                            </div>
                        </a>
                    </article>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const qtd = document.getElementById('quantity');
            const qtdHidden = document.getElementById('quantidadeHidden');
            const minus = document.querySelector('.pdp-qty-btn.minus');
            const plus = document.querySelector('.pdp-qty-btn.plus');
            const mobileAdd = document.getElementById('mobileAddToCartBtn');
            const form = document.getElementById('addToCartForm');
            const max = parseInt(qtd?.max || '1', 10);

            function normalizeQty() {
                if (!qtd) return;
                let value = parseInt(qtd.value || '1', 10);
                if (isNaN(value) || value < 1) value = 1;
                if (value > max) value = max;
                qtd.value = value;
                if (qtdHidden) qtdHidden.value = value;
            }

            minus?.addEventListener('click', function () {
                if (!qtd) return;
                qtd.stepDown();
                normalizeQty();
            });

            plus?.addEventListener('click', function () {
                if (!qtd) return;
                qtd.stepUp();
                normalizeQty();
            });

            qtd?.addEventListener('input', normalizeQty);

            mobileAdd?.addEventListener('click', function () {
                if (!form) return;
                form.requestSubmit();
            });

            normalizeQty();
        })();

        (function () {
            const radios = document.querySelectorAll('.pdp-flavor-radio');
            const hidden = document.getElementById('saborSelecionado');
            const info = document.getElementById('estoque-info');
            const span = document.getElementById('estoque-quantidade');

            radios.forEach(r => {
                r.addEventListener('change', function (e) {
                    const value = e.target.value;
                    const estoque = e.target.getAttribute('data-estoque') || '0';

                    if (hidden) hidden.value = value;

                    if (info && span) {
                        span.textContent = estoque;
                        info.hidden = false;
                    }
                });
            });
        })();

        (function () {
            const tabs = document.querySelectorAll('.pdp-tab-btn');
            const panes = document.querySelectorAll('.pdp-tab-pane');

            tabs.forEach(btn => {
                btn.addEventListener('click', function () {
                    const tab = btn.getAttribute('data-tab');

                    tabs.forEach(x => x.classList.remove('active'));
                    panes.forEach(x => x.classList.remove('active'));

                    btn.classList.add('active');
                    document.querySelector(`.pdp-tab-pane[data-pane="${tab}"]`)?.classList.add('active');
                });
            });
        })();
    </script>
}