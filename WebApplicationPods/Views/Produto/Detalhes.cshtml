@using System.Globalization
@using WebApplicationPods.Enum
@model WebApplicationPods.Models.ProdutoDetalhesViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model?.Produto?.Nome ?? "Produto";

    var produto = Model?.Produto;
    if (produto == null)
    {
        <div class="container py-5">
            <div class="alert alert-warning">Produto não encontrado.</div>
        </div>
        return;
    }

    var temPromocao = produto.PrecoPromocional.HasValue && produto.PrecoPromocional.Value > 0 && produto.PrecoPromocional.Value < produto.Preco;
    var precoAtual = temPromocao ? produto.PrecoPromocional!.Value : produto.Preco;
    var precoPix = Math.Round(precoAtual * 0.95m, 2);

    var isPod = produto.TipoProduto == ProdutoTipo.PodVape;
    var isBebida = produto.TipoProduto == ProdutoTipo.BebidaAlcoolica;
    var isPadrao = !isPod && !isBebida;

    var totalSabores = Model?.SaboresDisponiveis?.Count ?? 0;
    var totalSaboresComEstoque = Model?.SaboresDisponiveis?.Count(s => s.Quantidade > 0) ?? 0;

    string tipoLabel = isPod ? "Pod" : isBebida ? "Bebida alcoólica" : "Produto";
    string disponibilidade = produto.Estoque > 0 ? "Em estoque" : "Esgotado";
}

<link rel="stylesheet" href="~/css/produto-detalhes.css" asp-append-version="true" />

<div id="product-data"
     data-stock="@produto.Estoque"
     data-is-out-of-stock="@(produto.Estoque <= 0 ? "true" : "false")"
     hidden></div>

<div class="produto-detalhes-page page-content" itemscope itemtype="https://schema.org/Product">

    <div class="produto-topbar">
        <a href="javascript:history.back()" class="btn-voltar">
            <i class="fas fa-arrow-left"></i>
            <span>Voltar</span>
        </a>

        <div class="produto-topbar-badges">
            <span class="tipo-badge">@tipoLabel</span>

            @if (produto.RequerMaioridade)
            {
                <span class="idade-badge">
                    <i class="fas fa-ban"></i> Venda 18+
                </span>
            }

            @if (produto.Estoque <= 0)
            {
                <span class="status-badge out">Esgotado</span>
            }
            else if (temPromocao)
            {
                <span class="status-badge promo">Promoção</span>
            }
            else
            {
                <span class="status-badge in">Disponível</span>
            }
        </div>
    </div>

    <div class="produto-hero">
        <div class="produto-galeria-card">
            @if (!string.IsNullOrWhiteSpace(produto.ImagemUrl))
            {
                <img src="@Url.Content(produto.ImagemUrl)"
                     alt="@produto.Nome"
                     class="produto-imagem-principal"
                     width="900"
                     height="900"
                     loading="lazy"
                     decoding="async"
                     itemprop="image" />
            }
            else
            {
                <div class="produto-imagem-placeholder">
                    <i class="fas fa-image"></i>
                    <span>Imagem não disponível</span>
                </div>
            }

            <div class="produto-selos">
                <div class="selo-item">
                    <i class="fas fa-shield-alt"></i>
                    <span>Compra segura</span>
                </div>
                <div class="selo-item">
                    <i class="fas fa-bolt"></i>
                    <span>Atendimento rápido</span>
                </div>
                @if (produto.Estoque > 0)
                {
                    <div class="selo-item">
                        <i class="fas fa-box-open"></i>
                        <span>Pronta entrega</span>
                    </div>
                }
            </div>
        </div>

        <div class="produto-resumo-card">
            <div class="produto-headline">
                <h1 class="produto-titulo" itemprop="name">@produto.Nome</h1>

                @if (!string.IsNullOrWhiteSpace(produto.Marca))
                {
                    <div class="produto-marca">Marca: <strong>@produto.Marca</strong></div>
                }

                @if (!string.IsNullOrWhiteSpace(produto.SKU) || !string.IsNullOrWhiteSpace(produto.CodigoBarras))
                {
                    <div class="produto-meta-linha">
                        @if (!string.IsNullOrWhiteSpace(produto.SKU))
                        {
                            <span>SKU: @produto.SKU</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.CodigoBarras))
                        {
                            <span>Cód. barras: @produto.CodigoBarras</span>
                        }
                    </div>
                }
            </div>

            <section class="produto-preco-box" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                <meta itemprop="priceCurrency" content="BRL" />
                <meta itemprop="price" content="@precoAtual.ToString(CultureInfo.InvariantCulture)" />
                <link itemprop="availability" href="https://schema.org/@(produto.Estoque > 0 ? "InStock" : "OutOfStock")" />

                <div class="preco-linha-principal">
                    <div class="preco-valores">
                        @if (temPromocao)
                        {
                            <span class="preco-antigo">@produto.Preco.ToString("C")</span>
                        }

                        <span class="preco-atual">@precoAtual.ToString("C")</span>

                        @if (temPromocao)
                        {
                            var desconto = (int)Math.Round(100 - (precoAtual / produto.Preco * 100));
                            <span class="desconto-chip">@desconto% OFF</span>
                        }
                    </div>

                    <div class="estoque-chip @(produto.Estoque > 0 ? "in" : "out")">
                        <i class="fas @(produto.Estoque > 0 ? "fa-check-circle" : "fa-times-circle")"></i>
                        <span>@disponibilidade</span>
                    </div>
                </div>

                <div class="preco-secundario">
                    <span class="pix-linha">Pix: <strong>@precoPix.ToString("C")</strong></span>
                    <span class="parcelamento-linha">Cartão: <strong>1x de @precoAtual.ToString("C")</strong></span>
                </div>
            </section>

            <section class="produto-resumo-tecnico">
                <div class="section-title-row">
                    <h3>Resumo do produto</h3>
                </div>

                <div class="resumo-grid resumo-grid-compacto">
                    @if (isPod)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="resumo-item resumo-item-wide">
                                <span class="label">Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div>
                        }

                        @if (produto.PodPuffs.HasValue)
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Puffs</span>
                                <strong>@produto.PodPuffs.Value</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.PodCapacidadeBateria))
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Bateria</span>
                                <strong>@produto.PodCapacidadeBateria</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.PodTipo))
                        {
                            <div class="resumo-item resumo-item-wide">
                                <span class="label">Tipo</span>
                                <strong>@produto.PodTipo</strong>
                            </div>
                        }
                    }
                    else if (isBebida)
                    {
                        @if (produto.BebidaVolumeMl.HasValue)
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Volume</span>
                                <strong>@produto.BebidaVolumeMl.Value ml</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.BebidaTipo))
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Tipo</span>
                                <strong>@produto.BebidaTipo</strong>
                            </div>
                        }

                        @if (produto.BebidaTeorAlcoolico.HasValue)
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Teor</span>
                                <strong>@produto.BebidaTeorAlcoolico.Value.ToString("0.##")%</strong>
                            </div>
                        }

                        @if (produto.BebidaQtdPorEmbalagem.HasValue && produto.BebidaQtdPorEmbalagem.Value > 0)
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Embalagem</span>
                                <strong>@produto.BebidaQtdPorEmbalagem.Value un.</strong>
                            </div>
                        }
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="resumo-item resumo-item-wide">
                                <span class="label">Sabor</span>
                                <strong>@produto.Sabor</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(produto.Cor))
                        {
                            <div class="resumo-item resumo-item-compact">
                                <span class="label">Cor</span>
                                <strong>@produto.Cor</strong>
                            </div>
                        }

                        <div class="resumo-item resumo-item-compact">
                            <span class="label">Estoque</span>
                            <strong>@produto.Estoque unidade(s)</strong>
                        </div>
                    }
                </div>
            </section>

            @if (isPod && Model?.SaboresDisponiveis != null && Model.SaboresDisponiveis.Any())
            {
                <section class="sabores-box">
                    <div class="box-head">
                        <h3>Escolha o sabor</h3>
                        <small>@totalSaboresComEstoque de @totalSabores disponível(is)</small>
                    </div>

                    <fieldset class="sabores-fieldset">
                        <legend class="sr-only">Sabores disponíveis</legend>

                        <div class="sabores-grid">
                            @{
                                var idx = 0;
                            }
                            @foreach (var sabor in Model.SaboresDisponiveis)
                            {
                                var saborId = $"sabor-{idx++}";
                                var disabled = sabor.Quantidade <= 0;

                                <div class="sabor-card @(disabled ? "is-disabled" : "")">
                                    <input type="radio"
                                           name="flavor"
                                           id="@saborId"
                                           value="@sabor.Sabor"
                                           class="flavor-radio"
                                           data-estoque="@sabor.Quantidade"
                                           @(disabled ? "disabled" : null) />
                                    <label for="@saborId" class="sabor-label">
                                        <span class="sabor-nome">@sabor.Sabor</span>
                                        @if (disabled)
                                        {
                                            <span class="sabor-status out">Esgotado</span>
                                        }
                                        else
                                        {
                                            <span class="sabor-status in">@sabor.Quantidade em estoque</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    </fieldset>

                    <div class="estoque-sabor-info" id="estoque-info" hidden>
                        <i class="fas fa-boxes"></i>
                        Estoque do sabor: <strong id="estoque-quantidade"></strong>
                    </div>
                </section>
            }

            <section class="compra-box">
                <div class="quantidade-box">
                    <label for="quantity">Quantidade</label>
                    <div class="quantity-control">
                        <button type="button" class="quantity-btn minus" aria-label="Diminuir">-</button>
                        <input type="number"
                               id="quantity"
                               name="quantity"
                               value="1"
                               min="1"
                               max="@(produto.Estoque > 0 ? produto.Estoque : 1)"
                               class="quantity-input" />
                        <button type="button" class="quantity-btn plus" aria-label="Aumentar">+</button>
                    </div>
                </div>

                <form asp-controller="Carrinho" asp-action="AdicionarItem" method="post" id="addToCartForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="produtoId" value="@produto.Id" />
                    <input type="hidden" name="quantidade" id="quantidadeHidden" value="1" />
                    <input type="hidden" name="sabor" id="saborSelecionado" value="" />
                    <input type="hidden" name="observacoes" id="observacoesProduto" value="" />

                    <button type="submit"
                            class="btn-principal"
                            @(produto.Estoque <= 0 ? "disabled" : null)>
                        <i class="fas fa-shopping-cart"></i>
                        @(produto.Estoque <= 0 ? "Produto esgotado" : "Adicionar ao carrinho")
                    </button>
                </form>

                <button type="button"
                        class="btn-secundario"
                        @(produto.Estoque <= 0 ? "disabled" : null)>
                    <i class="fas fa-bolt"></i>
                    Comprar agora
                </button>

                @if (produto.RequerMaioridade)
                {
                    <div class="alerta-maioridade">
                        <i class="fas fa-exclamation-triangle"></i>
                        Produto destinado a maiores de 18 anos.
                    </div>
                }
            </section>
        </div>
    </div>

    <div class="mobile-buybar">
        <div class="mobile-buybar-inner">
            <div class="mobile-buybar-price">
                <small>Preço</small>
                <strong>@precoAtual.ToString("C")</strong>
            </div>
            <button type="button"
                    class="btn-principal"
                    id="mobileAddToCartBtn"
                    @(produto.Estoque <= 0 ? "disabled" : null)>
                <i class="fas fa-shopping-cart"></i>
                Comprar
            </button>
        </div>
    </div>

    <section class="produto-tabs-section">
        <div class="tabs-header" role="tablist">
            <button class="tab-button active" type="button" data-tab="descricao">Descrição</button>
            <button class="tab-button" type="button" data-tab="especificacoes">Especificações</button>
            <button class="tab-button" type="button" data-tab="informacoes">Informações</button>
        </div>

        <div class="tab-pane active" data-pane="descricao">
            <div class="content-card">
                <h3>Descrição</h3>
                <p>@(string.IsNullOrWhiteSpace(produto.Descricao) ? "Sem descrição cadastrada." : produto.Descricao)</p>
            </div>
        </div>

        <div class="tab-pane" data-pane="especificacoes">
            <div class="content-card">
                <h3>Especificações técnicas</h3>

                <div class="specs-grid">
                    <div class="spec-item"><span>Nome</span><strong>@produto.Nome</strong></div>

                    @if (!string.IsNullOrWhiteSpace(produto.Marca))
                    {
                        <div class="spec-item"><span>Marca</span><strong>@produto.Marca</strong></div>
                    }

                    <div class="spec-item"><span>Preço</span><strong>@precoAtual.ToString("C")</strong></div>
                    <div class="spec-item"><span>Estoque</span><strong>@produto.Estoque unidade(s)</strong></div>

                    @if (isPod)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="spec-item"><span>Sabor</span><strong>@produto.Sabor</strong></div>
                        }
                        @if (produto.PodPuffs.HasValue)
                        {
                            <div class="spec-item"><span>Puffs</span><strong>@produto.PodPuffs.Value</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.PodCapacidadeBateria))
                        {
                            <div class="spec-item"><span>Bateria</span><strong>@produto.PodCapacidadeBateria</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.PodTipo))
                        {
                            <div class="spec-item"><span>Tipo do pod</span><strong>@produto.PodTipo</strong></div>
                        }
                    }

                    @if (isBebida)
                    {
                        @if (produto.BebidaVolumeMl.HasValue)
                        {
                            <div class="spec-item"><span>Volume</span><strong>@produto.BebidaVolumeMl.Value ml</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.BebidaTipo))
                        {
                            <div class="spec-item"><span>Tipo</span><strong>@produto.BebidaTipo</strong></div>
                        }
                        @if (produto.BebidaEmbalagem.HasValue)
                        {
                            <div class="spec-item"><span>Embalagem</span><strong>@produto.BebidaEmbalagem.Value</strong></div>
                        }
                        @if (produto.BebidaQtdPorEmbalagem.HasValue)
                        {
                            <div class="spec-item"><span>Qtd. embalagem</span><strong>@produto.BebidaQtdPorEmbalagem.Value</strong></div>
                        }
                        @if (produto.BebidaTeorAlcoolico.HasValue)
                        {
                            <div class="spec-item"><span>Teor alcoólico</span><strong>@produto.BebidaTeorAlcoolico.Value.ToString("0.##")%</strong></div>
                        }
                    }

                    @if (isPadrao)
                    {
                        @if (!string.IsNullOrWhiteSpace(produto.Sabor))
                        {
                            <div class="spec-item"><span>Sabor</span><strong>@produto.Sabor</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.Cor))
                        {
                            <div class="spec-item"><span>Cor</span><strong>@produto.Cor</strong></div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="tab-pane" data-pane="informacoes">
            <div class="content-card">
                <h3>Informações adicionais</h3>

                <ul class="lista-info">
                    <li>Produto vendido por loja vinculada à plataforma.</li>
                    <li>Disponibilidade sujeita à atualização de estoque.</li>

                    @if (produto.RequerMaioridade)
                    {
                        <li>Venda permitida apenas para maiores de 18 anos.</li>
                    }

                    @if (isPod)
                    {
                        <li>Selecione o sabor antes de adicionar ao carrinho.</li>
                    }

                    @if (isBebida)
                    {
                        <li>Confira volume, embalagem e teor alcoólico antes da compra.</li>
                    }
                </ul>
            </div>
        </div>
    </section>

    @if (Model?.ProdutosRelacionados != null && Model.ProdutosRelacionados.Any())
    {
        <section class="relacionados-section">
            <div class="section-head">
                <h2>Produtos relacionados</h2>
                <p>Outras opções que podem combinar com esta compra.</p>
            </div>

            <div class="relacionados-grid">
                @foreach (var pr in Model.ProdutosRelacionados)
                {
                    var prTemPromo = pr.PrecoPromocional.HasValue && pr.PrecoPromocional.Value > 0 && pr.PrecoPromocional.Value < pr.Preco;
                    var prPreco = prTemPromo ? pr.PrecoPromocional!.Value : pr.Preco;

                    <article class="produto-card-rel">
                        <a asp-controller="Produto" asp-action="Detalhes" asp-route-id="@pr.Id" class="produto-card-link">
                            <div class="produto-card-img">
                                @if (!string.IsNullOrWhiteSpace(pr.ImagemUrl))
                                {
                                    <img src="@Url.Content(pr.ImagemUrl)" alt="@pr.Nome" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <div class="produto-card-placeholder">
                                        <i class="fas fa-image"></i>
                                    </div>
                                }

                                @if (prTemPromo)
                                {
                                    <span class="produto-card-ribbon">Promo</span>
                                }
                            </div>

                            <div class="produto-card-body">
                                <h3>@pr.Nome</h3>

                                <div class="produto-card-preco">
                                    @if (prTemPromo)
                                    {
                                        <span class="old">@pr.Preco.ToString("C")</span>
                                    }
                                    <span class="new">@prPreco.ToString("C")</span>
                                </div>

                                <div class="produto-card-status @(pr.Estoque > 0 ? "in" : "out")">
                                    @(pr.Estoque > 0 ? "Em estoque" : "Esgotado")
                                </div>
                            </div>
                        </a>
                    </article>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const qtd = document.getElementById('quantity');
            const qtdHidden = document.getElementById('quantidadeHidden');
            const minus = document.querySelector('.quantity-btn.minus');
            const plus = document.querySelector('.quantity-btn.plus');
            const mobileAdd = document.getElementById('mobileAddToCartBtn');
            const form = document.getElementById('addToCartForm');
            const max = parseInt(qtd?.max || '1', 10);

            function normalizeQty() {
                if (!qtd) return;
                let value = parseInt(qtd.value || '1', 10);
                if (isNaN(value) || value < 1) value = 1;
                if (value > max) value = max;
                qtd.value = value;
                if (qtdHidden) qtdHidden.value = value;
            }

            minus?.addEventListener('click', function () {
                if (!qtd) return;
                qtd.stepDown();
                normalizeQty();
            });

            plus?.addEventListener('click', function () {
                if (!qtd) return;
                qtd.stepUp();
                normalizeQty();
            });

            qtd?.addEventListener('input', normalizeQty);

            mobileAdd?.addEventListener('click', function () {
                if (!form) return;
                form.requestSubmit();
            });

            normalizeQty();
        })();

        (function () {
            const radios = document.querySelectorAll('.flavor-radio');
            const hidden = document.getElementById('saborSelecionado');
            const info = document.getElementById('estoque-info');
            const span = document.getElementById('estoque-quantidade');

            radios.forEach(r => {
                r.addEventListener('change', function (e) {
                    const value = e.target.value;
                    const estoque = e.target.getAttribute('data-estoque') || '0';

                    if (hidden) hidden.value = value;
                    if (info && span) {
                        span.textContent = estoque;
                        info.hidden = false;
                    }
                });
            });
        })();

        (function () {
            const tabs = document.querySelectorAll('.tab-button');
            const panes = document.querySelectorAll('.tab-pane');

            tabs.forEach(btn => {
                btn.addEventListener('click', function () {
                    const tab = btn.getAttribute('data-tab');

                    tabs.forEach(x => x.classList.remove('active'));
                    panes.forEach(x => x.classList.remove('active'));

                    btn.classList.add('active');
                    document.querySelector(`.tab-pane[data-pane="${tab}"]`)?.classList.add('active');
                });
            });
        })();
    </script>
}