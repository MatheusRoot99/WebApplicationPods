@model SitePodsInicial.Models.ProdutoModel

@{
    ViewData["Title"] = "Editar Pod Eletrônico";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h4>@ViewData["Title"]</h4>
            <small class="text-muted">ID: @Model.Id</small>
        </div>
        <div class="card-body">
            <form asp-action="Editar" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DataCadastro" />
                <input type="hidden" asp-for="ImagemUrl" /> <!-- Campo oculto para manter a URL da imagem -->

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Nome" class="control-label"></label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Descricao" class="control-label"></label>
                            <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CategoriaId" class="control-label">Categoria</label>
                            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
                                <option value="">Selecione a categoria</option>
                            </select>
                            <span asp-validation-for="CategoriaId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Preco" class="control-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="Preco" id="Preco" class="form-control money-mask" />
                            </div>
                            <span asp-validation-for="Preco" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Estoque" class="control-label"></label>
                            <input asp-for="Estoque" class="form-control" />
                            <span asp-validation-for="Estoque" class="text-danger"></span>
                        </div>

                        <!-- Seção da Imagem Atual -->
                        <div class="form-group mb-3">
                            <label class="control-label">Imagem Atual</label>
                            @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ImagemUrl" alt="Imagem do produto" class="img-thumbnail" style="max-height: 200px;" />
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Nenhuma imagem cadastrada</p>
                            }

                            <label class="control-label">Alterar Imagem (opcional)</label>
                            <input type="file" asp-for="ImagemUpload" class="form-control" accept="image/*" />
                            <small class="text-muted">Deixe em branco para manter a imagem atual</small>
                            <span asp-validation-for="ImagemUpload" class="text-danger"></span>
                        </div>

                        <div class="form-group form-check mb-3">
                            <input class="form-check-input" asp-for="Ativo" />
                            <label class="form-check-label" asp-for="Ativo"></label>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-save"></i> Salvar Alterações
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Aplica a máscara monetária
            $('.money-mask').mask('#.##0,00', { reverse: true });

            // Validação do tamanho da imagem
            $('input[type="file"]').change(function() {
                const file = this.files[0];
                if (file) {
                    if (file.size > 2 * 1024 * 1024) {
                        alert('O tamanho da imagem não pode exceder 2MB');
                        $(this).val('');
                    }

                    const allowedExtensions = ['jpg', 'jpeg', 'png'];
                    const extension = file.name.split('.').pop().toLowerCase();
                    if (!allowedExtensions.includes(extension)) {
                        alert('Apenas arquivos JPG, JPEG e PNG são permitidos');
                        $(this).val('');
                    }
                }
            });
        });
    </script>
}