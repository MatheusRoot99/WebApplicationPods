@model WebApplicationPods.Models.ProdutoModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="col-md-4 mb-4">
    <div class="card h-100 produto-card shadow-sm">
        <!-- Imagem do produto -->
        @if (!string.IsNullOrEmpty(Model.ImagemUrl))
        {
            <img src="@Url.Content(Model.ImagemUrl)" class="card-img-top" alt="@Model.Nome" style="height: 200px; object-fit: cover;">
        }
        else
        {
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                <i class="fas fa-image fa-3x text-secondary"></i>
            </div>
        }

        <!-- Badges de status -->
        <div class="position-absolute top-0 end-0 p-2">
            @if (Model.Estoque <= 0)
            {
                <span class="badge bg-danger">ESGOTADO</span>
            }
            else if (Model.PrecoPromocional.HasValue && Model.PrecoPromocional < Model.Preco)
            {
                <span class="badge bg-success">PROMOÇÃO</span>
            }
        </div>

        <div class="card-body d-flex flex-column">
            <h5 class="card-title">@Model.Nome</h5>

            <!-- Descrição resumida -->
            <p class="card-text text-muted small mb-2">
                @if (!string.IsNullOrEmpty(Model.Descricao))
                {
                    @(Model.Descricao.Length > 50 ? Model.Descricao.Substring(0, 50) + "..." : Model.Descricao)
                }
            </p>

            <!-- Especificações -->
            <div class="small text-muted mb-2">
                @if (Model.Puffs > 0)
                {
                    <div><i class="fas fa-smoking me-1"></i> @Model.Puffs puffs</div>
                }
                @if (Model.CapacidadeBateria > 0)
                {
                    <div><i class="fas fa-battery-three-quarters me-1"></i> @Model.CapacidadeBateria mAh</div>
                }
            </div>

            <!-- Preço -->
            <div class="mt-auto">
                @if (Model.PrecoPromocional.HasValue && Model.PrecoPromocional < Model.Preco)
                {
                    <div>
                        <span class="text-decoration-line-through text-muted">@Model.Preco.ToString("C")</span>
                        <span class="text-success fw-bold ms-2">@Model.PrecoPromocional.Value.ToString("C")</span>
                    </div>
                }
                else
                {
                    <h6 class="text-primary fw-bold">@Model.Preco.ToString("C")</h6>
                }

                <!-- Formulário de compra -->
                <form asp-controller="Carrinho" asp-action="AdicionarItem" method="post" class="mt-2">
                    <input type="hidden" name="produtoId" value="@Model.Id" />
                    <div class="d-flex gap-2">
                        <input type="number" name="quantidade" value="1" min="1"
                               class="form-control" style="width: 60px;"
                               @(Model.Estoque <= 0 ? "disabled" : "")>
                        <button type="submit" class="btn btn-outline-primary flex-grow-1"
                                @(Model.Estoque <= 0 ? "disabled" : "")>
                            <i class="fas fa-cart-plus"></i> Add
                        </button>
                    </div>
                </form>

                <!-- Link para detalhes -->
                <a asp-action="Detalhes" asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary btn-block mt-2">
                    Ver Detalhes
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .produto-card {
        transition: all 0.3s ease;
        border-radius: 10px;
    }

        .produto-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

    .card-img-top {
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }
</style>