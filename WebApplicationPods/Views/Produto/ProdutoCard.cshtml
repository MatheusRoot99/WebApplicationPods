@model ProdutoModel

<div class="col-md-4 mb-4">
    <div class="card h-100 produto-card">
        <img src="@Model" class="card-img-top" alt="@Model.Nome" style="height: 200px; object-fit: cover;">
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">@Model.Nome</h5>
            <p class="card-text text-muted">@Model.Descricao</p>
            <div class="mt-auto">
                <h6 class="text-primary">@Model.Preco.ToString("C")</h6>
                <form asp-controller="Carrinho" asp-action="AdicionarItem" method="post" class="mt-2">
                    <input type="hidden" name="produtoId" value="@Model.Id" />
                    <div class="input-group mb-2">
                        <input type="number" name="quantidade" value="1" min="1" class="form-control" style="width: 60px;">
                        <div class="input-group-append">
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="fas fa-cart-plus"></i> Add
                            </button>
                        </div>
                    </div>
                </form>
                <a asp-controller="Produto" asp-action="Detalhes" asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary btn-block">Detalhes</a>
            </div>
        </div>
    </div>
</div>