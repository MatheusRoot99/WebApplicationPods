@using Newtonsoft.Json
@model SitePodsInicial.Models.ProdutoModel
@{
    ViewData["Title"] = "Cadastrar Novo Pod";
    var categorias = ViewBag.Categorias as SelectList ?? new SelectList(new List<SelectListItem>());
}

<link rel="stylesheet" href="~/css/produtos.css" asp-append-version="true" />


<div class="hero-pods py-5 mb-5 text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="hero-badge mb-3"><i class="fas fa-plus-circle me-2"></i>ADICIONAR NOVO PRODUTO</span>
                <h1 class="display-5 fw-bold mb-3">Cadastre seu Pod</h1>
                <p class="lead mb-4">Preencha os detalhes do produto para disponibilizá-lo em nossa loja virtual</p>
            </div>
            <div class="col-lg-4 d-none d-lg-block">
                <img src="https://clubedovapor.net/13061-thickbox_default/pod-ignite-v300-30000-puffs.jpg" alt="Pod" class="img-fluid" style="max-height: 200px;">
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Sucesso!</strong> @TempData["MensagemSucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            <strong>Erro!</strong> @TempData["MensagemErro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0">
        <div class="card-header bg-gradient-primary text-white py-3">
            <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Formulário de Cadastro</h4>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-action="Criar" enctype="multipart/form-data" class="needs-validation" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <input type="hidden" name="SaboresQuantidadesList" value='@JsonConvert.SerializeObject(Model.SaboresQuantidadesList)' />

                <div class="row g-4">
                    <!-- Coluna Esquerda -->
                    <div class="col-lg-6">
                        <div class="mb-4">
                            <label asp-for="Nome" class="form-label fw-bold text-primary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-tag"></i></span>
                                <input asp-for="Nome" class="form-control form-control-lg" placeholder="Ex: Pod Descartável XYZ 5000 puffs" required />
                            </div>
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Descricao" class="form-label fw-bold text-primary"></label>
                            <textarea asp-for="Descricao" class="form-control form-control-lg" rows="5"
                                      placeholder="Descreva o pod, sabores disponíveis, características técnicas..." style="min-height: 150px;"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <label class="form-label fw-bold text-primary h5">Sabores e Quantidades</label>
                                        <span class="badge bg-primary">
                                            <i class="fas fa-ice-cream me-1"></i>
                                            <span id="totalSabores">@Model.SaboresQuantidadesList?.Count ?? 0</span> sabores
                                        </span>
                                    </div>

                                    <div class="card border-0 shadow-sm mb-3">
                                        <div class="card-body p-3">
                                            <div class="row g-2 align-items-center">
                                                <div class="col-md-7">
                                                    <select class="form-select" id="saborSelect">
                                                        <option value="">Selecione um sabor...</option>
                                                        @foreach (var sabor in Model.TodosSabores)
                                                        {
                                                            <option value="@sabor.Value" data-text="@sabor.Text">@sabor.Text</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <input type="number" min="1" value="1" class="form-control" id="quantidadeInput" placeholder="Qtd">
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn btn-primary w-100" id="addSaborBtn">
                                                        <i class="fas fa-plus-circle me-1"></i> Add
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="saboresSelecionadosList" class="mb-3">
                                        @if (Model.SaboresQuantidadesList != null && Model.SaboresQuantidadesList.Any())
                                        {
                                            foreach (var sq in Model.SaboresQuantidadesList)
                                            {
                                                <div class="card mb-2 border-0 shadow-sm sabor-item">
                                                    <div class="card-body py-2 px-3">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <span class="fw-bold text-primary">@sq.Sabor</span>
                                                                <span class="badge bg-light text-primary ms-2">@sq.Quantidade un.</span>
                                                            </div>
                                                            <button type="button" class="btn btn-sm btn-link text-danger remove-sabor">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                        </div>
                                                        <input type="hidden" name="SaboresQuantidadesList"
                                                               value='@Json.Serialize(new { Sabor = sq.Sabor, Quantidade = sq.Quantidade })'>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="fas fa-ice-cream fa-2x text-muted mb-3"></i>
                                                <p class="mb-0 text-muted">Nenhum sabor adicionado ainda</p>
                                            </div>
                                        }
                                    </div>

                                    <div class="text-muted small">
                                        <i class="fas fa-info-circle me-1"></i> Adicione os sabores disponíveis e suas quantidades
                                    </div>
                                </div>
                            
                                <div class="mb-4">
                                    <label asp-for="Cor" class="form-label fw-bold text-primary"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-palette"></i></span>
                                        <input asp-for="Cor" class="form-control" placeholder="Ex: Preto, Azul" />
                                    </div>
                                    <span asp-validation-for="Cor" class="text-danger small"></span>
                                </div>
                            
                        </div>
                    </div>

                    <!-- Coluna Direita -->
                    <div class="col-lg-6">
                        <div class="mb-4">
                            <label asp-for="CategoriaId" class="form-label fw-bold text-primary">Categoria</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-list"></i></span>
                                <select asp-for="CategoriaId" asp-items="@categorias"
                                        class="form-select" required>
                                    <option value="">Selecione uma categoria</option>
                                </select>
                            </div>
                            <span asp-validation-for="CategoriaId" class="text-danger small"></span>

                            @if (!categorias.Any())
                            {
                                <div class="alert alert-warning mt-2">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    Nenhuma categoria disponível. Por favor, cadastre categorias primeiro.
                                </div>
                            }
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label asp-for="Preco" class="form-label fw-bold text-primary"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-dollar-sign"></i></span>
                                        <input asp-for="Preco" id="preco" name="Preco"
                                               class="form-control money-mask"
                                               placeholder="0.00"
                                               required
                                               type="text"
                                               value=""
                                               inputmode="decimal"
                                                /> <!-- Remova qualquer value inicial -->
                                    </div>
                                    <span asp-validation-for="Preco" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label asp-for="PrecoPromocional" class="form-label fw-bold text-primary">Preço Promocional</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-tag"></i></span>
                                        <input asp-for="PrecoPromocional" id="precoPromocional" name="PrecoPromocional"
                                               class="form-control money-mask"
                                               placeholder="0.00"
                                               type="text"
                                               inputmode="decimal" />

                                    </div>
                                    <span asp-validation-for="PrecoPromocional" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="mb-4">
                                    <label asp-for="Estoque" class="form-label fw-bold text-primary"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-boxes"></i></span>
                                        <input asp-for="Estoque" class="form-control" value="0" min="0" />
                                    </div>
                                    <span asp-validation-for="Estoque" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-4">
                                    <label asp-for="Puffs" class="form-label fw-bold text-primary">Puffs</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-wind"></i></span>
                                        <input asp-for="Puffs" class="form-control" min="0" />
                                    </div>
                                    <span asp-validation-for="Puffs" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-4">
                                    <label asp-for="CapacidadeBateria" class="form-label fw-bold text-primary">Bateria (mAh)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="fas fa-battery-three-quarters"></i></span>
                                        <input asp-for="CapacidadeBateria" class="form-control" min="0" />
                                    </div>
                                    <span asp-validation-for="CapacidadeBateria" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-primary">Imagem do Produto</label>
                            <div class="file-upload-wrapper">
                                <input type="file" asp-for="ImagemUpload" class="form-control" id="imagemUpload" accept="image/*" />
                                <label for="imagemUpload" class="file-upload-label">
                                    <i class="fas fa-cloud-upload-alt me-2"></i>
                                    <span class="file-upload-text">Escolha uma imagem...</span>
                                </label>
                            </div>
                            <small class="text-muted">Formatos aceitos: JPG, PNG (Máx. 2MB)</small>
                            <span asp-validation-for="ImagemUpload" class="text-danger small"></span>
                        </div>

                        <div class="card mb-4 border-0 bg-light">
                            <div class="card-body p-3">
                                <div class="row">
                                    <div class="col-md-4 mb-2 mb-md-0">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input asp-for="EmPromocao" class="form-check-input" type="checkbox" id="emPromocaoSwitch" />
                                            <label asp-for="EmPromocao" class="form-check-label fw-bold text-primary"></label>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2 mb-md-0">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input asp-for="MaisVendido" class="form-check-input" type="checkbox" id="maisVendidoSwitch" />
                                            <label asp-for="MaisVendido" class="form-check-label fw-bold text-primary"></label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input asp-for="Ativo" class="form-check-input" type="checkbox" id="ativoSwitch" checked />
                                            <label asp-for="Ativo" class="form-check-label fw-bold text-primary"></label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-arrow-left me-2"></i> Voltar
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-4">
                        <i class="fas fa-save me-2"></i> Cadastrar Produto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        $(document).ready(function() {
            // Máscara para campos monetários
            $('.money-mask').mask('#.##0,00', { reverse: true });
        }); // Fechamento adicionado aqui
    </script>

    <!-- Inclui o arquivo JS separado -->
    <script src="~/js/produto-form.js" asp-append-version="true"></script>
}