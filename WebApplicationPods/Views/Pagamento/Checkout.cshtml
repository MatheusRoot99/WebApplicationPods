@using WebApplicationPods.Enum
@model WebApplicationPods.Models.PaymentModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Pagamento";
    var isPaid = Model.Status == PaymentStatus.Paid;
    // Gera token anti-CSRF e grava cookie; usamos o valor no header do fetch.
    var afToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;

    // URL de acompanhamento: tenta Pedidos/Acompanhar; fallback p/ Carrinho/Confirmacao
    var trackUrl = Url.Action("Acompanhar", "Pedidos", new { id = Model.PedidoId })
                  ?? Url.Action("Confirmacao", "Carrinho", new { id = Model.PedidoId });
}

@section Styles {
    <!-- Arquivo CSS externo da página de checkout -->
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />
}

<div id="checkout-page" class="container-xxl py-4">
    <div id="checkout-header" class="mb-3">
        <h3 class="page-title">Pagamento do pedido #@Model.PedidoId</h3>
        <p class="page-sub">Total a pagar: <strong>@Model.Amount.ToString("C")</strong></p>
    </div>

    <div id="checkout-status" class="status-wrap">
        <div class="status-bar">
            <div id="statusFill" class="fill"></div>
        </div>
        <span id="statusBadge" class="status-badge">Status: @Model.Status</span>
    </div>

    <div id="checkout-main-row" class="row g-4">

        <!-- COL ESQUERDA -->
        <div class="col-lg-7">
            <div id="checkout-main-card" class="card">
                <div class="card-header">
                    <h5 class="mb-0">Finalize seu pagamento</h5>
                </div>
                <div class="card-body">

                    @* ===================== PIX ===================== *@
                    @if (Model.Metodo == PaymentMethod.Pix)
                    {
                        <section id="pix-section" class="pix">
                            <h6 class="mb-2">Pix (chave/QR)</h6>

                            <p class="pix-lead">
                                Escaneie o QR Code com o app do seu banco <span class="d-none d-md-inline">ou</span>
                                <span class="d-md-none"><br /></span> use <strong>copia e cola</strong>.
                                Assim que o pagamento for identificado, a confirmação acontece automaticamente.
                            </p>

                            <div class="pix-grid">
                                <!-- Coluna do QR -->
                                <div class="pix-qr">
                                    <div id="pix-qr-container">
                                        @if (!string.IsNullOrEmpty(Model.PixQrBase64Png))
                                        {
                                            <img id="pix-qr-img"
                                                 src="data:image/png;base64,@Model.PixQrBase64Png"
                                                 alt="QR Code Pix" class="qr-box" />
                                        }
                                        else
                                        {
                                            <div id="pix-qr" class="qr-box text-secondary" aria-label="QR Code do Pix">QR Code</div>
                                        }
                                    </div>

                                    <div class="pix-meta">
                                        <div class="pix-amount">
                                            <span>Valor</span>
                                            <strong>@Model.Amount.ToString("C")</strong>
                                        </div>

                                        @if (Model.ExpiresAt.HasValue)
                                        {
                                            <div class="pix-expire">
                                                <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
                                                <span id="pix-timer"
                                                      data-exp="@Model.ExpiresAt.Value.ToUniversalTime().ToString("o")">
                                                    Expira em — <span id="pixCountdownTimer">--:--</span>
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Coluna de ações/“copia e cola” -->
                                <div class="pix-actions">
                                    <label class="form-label" for="pixCopyPaste">Copia e cola</label>
                                    <div class="input-group">
                                        <input class="form-control" value="@Model.PixQrData" id="pixCopyPaste" readonly />
                                        <button class="btn btn-soft" type="button" onclick="copyPix()" id="btnCopyPix">Copiar</button>
                                    </div>
                                    <small class="text-muted d-block mt-1">
                                        Cole o código no seu app bancário caso não possa ler o QR.
                                    </small>
                                    <span id="copyBadge" class="copy-badge d-none ms-2">Copiado!</span>

                                    <div class="pix-actions-row">
                                        <button class="btn btn-soft btn-sm" type="button" id="btnForcarConsulta">Atualizar status</button>
                                        <button class="btn btn-soft btn-sm" type="button" id="pix-cancel-btn">Cancelar</button>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }

                    @* ===================== CARTÃO ===================== *@
                    @if (Model.Metodo == PaymentMethod.CardCredit || Model.Metodo == PaymentMethod.CardDebit)
                    {
                        <section id="card-section">
                            <h6 class="mb-2">Pagamento com cartão</h6>
                            <div id="cardPaymentBrick_container"></div>

                            <div class="mt-3 d-flex gap-2 flex-wrap">
                                <button id="mp-cancel-btn" type="button" class="btn btn-soft flex-grow-1 flex-sm-grow-0">
                                    Cancelar
                                </button>
                            </div>

                            <div class="text-muted mt-2">Se necessário, faremos a autenticação 3-D Secure.</div>
                        </section>
                    }

                    @* ================= DINHEIRO/MAQUININHA ================ *@
                    @if (Model.Metodo == PaymentMethod.Cash)
                    {
                        <section id="cash-section">
                            <h6 class="mb-2">Pagamento na entrega</h6>
                            <p class="mb-0 text-muted">Seu pedido será cobrado na retirada/entrega.</p>
                        </section>
                    }

                    <hr class="my-4" />

                    <div class="d-flex flex-wrap gap-2">
                        <!-- Botão de acompanhar pedido (aparece quando pago) -->
                        <a id="goTrackBtn" href="@trackUrl" class="btn btn-brand d-none">
                            Acompanhar pedido
                        </a>
                        <!-- Voltar / mudar pagamento -->
                        @* <a class="btn btn-soft" href="@Url.Action("Index", "Carrinho")">Voltar</a> *@
                    </div>
                </div>
            </div>
        </div>

        <!-- COL DIREITA -->
        <div class="col-lg-5">
            <div id="checkout-summary-card" class="card sticky-lg-top" style="top:-27px;">
                <div class="card-header">
                    <h5 class="mb-0">Resumo</h5>
                </div>
                <div class="card-body">

                    <!-- Cabeçalho -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Pedido: #@Model.PedidoId</span>
                        <span id="pay-badge" class="badge bg-light text-dark">
                            Status: @Model.Status
                        </span>
                    </div>

                    <!-- Lista de itens -->
                    @{
                        var items = ViewBag.Itens as IEnumerable<dynamic>;
                    }
                    @if (items != null && items.Any())
                    {
                        <ul class="list-unstyled mb-3" id="checkout-resumo-itens">
                            @foreach (var it in items)
                            {
                                <li class="d-flex align-items-start gap-2 py-2 border-bottom">
                                    @if (it.Img != null)
                                    {
                                        <img src="@it.Img" alt="@it.Nome" style="width:48px;height:48px;object-fit:cover;border-radius:8px;" />
                                    }
                                    <div class="flex-grow-1">
                                        <div class="fw-600">@it.Nome</div>
                                        <div class="text-muted small">@it.Qtd × @(((decimal)it.Preco).ToString("C"))</div>
                                    </div>
                                    <div class="fw-600">@(((decimal)it.Subtotal).ToString("C"))</div>
                                </li>
                            }
                        </ul>
                    }

                    <!-- Totais -->
                    @{
                        var resumo = ViewBag.PedidoResumo;
                        decimal subtotal = resumo?.Subtotal ?? Model.Amount; // já com preço promocional
                        decimal frete = resumo?.Frete ?? 0m;
                        decimal desconto = resumo?.Desconto ?? 0m;           // só informativo
                        decimal total = subtotal + frete;                 // ✅ total correto
                    }

                    <div class="d-flex justify-content-between text-muted">
                        <span>Valor com desconto</span><span>@subtotal.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted">
                        <span>Valor entrega</span><span>@frete.ToString("C")</span>
                    </div>
                    @if (desconto > 0)
                    {
                        <div class="d-flex justify-content-between text-muted">
                            <span>Desconto</span><span>-@desconto.ToString("C")</span>
                        </div>
                    }
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fs-5 fw-600">
                        <span>Total</span><span>@total.ToString("C")</span>
                    </div>

                    <!-- CTA: Acompanhar pedido -->
                    <div class="mt-3">
                        <a id="btn-acompanhar-pedido"
                           class="btn btn-outline-primary w-100 @(isPaid ? "" : "d-none")"
                           href="@Url.Action("Acompanhar", "Pedido", new { id = Model.PedidoId })">
                            Acompanhar pedido
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://sdk.mercadopago.com/js/v2"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"
            referrerpolicy="no-referrer"></script>

    <script>
        // Config repassada para o JS externo
        window.CHECKOUT_CONFIG = {
          paymentId: @Model.Id,
          statusUrl: '@Url.Action("Status", "Pagamento")?id=@Model.Id',
          initialStatus: '@Model.Status',
          mpPublicKey: '@(ViewBag.MP_PublicKey ?? "")',
          antiForgery: '@afToken',
          // URLs auxiliares
          confirmCardUrl: '@Url.Action("ConfirmCard", "Pagamento", new { id = Model.Id })',
          cancelUrl: '@Url.Action("Cancelar", "Pagamento", new { id = Model.Id })',
          cartUrl: '@Url.Action("Index", "Carrinho")',
          // opcional: string do amount (para o Brick)
          amountStr: '@Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)'
        };
    </script>

    <script src="~/js/checkout.js" asp-append-version="true"></script>
}

