@using WebApplicationPods.Enum
@model WebApplicationPods.Models.PaymentModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Pagamento";
    // Gera token anti-CSRF e grava cookie; usamos o valor no header do fetch.
    var afToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

@section Styles {
    <style>
        /* Botões ocupam largura total no mobile */
        @@media (max-width: 576px) {
            .btn {
                width: 100%;
            }

            .input-group .btn {
                width: auto;
            }
            /* mantém o 'Copiar' encaixado */
        }

        /* Evita clipes dentro do card */
        .card-body {
            overflow: visible;
        }

        .qr-box {
            width: 220px;
            height: 220px;
            border-radius: 10px;
            border: 1px solid #eee;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
        }

        .text-muted small.code {
            word-break: break-all;
            white-space: pre-wrap;
        }

        .copy-badge {
            display: inline-flex;
            align-items: center;
            font-size: .875rem;
            color: #198754; /* text-success */
            background: #e9f7ef; /* verdinho claro */
            border: 1px solid #cfe9da; /* contorno suave */
            border-radius: .35rem;
            padding: .15rem .45rem;
            transition: opacity .2s ease, transform .2s ease;
            opacity: 0;
            transform: translateY(-2px);
        }

            .copy-badge.show {
                opacity: 1;
                transform: translateY(0);
            }

        .d-none {
            display: none !important;
        }
    </style>
}

<div class="container-xxl py-4">
    <div class="row g-4">

        <!-- COL ESQUERDA -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Finalize seu pagamento</h5>
                </div>
                <div class="card-body">

                    @* ===================== PIX ===================== *@
                    @if (Model.Metodo == PaymentMethod.Pix)
                    {
                        <h6 class="mb-2">Pix</h6>
                        <p class="text-muted">Escaneie o QR Code ou use “copia e cola”. Confirmaremos automaticamente após o pagamento.</p>

                        <div class="d-flex gap-3 flex-wrap align-items-start">
                            <div>
                                @if (!string.IsNullOrEmpty(Model.PixQrBase64Png))
                                {
                                    <img src="data:image/png;base64,@Model.PixQrBase64Png" alt="QR Code Pix"
                                         class="qr-box" style="object-fit: contain;" />
                                }
                                else
                                {
                                    <div id="pix-qr" class="qr-box text-secondary">
                                        QR Code
                                    </div>
                                }
                            </div>

                            <div class="flex-grow-1">
                                <label class="form-label">Copia e cola</label>
                                <div class="input-group">
                                    <input class="form-control" value="@Model.PixQrData" id="pixCopyPaste" readonly />
                                    <button class="btn btn-secondary" type="button" onclick="copyPix()" id="btnCopyPix">Copiar</button>
                                    <span id="copyBadge" class="copy-badge d-none ms-2">Copiado!</span>
                                </div>

                                <div class="d-flex align-items-center gap-2 mt-3 flex-wrap">
                                    <span id="pixStatus" class="badge bg-light text-dark">Status: @Model.Status</span>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" id="btnForcarConsulta">Atualizar status</button>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" id="pix-cancel-btn">Cancelar</button>
                                </div>

                                <div class="text-muted mt-2">Valor: <strong>@Model.Amount.ToString("C")</strong></div>
                                <div class="text-muted mt-2 small">Pedido: #@Model.PedidoId</div>
                            </div>
                        </div>
                    }

                    @* ===================== CARTÃO ===================== *@
                    @if (Model.Metodo == PaymentMethod.CardCredit || Model.Metodo == PaymentMethod.CardDebit)
                    {
                        <div id="cardPaymentBrick_container"></div>

                        @* Mantemos somente o CANCELAR da página (o Brick já tem o botão Pagar) *@
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <button id="mp-cancel-btn" type="button" class="btn btn-outline-secondary flex-grow-1 flex-sm-grow-0">
                                Cancelar
                            </button>
                        </div>

                        <div class="text-muted mt-2">Se necessário, faremos a autenticação 3-D Secure.</div>
                        <span id="payStatus" class="badge bg-light text-dark mt-3 d-inline-block">Status: @Model.Status</span>
                    }

                    @* ================= DINHEIRO/MAQUININHA ================ *@
                    @if (Model.Metodo == PaymentMethod.Cash)
                    {
                        <p class="mb-0">Pagamento na entrega. Status: <strong>@Model.Status</strong></p>
                    }
                </div>
            </div>
        </div>

        <!-- COL DIREITA -->
        <div class="col-lg-5">
            <div class="card sticky-lg-top" style="top:-27px;">
                <div class="card-header">
                    <h5 class="mb-0">Resumo</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <span>Total</span><strong>@Model.Amount.ToString("C")</strong>
                    </div>
                    <div class="mt-3 small text-muted">Pedido: #@Model.PedidoId</div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://sdk.mercadopago.com/js/v2"></script>
    <!-- QRCode.js (frontend, sem servidor) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" referrerpolicy="no-referrer"></script>

    <script>
        // Copiar PIX + mostrar badge "Copiado!"
        async function copyPix() {
          const input = document.getElementById('pixCopyPaste');
          const btn   = document.getElementById('btnCopyPix');
          const badge = document.getElementById('copyBadge');
          if (!input) return;

          // tenta Clipboard API
          let ok = false;
          try {
            await navigator.clipboard.writeText(input.value);
            ok = true;
          } catch {
            try {
              input.select(); input.setSelectionRange(0, 99999);
              document.execCommand('copy'); // fallback
              ok = true;
            } catch {}
          }

          if (ok && badge) {
            // mostra badge por 2s
            badge.classList.remove('d-none');
            void badge.offsetWidth; // força reflow p/ animar
            badge.classList.add('show');

            const old = btn ? btn.textContent : '';
            if (btn) btn.textContent = 'Copiado!';

            setTimeout(() => {
              badge.classList.remove('show');
              setTimeout(() => {
                badge.classList.add('d-none');
                if (btn) btn.textContent = old || 'Copiar';
              }, 200);
            }, 2000);
          }
        }
    </script>

    <script>
        // ------- Polling de Status -------
        (function polling(){
          const paymentId = '@Model.Id';
          const statusUrl = '@Url.Action("Status", "Pagamento")' + '?id=' + encodeURIComponent(paymentId);

          async function checkPaid(){
            try{
              const r = await fetch(statusUrl, { cache: 'no-store' });
              if (!r.ok) return;
              const data = await r.json();

              const pixBadge = document.getElementById('pixStatus');
              if (pixBadge && data.status) pixBadge.textContent = 'Status: ' + data.status;

              const payBadge = document.getElementById('payStatus');
              if (payBadge && data.status) payBadge.textContent = 'Status: ' + data.status;

              if (data.paid === true && data.redirect) {
                window.location.href = data.redirect;
              }
            } catch(e) { /* silencia erros de polling */ }
          }

          const btn = document.getElementById('btnForcarConsulta');
          if (btn && !btn.dataset.bound){
            btn.dataset.bound = '1';
            btn.addEventListener('click', checkPaid);
          }

          checkPaid();
          setInterval(checkPaid, 3000);
          window.__checkPaid = checkPaid;
        })();
    </script>

    <script>
        // ------- Monta QR no frontend (somente se não veio Base64) -------
        (function mountQrIfNeeded(){
          // Só tenta montar se existe container e temos BR Code no input
          const el = document.getElementById('pix-qr');
          const copyInput = document.getElementById('pixCopyPaste');
          if (!el || !copyInput) return;

          const brcode = copyInput.value || '';
          if (!brcode) return;

          try {
            el.textContent = '';
            new QRCode(el, {
              text: brcode,
              width: 220,
              height: 220
            });
          } catch (e) { console.warn('QR fallback falhou', e); }
        })();
    </script>

    <script>
        // ------- Brick de Cartão (Mercado Pago) -------
        (function initMPBrick(){
          const publicKey = '@(ViewBag.MP_PublicKey ?? "")'.trim();
          if (!publicKey || (publicKey.indexOf('TEST-') !== 0 && publicKey.indexOf('APP_USR-') !== 0)) {
            console.error('Mercado Pago PublicKey inválida/ausente:', publicKey);
            return;
          }

          if (window.__mpBrickMounted) return;
          window.__mpBrickMounted = true;

          const mp = new MercadoPago(publicKey, { locale: 'pt-BR' });
          const bricks = mp.bricks();

          const hasCardContainer = document.getElementById('cardPaymentBrick_container');
          if (!hasCardContainer) return;

          const amount = Number('@Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)');

          bricks.create('cardPayment', 'cardPaymentBrick_container', {
            initialization: { amount },
            customization: {
              paymentMethods: { creditCard: 'all', debitCard: 'all' },
              visual: { style: { theme: 'default' } }
            },
            callbacks: {
              onReady: () => { /* o Brick já exibe o botão Pagar */ },
              onSubmit: async (cardFormData) => {
                try {
                  const res = await fetch('@Url.Action("ConfirmCard", "Pagamento", new { id = Model.Id })', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'RequestVerificationToken': '@afToken'
                    },
                    body: JSON.stringify(cardFormData)
                  });

                  const json = await res.json();
                  const statusEl = document.getElementById('payStatus');

                  if (json && json.success) {
                    if (statusEl) statusEl.textContent = 'Status: Pago';
                    if (json.redirect) window.location.href = json.redirect;
                    else if (window.__checkPaid) window.__checkPaid();
                  } else {
                    if (statusEl) statusEl.textContent = 'Status: Pagamento falhou';
                    alert('Não foi possível processar o pagamento.');
                  }
                } catch (e) {
                  console.error('ConfirmCard error', e);
                  alert('Erro ao confirmar o pagamento.');
                }
              },
              onError: (error) => {
                console.error('Brick error:', error);
                alert('Erro ao carregar/validar os campos do cartão.');
              }
            }
          });
        })();
    </script>

    <script>
        // ------ Cancelar (comum ao cartão e ao pix) ------
        (function bindCancel(){
          const cancelBtns = [
            document.getElementById('mp-cancel-btn'),
            document.getElementById('pix-cancel-btn')
          ].filter(Boolean);

          cancelBtns.forEach(btn => {
            if (btn.dataset.bound) return;
            btn.dataset.bound = '1';
            btn.addEventListener('click', async () => {
              try {
                const r = await fetch('@Url.Action("Cancelar", "Pagamento", new { id = Model.Id })', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': '@afToken' }
                });
                const data = await r.json().catch(() => ({}));
                if (data && data.redirect) window.location.href = data.redirect;
                else window.location.href = '@Url.Action("Index", "Carrinho")';
              } catch {
                window.location.href = '@Url.Action("Index", "Carrinho")';
              }
            });
          });
        })();
    </script>
}
