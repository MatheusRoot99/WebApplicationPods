@using WebApplicationPods.Enum
@model PaymentModel
@{
    ViewData["Title"] = "Pagamento";
}

<div class="container-xxl py-4">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header text-white d-flex align-items-center gap-2">
                    <i class="bi bi-shield-lock"></i>
                    <h5 class="mb-0">Finalize seu pagamento</h5>
                </div>
                <div class="card-body">
                    @if (Model.Metodo == PaymentMethod.Pix)
                    {
                        <h6 class="mb-3">Pix</h6>
                        <div class="d-flex gap-3 flex-wrap align-items-center">
                            <div>
                                @if (!string.IsNullOrEmpty(Model.PixQrBase64Png))
                                {
                                    <img src="data:image/png;base64,@Model.PixQrBase64Png" alt="QR Code Pix" style="width:220px;height:220px;border-radius:8px;border:1px solid #eee;" />
                                }
                                else
                                {
                                    <div class="border rounded p-3 bg-light">QR Code será exibido aqui.</div>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <label class="form-label">Copia e cola</label>
                                <div class="input-group">
                                    <input class="form-control" value="@Model.PixQrData" id="pixCopyPaste" readonly />
                                    <button class="btn btn-dark" type="button" onclick="copyPix()">Copiar</button>
                                </div>
                                <div class="form-text mt-2">Após o pagamento, confirmaremos automaticamente.</div>
                            </div>
                        </div>
                    }
                    else if (Model.Metodo == PaymentMethod.CardCredit || Model.Metodo == PaymentMethod.CardDebit)
                    {
                        <h6 class="mb-3">Cartão @(Model.Metodo == PaymentMethod.CardCredit ? "de Crédito" : "de Débito")</h6>
                        <div id="card-hosted-form">
                            @* Aqui entra o JS do provedor (Hosted Fields/Elements) *@
                            <div class="row g-3">
                                <div class="col-12">
                                    <div id="card-number" class="form-control"></div>
                                </div>
                                <div class="col-6">
                                    <div id="card-exp" class="form-control"></div>
                                </div>
                                <div class="col-6">
                                    <div id="card-cvv" class="form-control"></div>
                                </div>
                            </div>
                            <button class="btn btn-success mt-3" onclick="confirmCard(@Model.Id)">Pagar</button>
                            <div class="form-text mt-2">Se necessário, faremos a autenticação 3-D Secure.</div>
                        </div>
                    }
                    else
                    {
                        <p>Pagamento na entrega. Status: @Model.Status</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Resumo</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <span>Total</span><strong>@Model.Amount.ToString("C")</strong>
                    </div>
                    <div id="payStatus" class="mt-3 badge-soft">Status: @Model.Status</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyPix(){
          const i = document.getElementById('pixCopyPaste');
          i.select(); i.setSelectionRange(0, 99999);
          navigator.clipboard.writeText(i.value);
        }

        // Exemplo: confirmar cartão (após Hosted Fields gerar um token/nonce/intent)
        async function confirmCard(paymentId){
          // TODO: pegar token/nonce do JS do provedor:
          const clientPayload = { token: "TOKEN_DO_PROVEDOR" }; // substitua

          const res = await fetch(`/Pagamento/ConfirmCard/${paymentId}`, {
            method:'POST',
            headers:{ 'Content-Type':'application/json' },
            body: JSON.stringify(clientPayload)
          });
          const json = await res.json();
          if(json.success){
            document.getElementById('payStatus').textContent = 'Status: Pago';
            // redirecione para página de confirmação do pedido se quiser
            // window.location.href = '/Carrinho/Confirmacao?id=...';
          }else{
            document.getElementById('payStatus').textContent = 'Status: Pagamento falhou';
            alert('Não foi possível processar o pagamento.');
          }
        }

        // Polling simples para PIX (até o webhook atualizar pode levar alguns segundos)
        // Você pode criar uma action para consultar o status por providerPaymentId e atualizar.
    </script>
}
