@using System.Globalization
@using WebApplicationPods.Enum
@model WebApplicationPods.Models.PaymentModel
@{
    ViewData["Title"] = "Pagamento";
}

@section Styles {
    <style>
        :root {
            --brand: #FF8C00;
            --brand-600: #e67600;
            --dark: #222;
            --bg: #f5f5f7;
        }

        body {
            background: var(--bg);
        }

        .card {
            border-radius: 12px;
            border: 1px solid #eaeaea;
            box-shadow: 0 10px 25px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .card-header {
            background: var(--brand);
            color: #fff;
            font-weight: 700;
        }

            .card-header.bg-dark {
                background: #222;
            }

        .btn-success {
            background: var(--brand);
            border-color: var(--brand);
        }

            .btn-success:hover {
                background: var(--brand-600);
                border-color: var(--brand-600);
            }

        .btn-dark {
            background: var(--dark);
            border-color: var(--dark);
        }

        .badge-soft {
            background: #fff4e6;
            color: #c45f00;
            border-radius: 999px;
            padding: .25rem .6rem;
            font-weight: 600;
        }

        .qr-placeholder {
            width: 220px;
            height: 220px;
            border-radius: 10px;
            border: 1px dashed #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
        }

        .muted {
            color: #6f6f6f;
        }

        .hint {
            font-size: .9rem;
            color: #6f6f6f;
        }
    </style>
}

<div class="container-xxl py-4">
    <div class="row g-4">

        <!-- COL ESQUERDA -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-shield-lock"></i>
                    <h5 class="mb-0">Finalize seu pagamento</h5>
                </div>
                <div class="card-body">

                    @* ===================== PIX ===================== *@
                    @if (Model.Metodo == PaymentMethod.Pix)
                    {
                        <h6 class="mb-2">Pix</h6>
                        <p class="muted">Escaneie o QR Code ou use “copia e cola”. Confirmaremos automaticamente após o pagamento.</p>

                        <div class="d-flex gap-3 flex-wrap align-items-start">
                            <div>
                                @if (!string.IsNullOrEmpty(Model.PixQrBase64Png))
                                {
                                    <img src="data:image/png;base64,@Model.PixQrBase64Png"
                                         alt="QR Code Pix"
                                         style="width:220px;height:220px;border-radius:10px;border:1px solid #eee;" />
                                }
                                else
                                {
                                    <div id="pixQr" class="qr-placeholder">QR Code</div>
                                }
                            </div>

                            <div class="flex-grow-1">
                                <label class="form-label">Copia e cola</label>
                                <div class="input-group">
                                    <input class="form-control" value="@Model.PixQrData" id="pixCopyPaste" readonly />
                                    <button class="btn btn-dark" type="button" onclick="copyPix()">Copiar</button>
                                </div>

                                <div class="d-flex align-items-center gap-2 mt-3">
                                    <div id="pixStatus" class="badge-soft">Status: @Model.Status</div>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" id="btnForcarConsulta">Atualizar status</button>
                                </div>

                                <div class="hint mt-2">Valor: <strong>@Model.Amount.ToString("C")</strong></div>
                            </div>
                        </div>
                    }

                    @* ===================== CARTÃO ===================== *@
                    @if (Model.Metodo == PaymentMethod.CardCredit || Model.Metodo == PaymentMethod.CardDebit)
                    {
                        <h6 class="mb-3">Cartão @(Model.Metodo == PaymentMethod.CardCredit ? "de Crédito" : "de Débito")</h6>

                        <!-- Container exigido pelo Bricks -->
                        <div id="cardPaymentBrick_container"></div>

                        <div class="mt-3 d-flex gap-2">
                            <button id="mp-pay-btn" class="btn btn-success" disabled>Pagar</button>
                            <button id="mp-cancel-btn" type="button" class="btn btn-outline-secondary">Cancelar</button>
                        </div>

                        <div class="hint mt-2">Se necessário, faremos a autenticação 3-D Secure.</div>
                        <div id="payStatus" class="badge-soft mt-3">Status: @Model.Status</div>
                    }

                    @* ================= DINHEIRO/MAQUININHA ================ *@
                    @if (Model.Metodo == PaymentMethod.Cash)
                    {
                        <p class="mb-0">Pagamento na entrega. Status: <strong>@Model.Status</strong></p>
                    }
                </div>
            </div>
        </div>

        <!-- COL DIREITA -->
        <div class="col-lg-5">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Resumo</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <span>Total</span><strong>@Model.Amount.ToString("C")</strong>
                    </div>
                    <div class="mt-3 small muted">Pedido: #@Model.PedidoId • Pagamento: #@Model.Id</div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <!-- SDK Mercado Pago v2 (deve vir antes do init) -->
    <script src="https://sdk.mercadopago.com/js/v2"></script>

    <script>
        (function initMPBrick(){
          const publicKey = '@(ViewBag.MP_PublicKey ?? "")'.trim();
          if (!publicKey || publicKey.indexOf('TEST-') !== 0 && publicKey.indexOf('APP_USR-') !== 0) {
            console.error('Mercado Pago PublicKey inválida/ausente:', publicKey);
            return;
          }

          // Evita criar duas vezes (ex.: hot reload / partial duplicado)
          if (window.__mpBrickMounted) return;
          window.__mpBrickMounted = true;

          const mp = new MercadoPago(publicKey, { locale: 'pt-BR' });
          const bricks = mp.bricks();

          // Somente monta o brick se o método for cartão
          const hasCardContainer = document.getElementById('cardPaymentBrick_container');
          if (hasCardContainer) {
            const amount = Number('@Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)');

            bricks.create('cardPayment', 'cardPaymentBrick_container', {
              initialization: { amount },
              customization: {
                paymentMethods: { creditCard: 'all', debitCard: 'all' },
                visual: { style: { theme: 'default' } }
              },
              callbacks: {
                onReady: () => {
                  const b = document.getElementById('mp-pay-btn');
                  if (b) b.disabled = false;
                },
                onSubmit: async (cardFormData) => {
                  const btn = document.getElementById('mp-pay-btn');
                  try {
                    if (btn) btn.disabled = true;
                    const res = await fetch('/Pagamento/ConfirmCard/@Model.Id', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify(cardFormData)
                    });
                    const json = await res.json();
                    const statusEl = document.getElementById('payStatus');
                    if (json && json.success) {
                      if (statusEl) statusEl.textContent = 'Status: Pago';
                      // window.location.href = '/Carrinho/Confirmacao/@Model.PedidoId';
                    } else {
                      if (statusEl) statusEl.textContent = 'Status: Pagamento falhou';
                      alert('Não foi possível processar o pagamento.');
                    }
                  } catch (e) {
                    console.error('ConfirmCard error', e);
                    alert('Erro ao confirmar o pagamento.');
                  } finally {
                    if (btn) btn.disabled = false;
                  }
                },
                onError: (error) => {
                  console.error('Brick error:', error);
                  alert('Erro ao carregar/validar os campos do cartão.');
                }
              }
            });
          }
        })();
    </script>
    <script>
        // Botão Voltar/Cancelar
        (function wireBackButton() {
          const btn = document.getElementById('mp-cancel-btn');
          if (!btn) return;

          // Evita duplo-bind em hot reload
          if (btn.dataset.bound === "1") return;
          btn.dataset.bound = "1";

          btn.addEventListener('click', function (e) {
            e.preventDefault();

            try {
              const ref = document.referrer;
              // se veio de alguma página do mesmo host, usa o histórico
              if (ref && new URL(ref).host === location.host) {
                history.back();
                return;
              }
            } catch { /* ignora e usa fallback */ }

            // fallback: vai para o resumo do carrinho
            window.location.href = '@Url.Action("Resumo", "Carrinho")';
          });
        })();
    </script>
}

