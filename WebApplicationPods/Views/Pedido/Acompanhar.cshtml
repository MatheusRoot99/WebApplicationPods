@using WebApplicationPods.Models
@model PedidoModel
@{
    ViewData["Title"] = "Acompanhar pedido";

    var ultimos = ViewBag.Ultimos as IEnumerable<PedidoModel> ?? Enumerable.Empty<PedidoModel>();

    string statusAtual = Model?.Status ?? "";
    string[] finais = new[] { "Cancelado", "Pagamento Falhou", "Entregue", "Concluído" };
    bool temPedidoAtual = Model != null && !finais.Any(f => statusAtual.Contains(f, StringComparison.OrdinalIgnoreCase));

    var subtotal = Model?.PedidoItens?.Sum(i => i.PrecoUnitario * i.Quantidade) ?? 0m;
    var total = subtotal + (Model?.TaxaEntrega ?? 0m);
}


@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/acompanharPedido.css" asp-append-version="true" />
}

<div class="wrap">
    <div class="page-head">
        <div>
            <h2>Meus pedidos</h2>
            @if (Model != null)
            {
                <div class="subtle">• realizado em @Model.DataPedido.ToString("dd/MM/yyyy HH:mm")</div>
            }
        </div>
        <a asp-controller="Home" asp-action="Index" class="btnx"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>

    <div class="seg-tabs" id="tabs">
        @if (temPedidoAtual)
        {
            <div class="seg @(temPedidoAtual ? "active" : "")" data-tab="track"><i class="bi bi-truck"></i> Acompanhar</div>
        }
        <div class="seg @(!temPedidoAtual ? "active" : "")" data-tab="history"><i class="bi bi-clock-history"></i> Histórico</div>
    </div>

    <!-- ACOMPANHAR -->
    <div class="tab @(temPedidoAtual ? "active" : "")" id="tab-track">
        @if (temPedidoAtual)
        {
            <div class="grid-2">
                <!-- Andamento + Itens -->
                <div class="cardx">
                    <div class="cardx-h">
                        <div class="d-flex align-items-center">
                            <span>Andamento do pedido</span>
                        </div>
                    </div>


                    <div class="cardx-b">
                        <!-- Timeline vertical (grid, sem sobreposição) -->
                        <div class="vtrack" id="vtrack"
                             data-start="@Model.DataPedido.ToString("o")"
                             data-is-delivery="@((Model.EnderecoId.HasValue && Model.EnderecoId.Value > 0).ToString().ToLower())">

                            <div class="vstep" data-step="0">
                                <div class="vbullet"><i class="bi bi-ui-checks"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Pendente</div>
                                    <div class="vdesc">Pedido recebido</div>
                                    <time class="vtime">@Model.DataPedido.ToString("HH:mm")</time>
                                </div>
                            </div>

                            <div class="vstep" data-step="1">
                                <div class="vbullet"><i class="bi bi-cash-coin"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Pagamento</div>
                                    <div class="vdesc">Aguardando confirmação</div>
                                    <time class="vtime">—</time>
                                </div>
                            </div>

                            <div class="vstep" data-step="2">
                                <div class="vbullet"><i class="bi bi-check2-circle"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Pago</div>
                                    <div class="vdesc">Pagamento aprovado</div>
                                    <time class="vtime">—</time>
                                </div>
                            </div>

                            <div class="vstep" data-step="3">
                                <div class="vbullet"><i class="bi bi-gear-wide-connected"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Preparando</div>
                                    <div class="vdesc">Em produção</div>
                                    <time class="vtime">—</time>
                                </div>
                            </div>

                            <div class="vstep" data-step="4">
                                <div class="vbullet"><i class="bi bi-truck"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Em rota</div>
                                    <div class="vdesc">@((Model.EnderecoId > 0) ? "A caminho" : "Pronto para retirada")</div>
                                    <time class="vtime">—</time>
                                </div>
                            </div>

                            <div class="vstep" data-step="5">
                                <div class="vbullet"><i class="bi bi-bag-check"></i></div>
                                <div class="vbody">
                                    <div class="vtitle">Concluído</div>
                                    <div class="vdesc">Entregue</div>
                                    <time class="vtime">—</time>
                                </div>
                            </div>
                        </div>

                        <div class="actions">
                             @*<button type="button" id="btnRefresh" class="btnx">
                                <i class="bi bi-arrow-clockwise"></i> Atualizar agora
                             </button>*@
                            <a asp-controller="Pedido" asp-action="Acompanhar"
                               asp-route-id="@Model.Id" asp-route-t="@Model.RastreioToken"
                               class="btnx btn-brand">
                                <i class="bi bi-shuffle"></i> Recarregar
                            </a>
                        </div>

                        <!-- Itens -->
                        <div class="mt-3">
                            @if (Model.PedidoItens != null)
                            {
                                @foreach (var it in Model.PedidoItens)
                                {
                                    var nome = it?.Produto?.Nome ?? $"Produto #{it?.ProdutoId}";
                                    var img = it?.Produto?.ImagemUrl ?? "https://via.placeholder.com/80x80?text=Produto";
                                    var sabor = it?.Observacoes;
                                    <div class="it">
                                        <img class="it-img" src="@img" alt="@nome" />
                                        <div>
                                            <div class="it-name">@nome x @(it?.Quantidade ?? 0)</div>
                                            @if (!string.IsNullOrWhiteSpace(sabor))
                                            {
                                                <div class="it-sabor">Obs: @sabor</div>
                                            }
                                        </div>
                                        <div class="it-price">@(((it?.PrecoUnitario ?? 0m) * (it?.Quantidade ?? 0)).ToString("C"))</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Resumo -->
                <div class="cardx">
                    <div class="cardx-h">Resumo</div>
                    <div class="cardx-b">
                        <div class="tot-row"><span>Subtotal</span><strong>@subtotal.ToString("C")</strong></div>
                        <div class="tot-row"><span>Taxa de entrega</span><strong>@(Model?.TaxaEntrega.ToString("C") ?? "R$ 0,00")</strong></div>
                        <div class="tot-row total"><span>Total</span><strong id="totalLabel">@total.ToString("C")</strong></div>
                        <div class="subtle mt-2">
                            <div><i class="bi bi-cash-coin"></i> Pagamento: @(Model?.MetodoPagamento ?? "N/A")</div>
                            @if (Model?.EnderecoId > 0 && Model?.Endereco != null)
                            {
                                <div class="mt-1"><i class="bi bi-geo-alt"></i> Entrega: @Model.Endereco.Logradouro, @Model.Endereco.Numero - @Model.Endereco.Bairro</div>
                            }
                            else
                            {
                                <div class="mt-1"><i class="bi bi-bag"></i> Retirada no local</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="cardx">
                <div class="cardx-h">Sem pedido em andamento</div>
                <div class="cardx-b">
                    <div class="subtle">Assim que você fizer uma compra, o acompanhamento aparece aqui 👇</div>
                </div>
            </div>
        }
    </div>

    <!-- HISTÓRICO -->
    <div class="tab @(!temPedidoAtual ? "active" : "")" id="tab-history">
        <div class="cardx">
            <div class="cardx-h">Histórico</div>
            <div class="cardx-b">
                @if (ultimos.Any())
                {
                    <div class="orders">
                        @foreach (var p in ultimos.OrderByDescending(x => x.DataPedido).Take(10))
                        {
                            var st = (p.Status ?? "").ToLowerInvariant();
                            var badgeClass = st.Contains("cancel") ? "err"
                            : (st.Contains("entreg") || st.Contains("concl")) ? "ok"
                            : (st.Contains("pago") || st.Contains("prepar") || st.Contains("rota")) ? "warn"
                            : "";

                            var firstItem = p.PedidoItens?.FirstOrDefault();
                            var img = firstItem?.Produto?.ImagemUrl ?? "https://via.placeholder.com/64x64?text=%20";
                            var title = firstItem?.Produto?.Nome ?? "Pedido";
                            var totalUnidades = p.PedidoItens?.Sum(i => i.Quantidade) ?? 0;
                            var extras = totalUnidades > 1 ? $"+ {totalUnidades - 1} itens" : $"{totalUnidades} un";

                            <div class="order-card">
                                <img class="order-thumb" src="@img" alt="@title" />
                                <div class="order-info">
                                    <div class="order-title">@title <span class="text-muted">(@extras)</span></div>
                                    <div class="order-extras">
                                        <span class="badge-soft @badgeClass">@p.Status</span>
                                        <span><i class="bi bi-clock"></i> @p.DataPedido.ToString("dd/MM HH:mm")</span>
                                    </div>
                                </div>
                                <div class="order-right">
                                    <div class="order-total">@(p.ValorTotal.ToString("C") ?? "R$ 0,00")</div>
                                    <a class="btnx btn-brand btn-compact"
                                       asp-controller="Pedido" asp-action="ResumoPedidoCliente"
                                       asp-route-id="@p.Id" asp-route-t="@p.RastreioToken">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="subtle">Você ainda não possui pedidos no histórico.</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Elemento oculto com dados para o tracker -->
<div id="trackData"
     data-status-url="@ViewBag.StatusUrl"
     data-initial-status="@Model?.Status"
     style="display: none;">
</div>

@section Scripts {
    <script src="~/js/pedido-tracker.js" asp-append-version="true" defer></script>
    <script src="~/js/page-acompanhar.js" asp-append-version="true" defer></script>
}