@model WebApplicationPods.Models.CarrinhoPageViewModel
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ptBR = CultureInfo.GetCultureInfo("pt-BR");
    ViewData["Title"] = "Seu carrinho";
}

@section Styles {
    <link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="carrinho-container">
    <div id="carrinho-alerts">
        @if (TempData["Sucesso"] is string ok && !string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-1"></i>@ok
            </div>
        }

        @if (TempData["Erro"] is string err && !string.IsNullOrWhiteSpace(err))
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-1"></i>@err
            </div>
        }
    </div>

    <h2 class="carrinho-title">@ViewData["Title"]</h2>

    @if (Model?.Carrinho?.Itens?.Any() == true)
    {
        <div class="cart-grid">
            <div>
                <div class="table-responsive">
                    <table class="carrinho-table">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th style="width:260px;">Quantidade</th>
                                <th>Preço</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Carrinho.Itens)
                            {
                                item.Produto?.DeserializarSaboresQuantidades();
                                var chaveSabor = item.Sabor ?? string.Empty;

                                int maxPermitido;
                                if (!string.IsNullOrWhiteSpace(chaveSabor) &&
                                item.Produto?.SaboresQuantidadesList?.Any() == true)
                                {
                                    var sq = item.Produto.SaboresQuantidadesList
                                    .FirstOrDefault(s => string.Equals(s.Sabor, chaveSabor, StringComparison.OrdinalIgnoreCase));
                                    maxPermitido = sq?.Quantidade ?? item.Produto!.Estoque;
                                }
                                else
                                {
                                    maxPermitido = item.Produto?.Estoque ?? 1;
                                }

                                if (maxPermitido < 1) maxPermitido = 1;

                                var temPromo = item.Produto?.EstaEmPromocao() == true;
                                var precoNormal = item.Produto?.Preco ?? 0m;
                                var precoFinal = temPromo
                                ? (item.Produto?.PrecoPromocional ?? precoNormal)
                                : precoNormal;

                                bool puffOk = item.Produto?.PodPuffs > 0;
                                bool batOk = int.TryParse(item.Produto?.PodCapacidadeBateria, out var bat) && bat > 0;
                                bool temSpecsPod = puffOk || batOk;

                                bool volumeOk = item.Produto?.BebidaVolumeMl.HasValue == true &&
                                item.Produto.BebidaVolumeMl.Value > 0;

                                bool teorOk = false;
                                string teorTxt = "";
                                if (item.Produto?.BebidaTeorAlcoolico.HasValue == true &&
                                item.Produto.BebidaTeorAlcoolico.Value > 0)
                                {
                                    teorOk = true;
                                    teorTxt = item.Produto.BebidaTeorAlcoolico.Value.ToString("0.##") + "%";
                                }

                                bool embalagemOk = item.Produto?.BebidaEmbalagem.HasValue == true &&
                                item.Produto.BebidaEmbalagem.Value != WebApplicationPods.Enum.BebidaEmbalagemTipo.NaoInformado;

                                bool qtdEmbOk = item.Produto?.BebidaQtdPorEmbalagem.HasValue == true &&
                                item.Produto.BebidaQtdPorEmbalagem.Value > 0;

                                string embalagemTxt = "";
                                if (embalagemOk)
                                {
                                    embalagemTxt = item.Produto!.BebidaEmbalagem!.Value switch
                                    {
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Unidade => "Unidade",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Lata => "Lata",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.LongNeck => "Long Neck",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Garrafa => "Garrafa",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Fardo => "Fardo",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Caixa => "Caixa",
                                        WebApplicationPods.Enum.BebidaEmbalagemTipo.Pack => "Pack",
                                        _ => ""
                                    };
                                }

                                string embalagemResumo = "";
                                if (embalagemOk)
                                {
                                    var emb = item.Produto!.BebidaEmbalagem!.Value;
                                    bool embMultipla =
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Fardo ||
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Caixa ||
                                    emb == WebApplicationPods.Enum.BebidaEmbalagemTipo.Pack;

                                    if (embMultipla && qtdEmbOk)
                                        embalagemResumo = $"{embalagemTxt} {item.Produto.BebidaQtdPorEmbalagem}un";
                                    else
                                        embalagemResumo = embalagemTxt;
                                }

                                bool temSpecsBebida = volumeOk || teorOk || !string.IsNullOrWhiteSpace(embalagemResumo);
                                bool pareceBebida = temSpecsBebida || !string.IsNullOrWhiteSpace(item.Produto?.BebidaTipo);

                                var partesDescricao = new List<string>();

                                if (temSpecsPod)
                                {
                                    if (puffOk)
                                        partesDescricao.Add($"{item.Produto!.PodPuffs} puffs");

                                    if (batOk)
                                        partesDescricao.Add($"{bat} mAh");
                                }
                                else if (pareceBebida)
                                {
                                    if (volumeOk)
                                        partesDescricao.Add($"{item.Produto!.BebidaVolumeMl} ml");

                                    if (teorOk)
                                        partesDescricao.Add(teorTxt);

                                    if (!string.IsNullOrWhiteSpace(embalagemResumo))
                                        partesDescricao.Add(embalagemResumo);
                                }

                                string descricaoResumo = partesDescricao.Any()
                                ? string.Join(" • ", partesDescricao)
                                : (!string.IsNullOrWhiteSpace(item.Produto?.Descricao)
                                ? item.Produto.Descricao
                                : "Produto selecionado");

                                <tr class="linha-item">
                                    <td data-label="Produto" class="cell-produto">
                                        <div class="produto-info">
                                            <img src="@(item.Produto?.ImagemUrl ?? "https://via.placeholder.com/120x120?text=%20")"
                                                 alt="@(item.Produto?.Nome ?? "Produto")"
                                                 class="produto-imagem" />

                                            <div class="produto-meta">
                                                <h5 class="produto-nome">@item.Produto?.Nome</h5>

                                                <div class="produto-descricao">
                                                    @descricaoResumo
                                                </div>

                                                @if (!string.IsNullOrEmpty(item.Observacoes))
                                                {
                                                    <div class="produto-observacoes">
                                                        <strong>Obs:</strong> @item.Observacoes
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </td>

                                    <td data-label="Quantidade" class="cell-quantidade">
                                        <form asp-action="AtualizarItem" method="post" class="quantidade-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="produtoId" value="@item.Produto!.Id" />
                                            <input type="hidden" name="sabor" value="@item.Sabor" />

                                            <div class="input-group">
                                                <button type="submit"
                                                        name="op"
                                                        value="dec"
                                                        class="btn btn-outline btn-outline-secondary qty-btn"
                                                        aria-label="Diminuir">
                                                    <i class="fas fa-minus"></i>
                                                </button>

                                                <input type="number"
                                                       name="quantidade"
                                                       value="@item.Quantidade"
                                                       min="1"
                                                       max="@maxPermitido"
                                                       class="form-control text-center quantidade-input"
                                                       inputmode="numeric" />

                                                <button type="submit"
                                                        name="op"
                                                        value="inc"
                                                        class="btn btn-outline btn-outline-secondary qty-btn"
                                                        aria-label="Aumentar">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                            </div>
                                        </form>
                                    </td>

                                    <td data-label="Preço" class="cell-preco preco-final">
                                        @precoFinal.ToString("C", ptBR)
                                    </td>

                                    <td data-label="Ações" class="cell-acoes">
                                        <form asp-action="RemoverItem" method="post" class="remove-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="produtoId" value="@item.Produto!.Id" />
                                            <input type="hidden" name="sabor" value="@item.Sabor" />

                                            <button type="submit"
                                                    class="btn btn-danger btn-remover-icon"
                                                    aria-label="Remover item">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <aside>
                <div id="resumo-card" class="total-card">
                    <div class="total-label">Total:</div>
                    <div class="total-valor">
                        @Model.Carrinho.Total.ToString("C", ptBR)
                    </div>

                    <div class="carrinho-actions">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline block-mobile">
                            ← Continuar comprando
                        </a>

                        <a asp-action="Resumo" class="btn btn-primary block-mobile">
                            Finalizar pedido →
                        </a>
                    </div>
                </div>
            </aside>
        </div>
    }
    else
    {
        <div id="empty-state" class="carrinho-vazio">
            <h4>Seu carrinho está vazio</h4>
            <p>Adicione produtos ao seu carrinho para continuar.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-store me-1"></i> Ver produtos
            </a>
        </div>

        <section id="populares-wrapper" class="populares">
            <h5 class="pop-title">Mais populares</h5>

            <div class="pop-grid">
                @foreach (var p in Model.Populares)
                {
                    <article class="pop-card">
                        <div class="pop-img">
                            <img src="@p.ImagemUrl" alt="@p.Nome" loading="lazy" />
                        </div>

                        <div class="pop-body">
                            <div class="pop-name">@p.Nome</div>

                            <div class="pop-price">
                                @if (p.EmPromocao)
                                {
                                    <span class="old">@p.Preco.ToString("C", ptBR)</span>
                                    <span class="now">@p.PrecoPromocional.Value.ToString("C", ptBR)</span>
                                }
                                else
                                {
                                    <span class="now">@p.Preco.ToString("C", ptBR)</span>
                                }
                            </div>

                            <form asp-action="AdicionarItem" method="post" class="pop-add-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="produtoId" value="@p.Id" />
                                <input type="hidden" name="quantidade" value="1" />
                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                    Adicionar
                                </button>
                            </form>
                        </div>

                        <a class="stretched-link"
                           asp-controller="Produto"
                           asp-action="DetalhesProdutos"
                           asp-route-id="@p.Id"
                           aria-label="Ver detalhes de @p.Nome"></a>
                    </article>
                }
            </div>

            <div class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline">
                    Ver cardápio
                </a>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script src="~/js/Carrinho-form.js" asp-append-version="true"></script>
}