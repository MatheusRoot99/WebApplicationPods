@model WebApplicationPods.Models.CarrinhoPageViewModel
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ptBR = CultureInfo.GetCultureInfo("pt-BR");
    ViewData["Title"] = "Seu carrinho";
}

@section Styles {
    <link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="carrinho-container">
    <!-- Alerts -->
    <div id="carrinho-alerts">
        @if (TempData["Sucesso"] is string ok && !string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-1"></i>@ok
            </div>
        }
        @if (TempData["Erro"] is string err && !string.IsNullOrWhiteSpace(err))
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-1"></i>@err
            </div>
        }
    </div>

    <h2 class="carrinho-title">@ViewData["Title"]</h2>

    @if (Model?.Carrinho?.Itens?.Any() == true)
    {
        <div class="cart-grid">
            <!-- LISTA DE ITENS -->
            <div>
                <div class="table-responsive">
                    <table class="carrinho-table">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th style="width:360px;"></th>
                                <th>Preço Normal</th>
                                <th>Preço com Desconto</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Carrinho.Itens)
                            {
                                item.Produto?.DeserializarSaboresQuantidades();
                                var chaveSabor = item.Sabor ?? string.Empty;

                                int maxPermitido;
                                if (!string.IsNullOrWhiteSpace(chaveSabor) &&
                                item.Produto?.SaboresQuantidadesList?.Any() == true)
                                {
                                    var sq = item.Produto.SaboresQuantidadesList
                                    .FirstOrDefault(s => string.Equals(s.Sabor, chaveSabor, StringComparison.OrdinalIgnoreCase));
                                    maxPermitido = sq?.Quantidade ?? item.Produto!.Estoque;
                                }
                                else
                                {
                                    maxPermitido = item.Produto?.Estoque ?? 1;
                                }
                                if (maxPermitido < 1) maxPermitido = 1;

                                // ===== PREÇOS (definidos UMA ÚNICA VEZ por item) =====
                                var temPromo = item.Produto?.EstaEmPromocao() == true;
                                var precoNormal = item.Produto?.Preco ?? 0m;
                                decimal? precoPromo = temPromo ? item.Produto!.PrecoPromocional : null;

                                <tr class="linha-item">
                                    <!-- PRODUTO -->
                                    <td data-label="Produto">
                                        <div class="produto-info">
                                            <img src="@(item.Produto?.ImagemUrl ?? "https://via.placeholder.com/120x120?text=%20")"
                                                 alt="@(item.Produto?.Nome ?? "Produto")"
                                                 class="produto-imagem" />
                                            <div>
                                                <h5 class="produto-nome">@item.Produto?.Nome</h5>

                                                @if (!string.IsNullOrEmpty(item.Sabor))
                                                {
                                                    <div class="produto-sabor">
                                                        <strong>Sabor:</strong> @item.Sabor
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(item.Observacoes))
                                                {
                                                    <div class="produto-observacoes">
                                                        <strong>Obs:</strong> @item.Observacoes
                                                    </div>
                                                }

                                                <div class="produto-estoque">
                                                    <small class="text-muted">
                                                        Estoque disponível: <strong>@maxPermitido</strong>
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- QUANTIDADE -->
                                    <td data-label="">
                                        <form asp-action="AtualizarItem" method="post" class="quantidade-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="produtoId" value="@item.Produto!.Id" />
                                            <input type="hidden" name="sabor" value="@item.Sabor" />

                                            <div class="input-group">
                                                <button type="submit" name="op" value="dec"
                                                        class="btn btn-outline btn-outline-secondary"
                                                        aria-label="Diminuir">
                                                    <i class="fas fa-minus"></i>
                                                </button>

                                                <input type="number"
                                                       name="quantidade"
                                                       value="@item.Quantidade"
                                                       min="1"
                                                       max="@maxPermitido"
                                                       class="form-control text-center quantidade-input"
                                                       inputmode="numeric" />

                                                <button type="submit" name="op" value="inc"
                                                        class="btn btn-outline btn-outline-secondary"
                                                        aria-label="Aumentar">
                                                    <i class="fas fa-plus"></i>
                                                </button>

                                                <button type="submit" class="btn btn-primary full-bleed">
                                                    Atualizar
                                                </button>
                                            </div>
                                        </form>
                                    </td>

                                    <!-- PREÇOS -->
                                    <td data-label="Preço Normal">@precoNormal.ToString("C", ptBR)</td>

                                    <td data-label="Preço com Desconto"
                                        data-has-discount="@(precoPromo.HasValue ? "true" : "false")">
                                        @(precoPromo.HasValue? precoPromo.Value.ToString("C", ptBR) : "")
                                    </td>

                                    <!-- AÇÕES -->
                                    <td data-label="Ações">
                                        <form asp-action="RemoverItem" method="post" class="remove-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="produtoId" value="@item.Produto!.Id" />
                                            <input type="hidden" name="sabor" value="@item.Sabor" />
                                            <button type="submit" class="btn btn-danger">
                                                <i class="fas fa-trash"></i> Remover
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- RESUMO -->
            <aside>
                <div id="resumo-card" class="total-card">
                    <div class="total-label">Total:</div>
                    <div class="total-valor">
                        @Model.Carrinho.Total.ToString("C", ptBR)
                    </div>

                    <div class="carrinho-actions">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline block-mobile">
                            ← Continuar comprando
                        </a>

                        <a asp-action="Resumo" class="btn btn-primary block-mobile">
                            Finalizar pedido →
                        </a>
                    </div>
                </div>
            </aside>
        </div>
    }
    else
    {
        <!-- ESTADO VAZIO + POPULARES -->
        <div id="empty-state" class="carrinho-vazio">
            <h4>Seu carrinho está vazio</h4>
            <p>Adicione produtos ao seu carrinho para continuar.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-store me-1"></i> Ver produtos
            </a>
        </div>

        <section id="populares-wrapper" class="populares">
            <h5 class="pop-title">Mais populares</h5>

            <div class="pop-grid">
                @foreach (var p in Model.Populares)
                {
                    <article class="pop-card">
                        <!-- Imagem sem <a>; o overlay abaixo cobre o card todo -->
                        <div class="pop-img">
                            <img src="@p.ImagemUrl" alt="@p.Nome" loading="lazy" />
                        </div>

                        <div class="pop-body">
                            <div class="pop-name">@p.Nome</div>

                            <div class="pop-price">
                                @if (p.EmPromocao)
                                {
                                    <span class="old">@p.Preco.ToString("C", ptBR)</span>
                                    <span class="now">@p.PrecoPromocional.Value.ToString("C", ptBR)</span>
                                }
                                else
                                {
                                    <span class="now">@p.Preco.ToString("C", ptBR)</span>
                                }
                            </div>

                            <form asp-action="AdicionarItem" method="post" class="pop-add-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="produtoId" value="@p.Id" />
                                <input type="hidden" name="quantidade" value="1" />
                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                    Adicionar
                                </button>
                            </form>
                        </div>

                        <!-- Link esticado: torna o card inteiro clicável (detalhes) -->
                        <a class="stretched-link"
                           asp-controller="Produto"
                           asp-action="DetalhesProdutos"
                           asp-route-id="@p.Id"
                           aria-label="Ver detalhes de @p.Nome"></a>
                    </article>
                }
            </div>

            <div class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline">
                    Ver cardápio
                </a>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script src="~/js/Carrinho-form.js" asp-append-version="true"></script>
    <script>
        setTimeout(() => {
            document.querySelectorAll('#carrinho-alerts .alert').forEach(a => {
                a.style.transition = 'opacity .5s';
                a.style.opacity = '0';
                setTimeout(() => a.remove(), 500);
            });
        }, 5000);
    </script>

    <script>
        (function () {
            const STORAGE_KEY = 'produtos_adicionados_carrinho';

            function getStorage() {
                try {
                    const data = localStorage.getItem(STORAGE_KEY);
                    if (!data) return [];
                    const parsed = JSON.parse(data);
                    return Array.isArray(parsed) ? parsed.map(String) : [];
                } catch {
                    return [];
                }
            }

            function saveStorage(ids) {
                localStorage.setItem(STORAGE_KEY, JSON.stringify([...new Set(ids.map(String))]));
            }

            function removeFromStorage(produtoId) {
                if (!produtoId) return;
                const ids = getStorage().filter(x => x !== String(produtoId));
                saveStorage(ids);
            }

            document.addEventListener('submit', function (e) {
                const form = e.target.closest('form.remove-form');
                if (!form) return;

                const produtoId = form.querySelector('input[name="produtoId"]')?.value;
                removeFromStorage(produtoId);
            });
        })();
    </script>
}
