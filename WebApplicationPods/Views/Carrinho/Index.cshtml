@model WebApplicationPods.Models.CarrinhoModel
@using System.Globalization
@using System.Linq

@{
    var ptBR = CultureInfo.GetCultureInfo("pt-BR");
}

@section Styles {
    <link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="carrinho-container">

    <div id="carrinho-alerts">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
            </div>
        }
    </div>

    <h2>Seu Carrinho de Compras</h2>

    @if (Model.Itens.Any())
    {
        <div class="table-responsive">
            <table class="carrinho-table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th style="width: 360px;">Quantidade</th>
                        <th>Preço Normal</th>
                        <th>Preço com Desconto</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        item.Produto.DeserializarSaboresQuantidades();

                        var chaveSabor = item.Sabor ?? string.Empty;
                        int maxPermitido;
                        if (!string.IsNullOrWhiteSpace(chaveSabor) &&
                        item.Produto.SaboresQuantidadesList?.Any() == true)
                        {
                            var sq = item.Produto.SaboresQuantidadesList
                            .FirstOrDefault(s => string.Equals(s.Sabor, chaveSabor, StringComparison.OrdinalIgnoreCase));
                            maxPermitido = sq?.Quantidade ?? item.Produto.Estoque;
                        }
                        else
                        {
                            maxPermitido = item.Produto.Estoque;
                        }
                        if (maxPermitido < 1) maxPermitido = 1;

                        var temPromo = item.Produto.EstaEmPromocao();
                        var precoNormal = item.Produto.Preco;
                        decimal? precoPromo = temPromo ? item.Produto.PrecoPromocional : null;
                        <tr class="linha-item">
                            <td>
                                <div class="produto-info">
                                    <img src="@item.Produto.ImagemUrl" alt="@item.Produto.Nome" class="produto-imagem" />
                                    <div>
                                        <h5 class="produto-nome">@item.Produto.Nome</h5>
                                        @if (!string.IsNullOrEmpty(item.Sabor))
                                        {
                                            <div class="produto-sabor"><strong>Sabor:</strong> @item.Sabor</div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Observacoes))
                                        {
                                            <div class="produto-observacoes">
                                                <strong>Obs:</strong> @item.Observacoes
                                            </div>
                                        }
                                    <div class="produto-estoque">
                                        <small>Estoque disponível: <strong>@maxPermitido</strong></small>
                                    </div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <form asp-action="AtualizarItem" method="post" class="quantidade-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="produtoId" value="@item.Produto.Id" />
                                <input type="hidden" name="sabor" value="@item.Sabor" />

                                <div class="input-group">
                                    <!-- Botão -1 envia op=dec -->
                                    <button type="submit" name="op" value="dec" class="btn btn-outline-secondary" aria-label="Diminuir">
                                        <i class="fas fa-minus"></i>
                                    </button>

                                    <input type="number"
                                           name="quantidade"
                                           value="@item.Quantidade"
                                           min="1"
                                           max="@maxPermitido"
                                           class="form-control text-center"
                                           inputmode="numeric" />

                                    <!-- Botão +1 envia op=inc -->
                                    <button type="submit" name="op" value="inc" class="btn btn-outline-secondary" aria-label="Aumentar">
                                        <i class="fas fa-plus"></i>
                                    </button>

                                    <!-- Botão atualizar explícito (usa o valor do input) -->
                                    <button type="submit" class="btn btn-primary">
                                        Atualizar
                                    </button>
                                </div>
                            </form>
                        </td>

                        <td>@precoNormal.ToString("C", ptBR)</td>
                        <td>
                            @(precoPromo.HasValue
                                                    ? precoPromo.Value.ToString("C", ptBR)
                                                    : Html.Raw("<span title=\"Sem promoção ativa\">—</span>"))
                    </td>

                            <td>
                                <form asp-action="RemoverItem" method="post" class="remove-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="produtoId" value="@item.Produto.Id" />
                                    <input type="hidden" name="sabor" value="@item.Sabor" />
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-trash"></i> Remover
                                    </button>
                                </form>
                            </td>
                        </tr>
                                }
                </tbody>
            </table>
        </div>

        <div class="carrinho-total">
            <div class="total-container">
                <div class="total-label">Total:</div>
                <div class="total-valor">
                    @Model.Total.ToString("C", ptBR)
                </div>
            </div>
        </div>

        <div class="carrinho-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i> Continuar Comprando
            </a>
            <a asp-action="Resumo" class="btn btn-primary">
                Finalizar Pedido <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    }
    else
    {
        <div class="carrinho-vazio">
            <h4>Seu carrinho está vazio</h4>
            <p>Adicione pods eletrônicos ao seu carrinho para continuar.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-store"></i> Ver Produtos
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/Carrinho-form.js" asp-append-version="true"></script>
    <script>
        // Apenas para sumir os alerts depois de 5s (não é AJAX)
        setTimeout(() => {
            document.querySelectorAll('#carrinho-alerts .alert').forEach(a => {
                a.style.transition = 'opacity .5s';
                a.style.opacity = '0';
                setTimeout(() => a.remove(), 500);
            });
        }, 5000);
    </script>
}
