@model WebApplicationPods.Models.CarrinhoModel
@using System.Globalization
@section Styles {
    <link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="carrinho-container">
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
        </div>
    }

    <h2>Seu Carrinho de Compras</h2>

    @if (Model.Itens.Any())
    {
        <div class="table-responsive">
            <table class="carrinho-table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Quantidade</th>
                        <th>Preço Unitário</th>
                        <th>Subtotal</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        <tr>
                            <td>
                                <div class="produto-info">
                                    <img src="@item.Produto.ImagemUrl" alt="@item.Produto.Nome" class="produto-imagem" />
                                    <div>
                                        <h5 class="produto-nome">@item.Produto.Nome</h5>
                                        @if (!string.IsNullOrEmpty(item.Sabor))
                                        {
                                            <div class="produto-sabor"><strong>Sabor:</strong> @item.Sabor</div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Observacoes))
                                        {
                                            <div class="produto-observacoes">
                                                <strong>Obs:</strong> @item.Observacoes
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <form asp-action="AtualizarItem" method="post" class="quantidade-form">
                                    <input type="hidden" name="produtoId" value="@item.Produto.Id" />
                                    <input type="hidden" name="sabor" value="@item.Sabor" />

                                    <div class="input-group">
                                        <button type="button" class="btn btn-outline-secondary quantidade-btn" data-action="decrease">
                                            <i class="fas fa-minus"></i>
                                        </button>

                                        <input type="number" name="quantidade" value="@item.Quantidade" min="1"
                                               class="form-control text-center quantidade-input">

                                        <button type="button" class="btn btn-outline-secondary quantidade-btn" data-action="increase">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </form>
                            </td>
                            <td>@item.PrecoUnitario.ToString("C", new CultureInfo("pt-BR"))</td>
                            <td>@item.Subtotal.ToString("C", new CultureInfo("pt-BR"))</td>
                            <td>
                                <form asp-action="RemoverItem" method="post">
                                    <input type="hidden" name="produtoId" value="@item.Produto.Id" />
                                    <input type="hidden" name="sabor" value="@item.Sabor" />
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-trash"></i> Remover
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="carrinho-total">
            <div class="total-container">
                <div class="total-label">Total:</div>
                <div class="total-valor">@Model.Total.ToString("C", new CultureInfo("pt-BR"))</div>
            </div>
        </div>

        <div class="carrinho-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i> Continuar Comprando
            </a>
            <a asp-action="Resumo" class="btn btn-primary">
                Finalizar Pedido <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    }
    else
    {
        <div class="carrinho-vazio">
            <h4>Seu carrinho está vazio</h4>
            <p>Adicione pods eletrônicos ao seu carrinho para continuar.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-store"></i> Ver Produtos
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/Carrinho-form.js" asp-append-version="true"></script>
}