@model WebApplicationPods.Models.PedidoModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Pedido confirmado";
    var pedidoId = Model?.Id;
}
@section Styles {
    <link rel="stylesheet" href="~/css/pedido-confirmado.css" asp-append-version="true" />
}
<div class="container my-4">
    <div class="alert alert-success">
        <h4 class="mb-1">Pedido #@pedidoId confirmado!</h4>
        <div>Obrigado! Você pode acompanhar o andamento em tempo real.</div>
    </div>

    <!-- CTA desktop/tablet -->
    <div class="d-none d-md-flex gap-2">
        <a class="btn btn-primary"
           href="@Url.Action("Acompanhar", "Pedido", new { id = pedidoId })">
            Acompanhar pedido
        </a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Home")">
            Voltar à loja
        </a>
    </div>
</div>

<!-- Barra fixa somente no mobile -->
<div class="d-md-none mobile-cta fixed-cta bg-white border-top p-3 shadow-lg">
    <a class="btn btn-primary btn-lg w-100"
       href="@Url.Action("Acompanhar", "Pedido", new { id = pedidoId })">
        Acompanhar pedido
    </a>
</div>
