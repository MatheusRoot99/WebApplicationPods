@model CarrinhoModel

@{
    ViewData["Title"] = "Resumo do Pedido";
}
<link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    @if (Model.Itens.Any())
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4>Itens do Pedido</h4>
                    </div>
                    <div class="card-body">
                        @foreach (var item in Model.Itens)
                        {
                            <div class="mb-3 border-bottom pb-3">
                                <div class="d-flex justify-content-between">
                                    <h5>@item.Produto.Nome</h5>
                                    <span>@item.Subtotal.ToString("C")</span>
                                </div>
                                <div class="text-muted">
                                    @item.Quantidade x @item.PrecoUnitario.ToString("C")
                                </div>
                                @if (!string.IsNullOrEmpty(item.Observacoes))
                                {
                                    <div class="mt-2">
                                        <strong>Obs:</strong> @item.Observacoes
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4>Total do Pedido</h4>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-3">
                            <span>Subtotal:</span>
                            <span>@Model.Total.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Frete:</span>
                            <span>Grátis</span>
                        </div>
                        <div class="d-flex justify-content-between font-weight-bold">
                            <span>Total:</span>
                            <span>@Model.Total.ToString("C")</span>
                        </div>

                        <form method="post" asp-action="FinalizarPedido" class="mt-4">
                            <button type="submit" class="btn btn-success btn-block">
                                Confirmar Pedido
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            Seu carrinho está vazio. <a asp-action="Index">Voltar ao carrinho</a>
        </div>
    }
</div>