@model WebApplicationPods.Models.ResumoPedidoViewModel
@using WebApplicationPods.Models
@using System.Globalization
@using System.Text.RegularExpressions

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Resumo do Pedido";
    var loja = ViewBag.Loja as LojaConfig;

    string FormatarTelefone(string telefone)
    {
        if (string.IsNullOrWhiteSpace(telefone)) return "";

        var d = Regex.Replace(telefone, @"\D+", "");

        if ((d.Length == 12 || d.Length == 13) && d.StartsWith("55"))
            d = d.Substring(2);

        if (d.Length == 11) return $"({d[..2]}) {d.Substring(2, 5)}-{d.Substring(7)}";
        if (d.Length == 10) return $"({d[..2]}) {d.Substring(2, 4)}-{d.Substring(6)}";
        if (d.Length == 9) return $"{d[..5]}-{d.Substring(5)}";
        if (d.Length == 8) return $"{d[..4]}-{d.Substring(4)}";

        return telefone;
    }

    int? TentarObterInt(object obj, params string[] nomes)
    {
        if (obj == null) return null;

        var type = obj.GetType();
        foreach (var nome in nomes)
        {
            var prop = type.GetProperty(nome);
            if (prop == null) continue;

            var valor = prop.GetValue(obj);
            if (valor == null) continue;

            if (valor is int i) return i;
            if (int.TryParse(valor.ToString(), out var convertido)) return convertido;
        }

        return null;
    }

    decimal? TentarObterDecimal(object obj, params string[] nomes)
    {
        if (obj == null) return null;

        var type = obj.GetType();
        foreach (var nome in nomes)
        {
            var prop = type.GetProperty(nome);
            if (prop == null) continue;

            var valor = prop.GetValue(obj);
            if (valor == null) continue;

            if (valor is decimal dec) return dec;
            if (valor is double dbl) return Convert.ToDecimal(dbl);
            if (valor is float flt) return Convert.ToDecimal(flt);

            if (decimal.TryParse(valor.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var convertidoInv))
                return convertidoInv;

            if (decimal.TryParse(valor.ToString(), out var convertido))
                return convertido;
        }

        return null;
    }

    string MontarDescricaoQuantidade(dynamic item)
    {
        var qtd = (int)(item?.Quantidade ?? 0);
        if (qtd <= 0) qtd = 1;

        var produto = item?.Produto;
        var unidadesPack = TentarObterInt(produto,
            "UnidadesPorPack",
            "QuantidadePorPack",
            "QtdPorPack",
            "PodsPorPack",
            "Unidades",
            "QuantidadeUnidades");

        if (unidadesPack.HasValue && unidadesPack.Value > 1)
        {
            var packTxt = qtd == 1 ? "pack" : "packs";
            var unTxt = unidadesPack.Value == 1 ? "unidade" : "unidades";
            return $"{qtd} {packTxt} c/ {unidadesPack.Value} {unTxt}";
        }

        return qtd == 1 ? "1 un." : $"{qtd} un.";
    }

    decimal ObterPrecoUnitario(dynamic item)
    {
        decimal? preco =
            TentarObterDecimal(item, "PrecoUnitario", "ValorUnitario", "Preco") ??
            TentarObterDecimal(item?.Produto, "PrecoPromocional", "PrecoPor", "PrecoVenda", "Preco");

        return preco ?? 0;
    }

    decimal ObterSubtotalItem(dynamic item)
    {
        var qtd = (int)(item?.Quantidade ?? 0);
        if (qtd <= 0) qtd = 1;

        var subtotalDireto =
            TentarObterDecimal(item, "Subtotal", "ValorTotal", "Total");

        if (subtotalDireto.HasValue && subtotalDireto.Value > 0)
            return subtotalDireto.Value;

        return ObterPrecoUnitario(item) * qtd;
    }

    var telefoneFormatado = FormatarTelefone(Model?.Cliente?.Telefone);
    var subtotalPedido = Model?.Carrinho?.Total ?? 0;
    var taxaEntregaInicial = Model?.RetiradaNoLocal == true ? 0 : 5;
    var totalItensCarrinho = Model?.Carrinho?.Itens?.Sum(i => i.Quantidade) ?? 0;
    var quantidadeProdutos = Model?.Carrinho?.Itens?.Count() ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/resumo-componente.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}

<div class="container-xxl mt-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4 resumo-topbar">
        <div>
            <h1 class="mb-1 fw-bold">@ViewData["Title"]</h1>
            @* <div class="text-muted small">Confira seus dados e finalize com segurança</div> *@
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    @if (Model?.Carrinho?.Itens?.Any() == true)
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 overflow-hidden compact-section-card">
                    <div class="card-header bg-gradient-orange text-white d-flex align-items-center compact-section-header">
                        <div class="icon-circle bg-white bg-opacity-10 me-2">
                            <i class="bi bi-person-badge text-white"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Dados do Cliente</h5>
                            <small class="opacity-75">Contato</small>
                        </div>
                    </div>

                    <div class="card-body compact-section-body">
                        <div class="row g-2 compact-client-grid">
                            <div class="col-md-4">
                                <div class="info-box info-box-premium compact-info-box">
                                    <small>Nome</small>
                                    <div class="fw-semibold info-value text-truncate" title="@Model.Cliente.Nome">
                                        @Model.Cliente.Nome
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="info-box info-box-premium compact-info-box">
                                    <small>Telefone</small>
                                    <div class="fw-semibold info-value" id="telefoneClienteTopo">
                                        @telefoneFormatado
                                    </div>
                                </div>
                            </div>

                            @* <div class="col-md-4">
                                <div class="info-box info-box-premium compact-info-box">
                                    <small>Email</small>
                                    <div class="fw-semibold info-value text-truncate" title="@Model.Cliente.Email">
                                        @Model.Cliente.Email
                                    </div>
                                </div>
                            </div> *@
                        </div>
                    </div>
                </div>

                <form asp-action="Finalizar" method="post" id="formFinalizar">
                    @Html.AntiForgeryToken()

                    <div class="card shadow-sm border-0 mt-4">
                        <div class="card-header bg-gradient-orange text-white d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="icon-circle bg-white bg-opacity-10 me-3">
                                    <i class="bi bi-truck text-white"></i>
                                </div>
                                <div>
                                    <h5 class="mb-0">Entrega</h5>
                                    <small class="opacity-75">Escolha como receber seu pedido</small>
                                </div>
                            </div>

                            <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#enderecoModal">
                                <i class="bi bi-plus-lg me-1"></i> Novo Endereço
                            </button>
                        </div>

                        <div class="card-body">
                            <div class="form-check form-switch switch-lg mb-3">
                                <input asp-for="RetiradaNoLocal" class="form-check-input" type="checkbox" id="retiradaLocal">
                                <label class="form-check-label" for="retiradaLocal">
                                    <span class="d-block fw-semibold">Retirar no local</span>
                                    <small class="text-muted">Você busca seu pedido no restaurante</small>
                                </label>
                            </div>

                            <div id="pickupBox" class="pickup-box mb-3 @(Model.RetiradaNoLocal ? "" : "d-none")">
                                <div class="title mb-1">
                                    <i class="bi bi-shop me-1"></i> @(loja?.Nome ?? "Retirada na loja")
                                </div>
                                <div class="text-muted">@(loja?.EnderecoTexto ?? "Endereço da loja não configurado.")</div>

                                @if (!string.IsNullOrWhiteSpace(loja?.MapsUrl))
                                {
                                    <a class="btn btn-dark btn-sm mt-2" href="@loja.MapsUrl" target="_blank" rel="noopener">
                                        <i class="bi bi-geo-alt me-1"></i> Abrir no Google Maps
                                    </a>
                                }
                            </div>

                            <div id="containerEntrega" class="@(Model.RetiradaNoLocal ? "d-none" : "") animate__animated animate__fadeIn">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Selecione um endereço</label>

                                    <div class="d-flex gap-2 mb-3">
                                        <select asp-for="EnderecoSelecionadoId" class="form-select" id="enderecoSelect">
                                            <option value="">Selecione...</option>
                                            @foreach (var e in Model.EnderecosDisponiveis)
                                            {
                                                <option value="@e.Id"
                                                        data-logradouro="@e.Logradouro"
                                                        data-numero="@e.Numero"
                                                        data-complemento="@e.Complemento"
                                                        data-bairro="@e.Bairro"
                                                        data-cidade="@e.Cidade"
                                                        data-estado="@e.Estado"
                                                        data-cep="@e.CEP"
                                                        data-principal="@(e.Principal ? "true" : "false")">
                                                    @e.Logradouro, @e.Numero - @e.Bairro
                                                </option>
                                            }
                                        </select>

                                        <button type="button"
                                                class="btn btn-outline-secondary flex-shrink-0"
                                                id="btnEditarEndereco"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editarEnderecoModal"
                                                disabled>
                                            <i class="bi bi-pencil-square"></i>
                                        </button>

                                        <button type="button"
                                                class="btn btn-outline-danger flex-shrink-0"
                                                id="btnExcluirEndereco"
                                                data-bs-toggle="modal"
                                                data-bs-target="#excluirEnderecoModal"
                                                disabled>
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>

                                <div id="enderecoDetalhes" class="address-card @(Model.EnderecoEntrega == null ? "empty" : "")">
                                    @if (Model.EnderecoEntrega != null)
                                    {
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="mb-0 d-flex align-items-center gap-2">
                                                <i class="bi bi-house-check text-orange"></i>
                                                <span>Endereço selecionado</span>
                                                @if (Model.EnderecoEntrega.Principal)
                                                {
                                                    <span class="badge bg-orange-soft">Principal</span>
                                                }
                                            </h6>
                                            <small class="text-muted">CEP: @Model.EnderecoEntrega.CEP</small>
                                        </div>

                                        <div class="address-details">
                                            <div>@Model.EnderecoEntrega.Logradouro, @Model.EnderecoEntrega.Numero</div>
                                            @if (!string.IsNullOrEmpty(Model.EnderecoEntrega.Complemento))
                                            {
                                                <div>@Model.EnderecoEntrega.Complemento</div>
                                            }
                                            <div>@Model.EnderecoEntrega.Bairro - @Model.EnderecoEntrega.Cidade/@Model.EnderecoEntrega.Estado</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="empty-state">
                                            <i class="bi bi-house-x"></i>
                                            <span>Nenhum endereço selecionado</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 mt-3 compact-section-card">
                        <div class="card-header bg-gradient-orange text-white d-flex align-items-center compact-section-header">
                            <div class="icon-circle bg-white bg-opacity-10 me-2">
                                <i class="bi bi-chat-square-text text-white"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Observações</h5>
                                <small class="opacity-75">Opcional</small>
                            </div>
                        </div>

                        <div class="card-body compact-section-body">
                            <textarea asp-for="Observacoes"
                                      class="form-control compact-textarea"
                                      rows="2"
                                      maxlength="200"
                                      placeholder="Ex.: trocar sabor, aviso, horário..."></textarea>
                            <div class="compact-helper-text">Máx. 200 caracteres</div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 mt-4">
                        <div class="card-header bg-gradient-orange text-white d-flex align-items-center">
                            <div class="icon-circle bg-white bg-opacity-10 me-3">
                                <i class="bi bi-credit-card text-white"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Pagamento</h5>
                                <small class="opacity-75">Escolha como deseja pagar</small>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="payments-grid">
                                <div>
                                    <input type="radio" class="btn-check" id="pay-money" asp-for="MetodoPagamento" value="Dinheiro" />
                                    <label class="btn btn-payment w-100" for="pay-money">
                                        <i class="bi bi-cash-coin payment-icon"></i>
                                        <span>Dinheiro</span>
                                    </label>
                                </div>

                                <div>
                                    <input type="radio" class="btn-check" id="pay-pix" asp-for="MetodoPagamento" value="Pix" />
                                    <label class="btn btn-payment w-100" for="pay-pix">
                                        <i class="bi bi-qr-code payment-icon"></i>
                                        <span>Pix</span>
                                    </label>
                                </div>

                                <div>
                                    <input type="radio" class="btn-check" id="pay-card-credit" asp-for="MetodoPagamento" value="Cartão de Crédito" />
                                    <label class="btn btn-payment w-100" for="pay-card-credit">
                                        <i class="bi bi-credit-card payment-icon"></i>
                                        <span>Cartão</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-orange btn-lg py-3 fw-bold">
                            <i class="bi bi-check2-circle me-2"></i> Finalizar Pedido
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top compact-summary-card">
                    @* <div class="card-header compact-summary-header d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center min-w-0">
                            <div class="icon-circle bg-white bg-opacity-10 me-2">
                                <i class="bi bi-bag-check text-white"></i>
                            </div>
                             <div class="min-w-0">
                                <h5 class="mb-0 compact-summary-title">Seu Pedido</h5>
                                <small class="opacity-75">Resumo compacto</small>
                            </div> 
                        </div>

                        <span class="compact-count-badge">@totalItensCarrinho</span>
                    </div> *@

                    <div class="card-body compact-summary-body">
                        @* <div class="compact-summary-top">
                            <div class="compact-summary-top-title">
                                @quantidadeProdutos @(quantidadeProdutos == 1 ? "produto" : "produtos")
                            </div>
                             <div class="compact-summary-top-subtitle">
                                Revise itens, sabores e valores
                            </div> 
                        </div> *@

                        <div class="compact-items">
                            @foreach (var item in Model.Carrinho.Itens)
                            {
                                var qtd = item.Quantidade;
                                var nome = item.Produto?.Nome ?? "Produto";
                                var sabor = item.Sabor as string;
                                var descricaoQtd = MontarDescricaoQuantidade(item);
                                var precoUnit = ObterPrecoUnitario(item);
                                var subtotalItem = ObterSubtotalItem(item);

                                <div class="compact-item">
                                    <div class="compact-item-image">
                                        <img src="@item.Produto.ImagemUrl" alt="@nome">
                                        <span class="compact-item-qty">@qtd</span>
                                    </div>

                                    <div class="compact-item-main">
                                        <div class="compact-item-top">
                                            <h6 class="compact-item-name">@nome</h6>
                                            <strong class="compact-item-total">@subtotalItem.ToString("C")</strong>
                                        </div>

                                        <div class="compact-item-meta">
                                            <span>@descricaoQtd</span>

                                            @if (!string.IsNullOrWhiteSpace(sabor))
                                            {
                                                <span class="compact-dot">•</span>
                                                <span class="compact-item-flavor">@sabor</span>
                                            }

                                            <span class="compact-dot">•</span>
                                            <span>@precoUnit.ToString("C")/un.</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="compact-order-summary">
                            <div class="compact-summary-row">
                                <span>Subtotal</span>
                                <strong>@subtotalPedido.ToString("C")</strong>
                            </div>

                            <div class="compact-summary-row">
                                <span>Entrega</span>
                                <strong id="taxaEntregaLabel">@(Model.RetiradaNoLocal ? "Grátis" : "R$ 5,00")</strong>
                            </div>

                            <div class="compact-summary-row compact-status-row">
                                <span>Tipo</span>
                                <strong id="tipoEntregaLabel">@(Model.RetiradaNoLocal ? "Retirada" : "Entrega")</strong>
                            </div>

                            <div class="compact-summary-divider"></div>

                            <div class="compact-summary-row total">
                                <span>Total</span>
                                <strong id="totalGeralLabel">@((subtotalPedido + taxaEntregaInicial).ToString("C"))</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-cart">
            <div class="empty-icon"><i class="bi bi-cart-x"></i></div>
            <h3>Seu carrinho está vazio</h3>
            <p class="text-muted">Adicione itens ao seu carrinho antes de finalizar o pedido</p>
            <a asp-action="Index" class="btn btn-orange mt-3">
                <i class="bi bi-arrow-left me-2"></i> Voltar ao cardápio
            </a>
        </div>
    }
</div>

<div class="modal fade" id="enderecoModal" tabindex="-1" aria-hidden="true" aria-labelledby="enderecoTitle" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal">
            <div class="modal-header">
                <h5 id="enderecoTitle" class="modal-title"><i class="bi bi-geo-alt me-2"></i>Novo Endereço</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="AdicionarEndereco" method="post" id="formEnderecoModal">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ClienteId" value="@Model.Cliente.Id" />

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-8">
                            <label class="form-label">CEP</label>
                            <input class="form-control" name="EnderecoNovo.CEP" data-cep inputmode="numeric" autocomplete="postal-code" placeholder="00000-000" />
                        </div>
                        <div class="col-4 d-flex align-items-end">
                            <button type="button" id="buscarCepBtn" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-search"></i> Buscar
                            </button>
                        </div>

                        <div class="col-9">
                            <label class="form-label">Logradouro</label>
                            <input class="form-control" name="EnderecoNovo.Logradouro" />
                        </div>
                        <div class="col-3">
                            <label class="form-label">Número</label>
                            <input class="form-control" name="EnderecoNovo.Numero" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Complemento</label>
                            <input class="form-control" name="EnderecoNovo.Complemento" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Bairro</label>
                            <input class="form-control" name="EnderecoNovo.Bairro" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cidade</label>
                            <input class="form-control" name="EnderecoNovo.Cidade" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">UF</label>
                            <input class="form-control text-uppercase" name="EnderecoNovo.Estado" maxlength="2" />
                        </div>

                        <div class="col-12 form-check">
                            <input class="form-check-input" type="checkbox" name="EnderecoNovo.Principal" id="novo_Principal" />
                            <label class="form-check-label" for="novo_Principal">Definir como principal</label>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-orange">Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editarEnderecoModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar Endereço</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form id="formEditarEndereco" asp-action="AtualizarEndereco" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ClienteId" value="@Model.Cliente.Id" />
                <input type="hidden" id="edit_Id" name="Id" />

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">CEP</label>
                            <div class="input-group">
                                <input id="edit_CEP" name="CEP" class="form-control" data-cep placeholder="00000-000" inputmode="numeric" />
                                <button class="btn btn-outline-secondary" type="button" id="buscarCepBtnEditar">Buscar</button>
                            </div>
                        </div>

                        <div class="col-6">
                            <label class="form-label">Número</label>
                            <input id="edit_Numero" name="Numero" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Logradouro</label>
                            <input id="edit_Logradouro" name="Logradouro" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Complemento</label>
                            <input id="edit_Complemento" name="Complemento" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Bairro</label>
                            <input id="edit_Bairro" name="Bairro" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cidade</label>
                            <input id="edit_Cidade" name="Cidade" class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">UF</label>
                            <input id="edit_Estado" name="Estado" class="form-control" maxlength="2" />
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="edit_Principal" name="Principal" />
                                <label class="form-check-label" for="edit_Principal">Definir como principal</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-orange">Salvar alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.PrecisaConfirmar)
{
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true" aria-labelledby="confirmTitle" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content confirm-modal">
                <div class="modal-header">
                    <h5 id="confirmTitle" class="modal-title"><i class="bi bi-shield-check me-2"></i>Confirme seus dados</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <div class="confirm-line mb-3">
                        <div class="confirm-ico"><i class="bi bi-person"></i></div>
                        <div>
                            <small class="text-muted d-block">Eu sou</small>
                            <div class="fw-semibold">@Model?.Cliente?.Nome</div>
                        </div>
                    </div>

                    <div class="confirm-line">
                        <div class="confirm-ico"><i class="bi bi-phone"></i></div>
                        <div>
                            <small class="text-muted d-block">Meu telefone é</small>
                            <div id="telefoneResumo" class="fw-semibold">@telefoneFormatado</div>
                        </div>
                    </div>

                    <div class="mt-3 d-grid gap-2">
                        <form class="m-0">
                            @Html.AntiForgeryToken()
