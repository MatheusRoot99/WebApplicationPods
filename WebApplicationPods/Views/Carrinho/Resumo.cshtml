@model WebApplicationPods.Models.ResumoPedidoViewModel

@{
    ViewData["Title"] = "Resumo do Pedido";
}

@section Styles {
    <link rel="stylesheet" href="~/css/resumo-componente.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        .confirm-modal .modal-header {
            background: linear-gradient(90deg,#8b5cf6,#2563eb);
            color: #fff;
        }

        .confirm-line {
            display: flex;
            align-items: flex-start;
            gap: .75rem;
        }

        .confirm-ico {
            width: 44px;
            height: 44px;
            border-radius: 999px;
            background: #eef2ff;
            display: grid;
            place-items: center;
        }

        .btn-confirm {
            background: #ffbf00;
            border-color: #ffbf00;
            color: #000;
            font-weight: 600;
        }

            .btn-confirm:hover {
                filter: brightness(.95);
                color: #000;
            }
    </style>
}

<div class="container-xxl mt-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 fw-bold">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-dark">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>

    <!-- Alertas -->
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    @* ===== CONTEÚDO ORIGINAL (seu formulário + resumo de itens) ===== *@
    @* --- DAQUI PRA BAIXO É A SUA VIEW ATUAL, sem a faixa superior "Confirme seus dados" --- *@

    @if (Model?.Carrinho?.Itens?.Any() == true)
    {
        <div class="row g-4">
            <!-- COLUNA ESQUERDA - Formulário -->
            <div class="col-lg-8">
                <!-- Dados do Cliente -->
                <div class="card shadow-sm border-0 overflow-hidden">
                    <div class="card-header bg-gradient-orange text-white d-flex align-items-center">
                        <div class="icon-circle bg-white bg-opacity-10 me-3">
                            <i class="bi bi-person-badge text-white"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Dados do Cliente</h5>
                            <small class="opacity-75">Informações para contato</small>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="info-box">
                                    <small class="text-muted">Nome</small>
                                    <div class="fw-semibold">@Model.Cliente.Nome</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-box">
                                    <small class="text-muted">Telefone</small>
                                    <div class="fw-semibold">@Model.Cliente.Telefone</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-box">
                                    <small class="text-muted">Email</small>
                                    <div class="fw-semibold">@Model.Cliente.Email</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Formulário Principal -->
                <form asp-action="Finalizar" method="post" id="formFinalizar">
                    @Html.AntiForgeryToken()

                    <!-- Entrega / Retirada -->
                    <div class="card shadow-sm border-0 mt-4">
                        <div class="card-header bg-gradient-orange text-white d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="icon-circle bg-white bg-opacity-10 me-3">
                                    <i class="bi bi-truck text-white"></i>
                                </div>
                                <div>
                                    <h5 class="mb-0">Entrega</h5>
                                    <small class="opacity-75">Escolha como receber seu pedido</small>
                                </div>
                            </div>
                            <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#enderecoModal">
                                <i class="bi bi-plus-lg me-1"></i> Novo Endereço
                            </button>
                        </div>

                        <div class="card-body">
                            <div class="form-check form-switch switch-lg mb-4">
                                <input asp-for="RetiradaNoLocal" class="form-check-input" type="checkbox" id="retiradaLocal">
                                <label class="form-check-label" for="retiradaLocal">
                                    <span class="d-block fw-semibold">Retirar no local</span>
                                    <small class="text-muted">Você busca seu pedido no restaurante</small>
                                </label>
                            </div>

                            <div id="containerEntrega" class="@(Model.RetiradaNoLocal ? "d-none" : "") animate__animated animate__fadeIn">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Selecione um endereço</label>
                                    <div class="d-flex gap-2 mb-3">
                                        <select asp-for="EnderecoSelecionadoId" class="form-select" id="enderecoSelect">
                                            <option value="">Selecione...</option>
                                            @foreach (var e in Model.EnderecosDisponiveis)
                                            {
                                                <option value="@e.Id"
                                                        data-logradouro="@e.Logradouro"
                                                        data-numero="@e.Numero"
                                                        data-complemento="@e.Complemento"
                                                        data-bairro="@e.Bairro"
                                                        data-cidade="@e.Cidade"
                                                        data-estado="@e.Estado"
                                                        data-cep="@e.CEP"
                                                        data-principal="@(e.Principal ? "true" : "false")">
                                                    @e.Logradouro, @e.Numero - @e.Bairro
                                                </option>
                                            }
                                        </select>
                                        <button type="button" class="btn btn-dark flex-shrink-0" data-bs-toggle="modal" data-bs-target="#enderecoModal">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary flex-shrink-0" id="btnEditarEndereco" data-bs-toggle="modal" data-bs-target="#editarEnderecoModal" disabled>
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    </div>
                                </div>

                                <div id="enderecoDetalhes" class="address-card @(Model.EnderecoEntrega == null ? "empty" : "")">
                                    @if (Model.EnderecoEntrega != null)
                                    {
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="mb-0 d-flex align-items-center gap-2">
                                                <i class="bi bi-house-check text-orange"></i>
                                                <span>Endereço selecionado</span>
                                                @if (Model.EnderecoEntrega.Principal)
                                                {
                                                    <span class="badge bg-orange-soft">Principal</span>
                                                }
                                            </h6>
                                            <small class="text-muted">CEP: @Model.EnderecoEntrega.CEP</small>
                                        </div>
                                        <div class="address-details">
                                            <div>@Model.EnderecoEntrega.Logradouro, @Model.EnderecoEntrega.Numero</div>
                                            @if (!string.IsNullOrEmpty(Model.EnderecoEntrega.Complemento))
                                            {
                                                <div>@Model.EnderecoEntrega.Complemento</div>
                                            }
                                            <div>@Model.EnderecoEntrega.Bairro - @Model.EnderecoEntrega.Cidade/@Model.EnderecoEntrega.Estado</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="empty-state">
                                            <i class="bi bi-house-x"></i>
                                            <span>Nenhum endereço selecionado</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Observações -->
                    <div class="card shadow-sm border-0 mt-4">
                        <div class="card-header bg-gradient-orange text-white d-flex align-items-center">
                            <div class="icon-circle bg-white bg-opacity-10 me-3">
                                <i class="bi bi-chat-square-text text-white"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Observações</h5>
                                <small class="opacity-75">Instruções especiais para seu pedido</small>
                            </div>
                        </div>
                        <div class="card-body">
                            <textarea asp-for="Observacoes" class="form-control" rows="3" placeholder="Ex.: aviso, trocar sabor, horário..."></textarea>
                            <small class="text-muted">Máximo de 200 caracteres</small>
                        </div>
                    </div>

                    <!-- Pagamento -->
                    <div class="card shadow-sm border-0 mt-4">
                        <div class="card-header bg-gradient-orange text-white d-flex align-items-center">
                            <div class="icon-circle bg-white bg-opacity-10 me-3">
                                <i class="bi bi-credit-card text-white"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">Pagamento</h5>
                                <small class="opacity-75">Escolha como deseja pagar</small>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="payments-grid">
                                <!-- Dinheiro -->
                                <div>
                                    <input type="radio" class="btn-check" id="pay-money"
                                           name="MetodoPagamento" value="Dinheiro"
                                           @(Model.MetodoPagamento == "Dinheiro" ? "checked" : "")>
                                    <label class="btn btn-payment" for="pay-money">
                                        <i class="bi bi-cash-coin payment-icon"></i>
                                        <span>Dinheiro</span>
                                    </label>
                                </div>

                                <!-- Pix -->
                                <div>
                                    <input type="radio" class="btn-check" id="pay-pix"
                                           name="MetodoPagamento" value="Pix"
                                           @(Model.MetodoPagamento == "Pix" ? "checked" : "")>
                                    <label class="btn btn-payment" for="pay-pix">
                                        <i class="bi bi-qr-code payment-icon"></i>
                                        <span>Pix</span>
                                    </label>
                                </div>

                                <!-- Cartão (Crédito/Débito) -->
                                <div>
                                    <!-- ⚠️ valor “Cartão de Débito” mantém compatibilidade com MapearMetodoPagamento (paga na entrega).
                                         O rótulo mostra as duas bandeiras. Se preferir online (crédito), troque o value para "Cartão de Crédito". -->
                                    <input type="radio" class="btn-check" id="pay-card"
                                           name="MetodoPagamento" value="Cartão de Débito"
                                           @(Model.MetodoPagamento == "Cartão de Débito" ? "checked" : "")>
                                    <label class="btn btn-payment" for="pay-card">
                                        <i class="bi bi-credit-card payment-icon"></i>
                                        <span>Cartão (Crédito/Débito)</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-orange btn-lg py-3 fw-bold">
                            <i class="bi bi-check2-circle me-2"></i> Finalizar Pedido
                        </button>
                    </div>
                </form>
            </div>

            <!-- COLUNA DIREITA - Resumo do Pedido -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 sticky-top">
                    <div class="card-header bg-dark text-white d-flex align-items-center">
                        <div class="icon-circle bg-white bg-opacity-10 me-3">
                            <i class="bi bi-bag-check text-white"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Seu Pedido</h5>
                            <small class="opacity-75">Resumo dos itens</small>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="order-items">
                            @foreach (var item in Model.Carrinho.Itens)
                            {
                                <div class="order-item">
                                    <div class="item-image">
                                        <img src="@item.Produto.ImagemUrl" alt="@item.Produto.Nome" class="img-fluid rounded">
                                        <span class="item-quantity">@item.Quantidade</span>
                                    </div>
                                    <div class="item-details">
                                        <h6 class="item-name">@item.Produto.Nome</h6>
                                        @if (!string.IsNullOrEmpty(item.Sabor))
                                        {
                                            <small class="item-flavor">Sabor: @item.Sabor</small>
                                        }
                                    </div>
                                    <div class="item-price">
                                        <div>@((item.Produto.Preco * item.Quantidade).ToString("C"))</div>
                                        @if (item.Produto.EstaEmPromocao())
                                        {
                                            <small class="text-muted text-decoration-line-through">@(item.Produto.Preco.ToString("C"))</small>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="order-summary">
                            <div class="summary-row">
                                <span>Subtotal</span>
                                <strong>@Model.Carrinho.Total.ToString("C")</strong>
                            </div>
                            <div class="summary-row">
                                <span>Taxa de Entrega</span>
                                <strong id="taxaEntregaLabel">@(Model.RetiradaNoLocal ? "Grátis" : "R$ 5,00")</strong>
                            </div>
                            <hr class="my-2">
                            <div class="summary-row total">
                                <span>Total</span>
                                <strong id="totalGeralLabel">
                                    @((Model.Carrinho.Total + (Model.RetiradaNoLocal ? 0 : 5)).ToString("C"))
                                </strong>
                            </div>
                            <small class="text-muted d-block mt-2">* Taxa pode variar por região</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-cart">
            <div class="empty-icon">
                <i class="bi bi-cart-x"></i>
            </div>
            <h3>Seu carrinho está vazio</h3>
            <p class="text-muted">Adicione itens ao seu carrinho antes de finalizar o pedido</p>
            <a asp-action="Index" class="btn btn-orange mt-3">
                <i class="bi bi-arrow-left me-2"></i> Voltar ao cardápio
            </a>
        </div>
    }
</div>

@* ===================== MODAL "CONFIRME SEUS DADOS" ===================== *@
<div class="modal fade confirm-modal" id="confirmModal" tabindex="-1" aria-hidden="true" aria-labelledby="confirmTitle">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="confirmTitle" class="modal-title"><i class="bi bi-shield-check me-2"></i>Confirme seus dados</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="confirm-line mb-3">
                    <div class="confirm-ico"><i class="bi bi-person"></i></div>
                    <div>
                        <small class="text-muted d-block">Eu sou</small>
                        <div class="fw-semibold">@Model?.Cliente?.Nome</div>
                    </div>
                </div>
                <div class="confirm-line">
                    <div class="confirm-ico"><i class="bi bi-phone"></i></div>
                    <div>
                        <small class="text-muted d-block">Meu telefone é</small>
                        <div class="fw-semibold">@Model?.Cliente?.Telefone</div>
                    </div>
                </div>

                <div class="mt-3 d-grid gap-2">
                    <a class="btn btn-outline-warning w-100 mb-2"
                       href="@Url.Action("Editar", "Auth", new { returnUrl = Url.Action("Resumo", "Carrinho") })">
                        Editar informações
                    </a>

                    <form class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="button" id="btnConfirmaModal" class="btn btn-confirm">Confirmar</button>
                    </form>

                    <form asp-controller="Auth" asp-action="TrocarUsuario" method="post" class="text-center">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link small p-0">Não é você? Entrar com outro número</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cep-autocomplete.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
          // ===================== 1) Abrir o modal SEMPRE no load =====================
          const modalEl = document.getElementById('confirmModal');
          if (modalEl) {
            const confirmModal = new bootstrap.Modal(modalEl, { backdrop: 'static', keyboard: false });
            confirmModal.show();

            // Ao clicar "Confirmar": marca sessão e fecha modal
            document.getElementById('btnConfirmaModal')?.addEventListener('click', async function () {
              try {
                await fetch('@Url.Action("ConfirmarDados", "Carrinho")', {
                  method: 'POST',
                  headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                  }
                });
              } catch (e) {
                // ignora erro e fecha mesmo assim
              }
              confirmModal.hide();
            });
          }

          // ===================== 2) Totais (retirada/entrega) =====================
          const retiradaChk       = document.getElementById('retiradaLocal');
          const containerEntrega  = document.getElementById('containerEntrega');
          const taxaEntregaLabel  = document.getElementById('taxaEntregaLabel');
          const totalGeralLabel   = document.getElementById('totalGeralLabel');
          const subtotal          = parseFloat('@Model.Carrinho.Total.ToString(System.Globalization.CultureInfo.InvariantCulture)');
          const taxaPadrao        = 5;

          function atualizarTotais() {
            if (!taxaEntregaLabel || !totalGeralLabel) return;
            const retirada = !!retiradaChk?.checked;
            const taxa = retirada ? 0 : taxaPadrao;

            taxaEntregaLabel.textContent = taxa.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            const total = subtotal + taxa;
            totalGeralLabel.textContent = total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

            if (containerEntrega) {
              if (retirada) containerEntrega.classList.add('d-none');
              else {
                containerEntrega.classList.remove('d-none');
                containerEntrega.classList.add('animate__animated', 'animate__fadeIn');
              }
            }
          }
          retiradaChk?.addEventListener('change', atualizarTotais);
          atualizarTotais();

          // ===================== 3) Select de endereço → detalhamento =====================
          const selectEndereco = document.getElementById('enderecoSelect');
          const detalhes       = document.getElementById('enderecoDetalhes');

          selectEndereco?.addEventListener('change', function () {
            const opt = this.selectedOptions[0];
            if (!opt || !detalhes) return;

            const log       = opt.getAttribute('data-logradouro')  || '';
            const num       = opt.getAttribute('data-numero')      || '';
            const comp      = opt.getAttribute('data-complemento') || '';
            const bai       = opt.getAttribute('data-bairro')      || '';
            const cid       = opt.getAttribute('data-cidade')      || '';
            const uf        = opt.getAttribute('data-estado')      || '';
            const cep       = opt.getAttribute('data-cep')         || '';
            const principal = opt.getAttribute('data-principal') === 'true';

            detalhes.innerHTML = `
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="mb-0 d-flex align-items-center gap-2">
                  <i class="bi bi-house-check text-orange"></i>
                  <span>Endereço selecionado</span>
                  ${principal ? '<span class="badge bg-orange-soft">Principal</span>' : ''}
                </h6>
                <small class="text-muted">CEP: ${cep}</small>
              </div>
              <div class="address-details">
                <div>${log}${log && num ? ', ' : ''}${num}</div>
                ${comp ? `<div>${comp}</div>` : ''}
                <div>${bai} - ${cid}/${uf}</div>
              </div>`;
            detalhes.classList.remove('empty');
          });

          // ===================== 4) CEP: botão "Buscar" do modal =====================
          document.getElementById('buscarCepBtn')?.addEventListener('click', function () {
            const modalCep = document.querySelector('#formEnderecoModal [data-cep]');
            if (modalCep) modalCep.dispatchEvent(new Event('blur'));
          });

          // ===================== 5) Habilitar/Desabilitar botão Editar + Prefill modal =====================
          const btnEditarEndereco = document.getElementById('btnEditarEndereco');

          function toggleEditar() {
            if (!btnEditarEndereco) return;
            const hasValue = !!selectEndereco?.value;
            btnEditarEndereco.disabled = !hasValue;
          }
          selectEndereco?.addEventListener('change', toggleEditar);
          toggleEditar();

          const editarModal = document.getElementById('editarEnderecoModal');
          editarModal?.addEventListener('show.bs.modal', function () {
            const opt = selectEndereco?.selectedOptions[0];
            if (!opt) return;

            (document.getElementById('edit_Id')          || {}).value = opt.value;
            (document.getElementById('edit_Logradouro')  || {}).value = opt.getAttribute('data-logradouro')  || '';
            (document.getElementById('edit_Numero')      || {}).value = opt.getAttribute('data-numero')      || '';
            (document.getElementById('edit_Complemento') || {}).value = opt.getAttribute('data-complemento') || '';
            (document.getElementById('edit_Bairro')      || {}).value = opt.getAttribute('data-bairro')      || '';
            (document.getElementById('edit_Cidade')      || {}).value = opt.getAttribute('data-cidade')      || '';
            (document.getElementById('edit_Estado')      || {}).value = (opt.getAttribute('data-estado') || '').toUpperCase();
            (document.getElementById('edit_CEP')         || {}).value = opt.getAttribute('data-cep')         || '';

            const principal = opt.getAttribute('data-principal') === 'true';
            const chk = document.getElementById('edit_Principal');
            if (chk) chk.checked = principal;
          });

          // ===================== 6) Validação antes de enviar o formulário =====================
          const formFinalizar = document.getElementById('formFinalizar');
          formFinalizar?.addEventListener('submit', function (e) {
            if (!retiradaChk?.checked && !selectEndereco?.value) {
              e.preventDefault();
              alert('Por favor, selecione um endereço de entrega ou marque "Retirar no local"');
            }
          });
        });
    </script>
}

