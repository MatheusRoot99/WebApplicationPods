                        </form>

                        <a class="btn btn-outline-warning btn-confirm" href="@Url.Action("Editar", "Auth", new { returnUrl = Url.Action("Resumo", "Carrinho") })">
                            Editar informações
                        </a>

                        <form asp-controller="Auth" asp-action="TrocarUsuario" method="post" class="text-center">
                            @Html.AntiForgeryToken()
