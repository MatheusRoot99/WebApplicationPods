@model WebApplicationPods.Models.ResumoPedidoViewModel

@{
    ViewData["Title"] = "Resumo do Pedido";
}
<link rel="stylesheet" href="~/css/carrinho.css" asp-append-version="true" />

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    @if (Model?.Carrinho?.Itens?.Any() == true)
    {
        <div class="row">
            <div class="col-md-8">
                <!-- Seção de Cliente -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4>Dados do Cliente</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.Cliente != null)
                        {
                            <p><strong>Nome:</strong> @Model.Cliente.Nome</p>
                            <p><strong>Telefone:</strong> @Model.Cliente.Telefone</p>
                            <p><strong>Email:</strong> @Model.Cliente.Email</p>
                        }
                        else
                        {
                            <p class="text-danger">Dados do cliente não disponíveis</p>
                        }
                    </div>
                </div>

                <!-- Seção de Endereço -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4>Endereço de Entrega</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.EnderecoEntrega != null)
                        {
                            <p>@Model.EnderecoEntrega.Logradouro, @Model.EnderecoEntrega.Numero</p>
                            @if (!string.IsNullOrEmpty(Model.EnderecoEntrega.Complemento))
                            {
                                <p>@Model.EnderecoEntrega.Complemento</p>
                            }
                            <p>@Model.EnderecoEntrega.Bairro - @Model.EnderecoEntrega.Cidade/@Model.EnderecoEntrega.Estado</p>
                            <p>CEP: @Model.EnderecoEntrega.CEP</p>
                        }
                        else
                        {
                            <p class="text-danger">Nenhum endereço de entrega disponível</p>
                            <a asp-controller="Cliente" asp-action="AdicionarEndereco" class="btn btn-sm btn-primary">
                                Adicionar Endereço
                            </a>
                        }
                    </div>
                </div>

                <!-- Restante do código da view... -->
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            Seu carrinho está vazio. <a asp-action="Index">Voltar ao carrinho</a>
        </div>
    }
</div>