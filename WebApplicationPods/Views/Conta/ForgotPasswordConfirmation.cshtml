@{
    ViewData["Title"] = "E-mail enviado";
}

@section Styles {
    <style>
        :root {
            --brand-start: #6a11cb;
            --brand-end: #2575fc;
            --bg: #f5f5f7;
        }

        body {
            background: var(--bg);
        }

        .auth-shell {
            width: min(90vw, 1000px);
            min-height: 70vh;
            margin-inline: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .auth-card {
            width: 100%;
            max-width: 720px;
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            box-shadow: 0 14px 32px rgba(0,0,0,.08);
            overflow: hidden;
        }

        .auth-head {
            background: linear-gradient(135deg,var(--brand-start) 0%,var(--brand-end) 100%);
            color: #fff;
            padding: 1.1rem 1.25rem;
        }

        .auth-body {
            padding: 1.5rem;
        }

        .lead {
            font-size: 1.05rem;
            color: #374151;
        }
        @@media (max-width:575.98px) {
            .auth-body

        {
            padding: 1rem;
        }

        }
    </style>
}

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-head d-flex align-items-center gap-2">
            <i class="fa-solid fa-paper-plane"></i>
            <h2 class="h5 mb-0">E-mail enviado</h2>
        </div>

        <div class="auth-body">
            <p class="lead mb-3">
                Se o e-mail informado existir no sistema, enviamos as instruções para redefinir sua senha.
            </p>
            <ul class="mb-4 text-muted">
                <li>Verifique a caixa de entrada e também a pasta de spam.</li>
                <li>O link expira após algum tempo por segurança.</li>
            </ul>

            <div class="d-flex gap-2">
                <a asp-controller="Conta" asp-action="Login" class="btn btn-primary">
                    Voltar ao login
                </a>
                <a asp-controller="Conta" asp-action="ForgotPassword" class="btn btn-outline-secondary">
                    Informei o e-mail errado
                </a>
            </div>
        </div>
    </div>
</div>
