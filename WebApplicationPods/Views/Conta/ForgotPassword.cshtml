@model WebApplicationPods.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Esqueci minha senha";
}

@section Styles {
    <style>
        :root {
            --brand-start: #6a11cb; /* roxo */
            --brand-end: #2575fc; /* azul */
            --bg: #f5f5f7;
        }

        body {
            background: var(--bg);
        }

        .auth-shell {
            width: min(90vw, 1000px);
            min-height: 90vh;
            margin-inline: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .auth-card {
            width: 100%;
            max-width: 720px;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            box-shadow: 0 14px 32px rgba(0,0,0,.08);
            overflow: hidden;
            background: #fff;
        }

        .auth-head {
            background: linear-gradient(135deg,var(--brand-start) 0%,var(--brand-end) 100%);
            color: #fff;
            padding: 1.1rem 1.25rem;
        }

        .auth-body {
            padding: 1.5rem;
        }

        .form-control:focus {
            border-color: var(--brand-end);
            box-shadow: 0 0 0 .2rem rgba(37,117,252,.25);
        }

        .input-group-text {
            background: #fff;
            border-right: 0;
        }

        .form-control.border-start-0 {
            border-left: 0;
        }

        .btn-brand {
            background: linear-gradient(135deg,var(--brand-start) 0%,var(--brand-end) 100%);
            border: 0;
            color: #fff;
            font-weight: 700;
        }

            .btn-brand:hover {
                filter: brightness(1.03);
                box-shadow: 0 10px 20px rgba(37,117,252,.25);
            }

        .helper {
            color: #6b7280;
            font-size: .9rem;
        }
        @@media (max-width: 575.98px) {
            .auth-body

        {
            padding: 1rem;
        }

        }
    </style>
}

<div class="auth-shell">
    <div class="auth-card">

        <div class="auth-head d-flex align-items-center gap-2">
            <i class="fa-solid fa-envelope-circle-check"></i>
            <h2 class="h5 mb-0">Esqueci minha senha</h2>
        </div>

        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <form asp-action="ForgotPassword" method="post" asp-antiforgery="true" novalidate id="fp-form">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-mail</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-at"></i></span>
                        <input asp-for="Email"
                               type="email"
                               class="form-control border-start-0"
                               autocomplete="email"
                               placeholder="seu@email.com"
                               required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                    <div class="helper mt-2">Enviaremos um link de redefinição se encontrarmos sua conta.</div>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2" id="fp-submit">
                    Enviar e-mail de redefinição
                </button>

                <div class="d-flex justify-content-between mt-3 small">
                    <a asp-controller="Conta" asp-action="Login"><i class="fa-solid fa-arrow-left-long me-1"></i>Voltar ao login</a>
                    @* <a asp-controller="Conta" asp-action="Registrar">Criar conta</a> *@
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Evita múltiplos envios
        document.getElementById('fp-form')?.addEventListener('submit', function(){
          const btn = document.getElementById('fp-submit');
          if(btn){
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Enviando...';
          }
        });
    </script>
}
