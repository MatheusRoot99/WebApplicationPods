@model WebApplicationPods.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["HideChrome"] = true;
    ViewData["BodyClass"] = "auth-page";

    var scheme = Context.Request.Scheme;
    var port = Context.Request.Host.Port;
    var portPart = port.HasValue ? $":{port.Value}" : "";
    var adminUrl = $"{scheme}://admin.lvh.me{portPart}/Conta/Login";
    var painelUrl = $"{scheme}://painel.lvh.me{portPart}/Conta/Login";
    var lojaUrl = $"{scheme}://loja-1.lvh.me{portPart}/";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-shell">
    <div class="auth-wrap">
        <div class="auth-grid">

            <aside class="auth-left">
                <div class="brand-pill">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <span>Plataforma multi-loja</span>
                </div>

                <div class="auth-title">Acesse seu painel.</div>
                <div class="auth-sub">
                    Entre com <strong>CPF, telefone ou e-mail</strong>.
                    O sistema identifica seu perfil e direciona para <strong>Admin</strong> ou <strong>Lojista</strong>.
                </div>

                <ul class="benefits">
                    <li>
                        <i class="fa-solid fa-user-shield"></i>
                        <div>
                            <strong>Admin central</strong>
                            <small>Crie lojas, vincule lojistas e acompanhe a plataforma.</small>
                        </div>
                    </li>
                    <li>
                        <i class="fa-solid fa-store"></i>
                        <div>
                            <strong>Painel do lojista</strong>
                            <small>Gerencie produtos, estoque, pedidos e configurações da loja.</small>
                        </div>
                    </li>
                    <li>
                        <i class="fa-solid fa-link"></i>
                        <div>
                            <strong>Subdomínios por loja</strong>
                            <small>Cada loja possui contexto automático pelo endereço.</small>
                        </div>
                    </li>
                </ul>

                <div class="dev-links">
                    <a href="@adminUrl"><i class="fa-solid fa-user-shield me-1"></i> Admin</a>
                    <a href="@painelUrl"><i class="fa-solid fa-store me-1"></i> Lojista</a>
                    <a href="@lojaUrl" target="_blank" rel="noopener"><i class="fa-solid fa-cart-shopping me-1"></i> Loja</a>
                </div>

                <div class="hint">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    Use <code>admin.lvh.me</code> ou <code>painel.lvh.me</code> no desenvolvimento.
                </div>
            </aside>

            <section class="login-card">
                <div class="login-head">
                    <div class="title">
                        <i class="fa-solid fa-right-to-bracket"></i>
                        <h2 class="h5 mb-0">Entrar</h2>
                    </div>

                    <button type="button" class="theme-toggle" id="themeToggle" aria-label="Alternar tema" title="Alternar tema">
                        <i class="fa-solid fa-moon" id="themeIcon"></i>
                    </button>
                </div>

                <div class="login-body">
                    <form asp-action="Login" method="post" asp-antiforgery="true" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="alert-validation mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="TelefoneOuCpf" class="form-label">Telefone, CPF ou e-mail</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-id-card"></i></span>
                                <input asp-for="TelefoneOuCpf"
                                       class="form-control"
                                       placeholder="Ex.: 11999999999 ou 123.456.789-00"
                                       autocomplete="username"
                                       id="login-credential" />
                            </div>
                            <span asp-validation-for="TelefoneOuCpf" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Senha" class="form-label">Senha</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                <input asp-for="Senha"
                                       class="form-control"
                                       type="password"
                                       autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="Senha" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3 login-links">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="LembrarMe" id="lembrar" />
                                <label class="form-check-label" for="lembrar">Lembrar-me</label>
                            </div>

                            <a id="forgot-link"
                               class="muted-link disabled small"
                               href="#"
                               aria-disabled="true"
                               title="Digite uma credencial válida para habilitar">
                                Esqueci minha senha
                            </a>
                        </div>

                        <button type="submit" class="btn btn-brand w-100 py-2">
                            Entrar
                        </button>

                        <div class="small-note mt-3">
                            Se você for lojista, o acesso é liberado apenas para a loja vinculada ao seu usuário.
                        </div>
                    </form>
                </div>
            </section>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
          const root = document.documentElement;
          const btn = document.getElementById('themeToggle');
          const icon = document.getElementById('themeIcon');

          function apply(theme) {
            if (!theme) root.removeAttribute('data-theme');
            else root.setAttribute('data-theme', theme);

            const isDark =
              (root.getAttribute('data-theme') === 'dark') ||
              (!root.getAttribute('data-theme') && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);

            if (icon) icon.className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
            if (btn) btn.title = isDark ? 'Mudar para claro' : 'Mudar para escuro';
          }

          const saved = localStorage.getItem('auth_theme'); // 'dark' | 'light' | null
          if (saved === 'dark' || saved === 'light') apply(saved);
          else apply(null);

          if (btn) {
            btn.addEventListener('click', () => {
              const current = root.getAttribute('data-theme');
              const next = current === 'dark' ? 'light' : 'dark';
              localStorage.setItem('auth_theme', next);
              apply(next);
            });
          }
        })();
    </script>

    <script>
        (function(){
          const input = document.getElementById('login-credential');
          const forgot = document.getElementById('forgot-link');
          const baseUrl = '@Url.Action("ForgotPassword", "Conta")';
          const checkUrl = '@Url.Action("CheckAccount", "Conta")';
          let timer;

          function setForgot(enabled, email){
            if(enabled){
              forgot.classList.remove('disabled');
              forgot.removeAttribute('aria-disabled');
              const param = email || input.value;
              forgot.href = baseUrl + '?email=' + encodeURIComponent(param);
              forgot.title = 'Recuperar acesso';
            }else{
              forgot.classList.add('disabled');
              forgot.setAttribute('aria-disabled','true');
              forgot.href = '#';
              forgot.title = 'Digite uma credencial válida para habilitar';
            }
          }

          async function check(){
            const val = (input.value || '').trim();
            if(!val){ setForgot(false); return; }
            try{
              const r = await fetch(checkUrl + '?input=' + encodeURIComponent(val), { cache: 'no-store' });
              if(!r.ok){ setForgot(false); return; }
              const data = await r.json();
              setForgot(!!data.exists, data.email);
            }catch{
              setForgot(false);
            }
          }

          input.addEventListener('input', () => {
            clearTimeout(timer);
            timer = setTimeout(check, 250);
          });
          input.addEventListener('blur', check);

          setForgot(false);
        })();
    </script>
}
