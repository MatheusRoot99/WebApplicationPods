@model IEnumerable<WebApplicationPods.Models.ApplicationUser>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Lojistas";
}
<h2>Lojistas</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<p><a class="btn btn-success" asp-action="Create">Novo Lojista</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Nome</td>
                <td>@u.CPF</td>
                <td>@u.PhoneNumber</td>
                <td>@u.Email</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@u.Id">Editar</a>

                    <form asp-action="ResetSenha" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@u.Id" />
                        <input class="form-control form-control-sm d-inline w-auto" name="novaSenha" placeholder="Nova senha" />
                        <button class="btn btn-sm btn-warning" type="submit">Resetar Senha</button>
                    </form>

                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Remover lojista?');">
                        <input type="hidden" name="id" value="@u.Id" />
                        <button class="btn btn-sm btn-danger">Excluir</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
