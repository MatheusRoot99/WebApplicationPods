@using WebApplicationPods.Models
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@model PedidosAdminIndexViewModel

@{
    ViewData["Title"] = "Pedidos";

    var filtro = Model.Filtros?.Filtro ?? "abertos";
    var tableUrl = Url.Action("Table", "PedidosAdmin", new
    {
        filtro = Model.Filtros?.Filtro,
        q = Model.Filtros?.Q,
        pedidoId = Model.Filtros?.PedidoId,
        telefone = Model.Filtros?.Telefone,
        status = Model.Filtros?.Status,
        entregadorId = Model.Filtros?.EntregadorId,
        dataInicial = Model.Filtros?.DataInicial?.ToString("yyyy-MM-dd"),
        dataFinal = Model.Filtros?.DataFinal?.ToString("yyyy-MM-dd")
    });
    var afToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;

    var temFiltrosAtivos =
        !string.IsNullOrWhiteSpace(Model.Filtros?.Q) ||
        Model.Filtros?.PedidoId.HasValue == true ||
        !string.IsNullOrWhiteSpace(Model.Filtros?.Telefone) ||
        !string.IsNullOrWhiteSpace(Model.Filtros?.Status) ||
        Model.Filtros?.EntregadorId.HasValue == true ||
        Model.Filtros?.DataInicial.HasValue == true ||
        Model.Filtros?.DataFinal.HasValue == true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/orders-admin.css" asp-append-version="true" />
}

<meta name="request-verification-token" content="@afToken" />

<div class="container-fluid mt-3 mt-md-4 orders-admin" id="ordersRoot" data-table-url="@tableUrl">

    <div class="orders-topbar header-row d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
        <div class="d-flex flex-column gap-1">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <h2 class="m-0">Pedidos @Model.ModoTitulo</h2>
                <span class="pill-badge d-none d-md-inline">Live</span>
                <span class="results-badge">@Model.TotalEncontrado encontrado(s)</span>
            </div>
            <div class="orders-subtext">
                Gestão mais forte do pedido: busca por cliente, telefone, número, status, data e entregador.
            </div>
        </div>

        <div class="d-flex flex-wrap align-items-center gap-2">
            <div class="btn-group mode-switch" role="group" aria-label="Modo da listagem">
                <a class="btn btn-outline-secondary @(filtro == "abertos" ? "active" : "")"
                   asp-action="Index"
                   asp-route-filtro="abertos"
                   asp-route-q="@Model.Filtros?.Q"
                   asp-route-pedidoId="@Model.Filtros?.PedidoId"
                   asp-route-telefone="@Model.Filtros?.Telefone"
                   asp-route-status="@Model.Filtros?.Status"
                   asp-route-entregadorId="@Model.Filtros?.EntregadorId"
                   asp-route-dataInicial="@Model.Filtros?.DataInicial?.ToString("yyyy-MM-dd")"
                   asp-route-dataFinal="@Model.Filtros?.DataFinal?.ToString("yyyy-MM-dd")">
                    Abertos
                </a>
                <a class="btn btn-outline-secondary @(filtro == "dia" ? "active" : "")"
                   asp-action="Index"
                   asp-route-filtro="dia"
                   asp-route-q="@Model.Filtros?.Q"
                   asp-route-pedidoId="@Model.Filtros?.PedidoId"
                   asp-route-telefone="@Model.Filtros?.Telefone"
                   asp-route-status="@Model.Filtros?.Status"
                   asp-route-entregadorId="@Model.Filtros?.EntregadorId"
                   asp-route-dataInicial="@Model.Filtros?.DataInicial?.ToString("yyyy-MM-dd")"
                   asp-route-dataFinal="@Model.Filtros?.DataFinal?.ToString("yyyy-MM-dd")">
                    Hoje
                </a>
                <a class="btn btn-outline-secondary @(filtro == "todos" ? "active" : "")"
                   asp-action="Index"
                   asp-route-filtro="todos"
                   asp-route-q="@Model.Filtros?.Q"
                   asp-route-pedidoId="@Model.Filtros?.PedidoId"
                   asp-route-telefone="@Model.Filtros?.Telefone"
                   asp-route-status="@Model.Filtros?.Status"
                   asp-route-entregadorId="@Model.Filtros?.EntregadorId"
                   asp-route-dataInicial="@Model.Filtros?.DataInicial?.ToString("yyyy-MM-dd")"
                   asp-route-dataFinal="@Model.Filtros?.DataFinal?.ToString("yyyy-MM-dd")">
                    Todos
                </a>
            </div>

            @if (filtro == "dia")
            {
                <a class="btn btn-brand btn-sm"
                   asp-controller="PedidosAdmin" asp-action="Relatorio"
                   asp-route-modo="dia" asp-route-data="@DateTime.Today.ToString("yyyy-MM-dd")">
                    Relatório (hoje)
                </a>
            }
            else
            {
                <a class="btn btn-outline-brand btn-sm"
                   asp-controller="PedidosAdmin" asp-action="Relatorio"
                   asp-route-modo="mes" asp-route-ano="@DateTime.Today.Year" asp-route-mes="@DateTime.Today.Month">
                    Relatório (mês atual)
                </a>
            }
        </div>
    </div>

    <form method="get" asp-controller="PedidosAdmin" asp-action="Index" class="orders-filters-card mb-3">
        <input type="hidden" name="filtro" value="@filtro" />

        <div class="filters-grid">
            <div class="filter-field filter-field-wide">
                <label for="FiltroQ" class="form-label">Busca geral</label>
                <input id="FiltroQ"
                       name="Q"
                       type="search"
                       class="form-control"
                       value="@Model.Filtros?.Q"
                       placeholder="Cliente, e-mail, telefone, status ou entregador" />
            </div>

            <div class="filter-field">
                <label for="PedidoId" class="form-label">Pedido</label>
                <input id="PedidoId"
                       name="PedidoId"
                       type="number"
                       min="1"
                       class="form-control"
                       value="@Model.Filtros?.PedidoId"
                       placeholder="# do pedido" />
            </div>

            <div class="filter-field">
                <label for="Telefone" class="form-label">Telefone</label>
                <input id="Telefone"
                       name="Telefone"
                       type="text"
                       class="form-control"
                       value="@Model.Filtros?.Telefone"
                       placeholder="(xx) xxxxx-xxxx" />
            </div>

            <div class="filter-field">
                <label for="Status" class="form-label">Status</label>
                <select id="Status" name="Status" class="form-select">
                    <option value="">Todos os status</option>
                    @foreach (var item in Model.StatusOptions)
                    {
                        if (string.Equals(item.Value, Model.Filtros?.Status, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-field">
                <label for="EntregadorId" class="form-label">Entregador</label>
                <select id="EntregadorId" name="EntregadorId" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var item in Model.Entregadores)
                    {
                        if (item.Value == Model.Filtros?.EntregadorId?.ToString())
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-field">
                <label for="DataInicial" class="form-label">De</label>
                <input id="DataInicial"
                       name="DataInicial"
                       type="date"
                       class="form-control"
                       value="@Model.Filtros?.DataInicial?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="filter-field">
                <label for="DataFinal" class="form-label">Até</label>
                <input id="DataFinal"
                       name="DataFinal"
                       type="date"
                       class="form-control"
                       value="@Model.Filtros?.DataFinal?.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="filters-actions">
            <button type="submit" class="btn btn-brand btn-sm">Aplicar filtros</button>
            <a class="btn btn-outline-secondary btn-sm"
               asp-action="Index"
               asp-route-filtro="@filtro">
                Limpar filtros
            </a>

            @if (temFiltrosAtivos)
            {
                <span class="filters-active-note">Filtros ativos nesta listagem.</span>
            }
        </div>
    </form>

    <div class="status-legend mb-3">
        <span class="legend-item"><i class="dot dot-info"></i> Aguardando</span>
        <span class="legend-item"><i class="dot dot-primary"></i> Em Preparo</span>
        <span class="legend-item"><i class="dot dot-warning"></i> Pronto</span>
        <span class="legend-item"><i class="dot dot-secondary"></i> Saiu p/ Entrega</span>
        <span class="legend-item"><i class="dot dot-dark"></i> Entregue</span>
        <span class="legend-item"><i class="dot dot-danger"></i> Cancelado</span>
    </div>

    <div class="table-container">
        <table class="table table-striped align-middle mb-0 responsive-table" id="ordersTable">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Data</th>
                    <th>Total</th>
                    <th>Pagamento</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody id="tbodyPedidos">
                @await Html.PartialAsync("~/Views/PedidosAdmin/_PedidosTableBody.cshtml", Model.Pedidos)
            </tbody>
        </table>
    </div>

    <template id="row-skeleton">
        <tr class="row-skeleton">
            <td colspan="6">
                <div class="sk-wrap">
                    <div class="sk-line w-25"></div>
                    <div class="sk-line w-50"></div>
                    <div class="sk-line w-75"></div>
                </div>
            </td>
        </tr>
    </template>

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100"></div>
</div>

@section Scripts {
    <script src="~/js/orders-admin.js" asp-append-version="true"></script>

    <script>
        window.__ORDERS_ADMIN__.boot({
            tableUrl: '@tableUrl',
            highlightFromQueryString: true
        });
    </script>
}