@using WebApplicationPods.Models
@using System.Linq
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@model IEnumerable<PedidoModel>

@{
    // Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Pedidos";

    var filtro = (string)(ViewBag.Filtro ?? "abertos");
    var tableUrl = Url.Action("Table", "PedidosAdmin", new { filtro });
    var afToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

@section Styles {
    <link rel="stylesheet" href="~/css/orders-admin.css" asp-append-version="true" />
}

<!-- Token anti-CSRF para o fetch -->
<meta name="request-verification-token" content="@afToken" />

<div class="container mt-4 orders-admin" id="ordersRoot" data-table-url="@tableUrl">

    <!-- Topbar / Filtros / Busca -->
    <div class="orders-topbar header-row d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="d-flex align-items-center gap-2">
            <h2 class="m-0">Pedidos (@(filtro == "dia" ? "de hoje" : "abertos"))</h2>
            <span class="pill-badge d-none d-md-inline">Live</span>
        </div>

        <div class="d-flex flex-wrap align-items-center gap-2">
            <div class="btn-group" role="group" aria-label="Filtros">
                <a class="btn btn-outline-secondary @(filtro == "abertos" ? "active" : "")"
                   asp-action="Index" asp-route-filtro="abertos">Abertos</a>
                <a class="btn btn-outline-secondary @(filtro == "dia" ? "active" : "")"
                   asp-action="Index" asp-route-filtro="dia">Hoje</a>
            </div>

            <div class="vr d-none d-md-block"></div>

            <div class="input-group input-group-sm quick-search">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="qPedidos" type="search" class="form-control"
                       placeholder="Buscar por cliente, método, status..." autocomplete="off" />
            </div>

            <!-- Relatórios -->
            @if (filtro == "dia")
            {
                <a class="btn btn-brand btn-sm"
                   asp-controller="PedidosAdmin" asp-action="Relatorio"
                   asp-route-modo="dia" asp-route-data="@DateTime.Today.ToString("yyyy-MM-dd")">
                    Relatório (hoje)
                </a>
            }
            else
            {
                <a class="btn btn-outline-brand btn-sm"
                   asp-controller="PedidosAdmin" asp-action="Relatorio"
                   asp-route-modo="mes" asp-route-ano="@DateTime.Today.Year" asp-route-mes="@DateTime.Today.Month">
                    Relatório (mês atual)
                </a>
            }
        </div>
    </div>

    <!-- Legenda de status -->
    <div class="status-legend mb-3">
        <span class="legend-item"><i class="dot dot-info"></i> Aguardando</span>
        <span class="legend-item"><i class="dot dot-primary"></i> Em Preparo</span>
        <span class="legend-item"><i class="dot dot-warning"></i> Pronto</span>
        <span class="legend-item"><i class="dot dot-secondary"></i> Saiu p/ Entrega</span>
        <span class="legend-item"><i class="dot dot-dark"></i> Entregue</span>
        <span class="legend-item"><i class="dot dot-danger"></i> Cancelado</span>
    </div>

    <!-- Tabela -->
    <div class="table-container">
        <table class="table table-striped align-middle mb-0 responsive-table" id="ordersTable">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Data</th>
                    <th>Total</th>
                    <th>Pagamento</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody id="tbodyPedidos">
                @await Html.PartialAsync("~/Views/PedidosAdmin/_PedidosTableBody.cshtml", Model)
            </tbody>
        </table>
    </div>

    <!-- Skeleton -->
    <template id="row-skeleton">
        <tr class="row-skeleton">
            <td colspan="6">
                <div class="sk-wrap">
                    <div class="sk-line w-25"></div>
                    <div class="sk-line w-50"></div>
                    <div class="sk-line w-75"></div>
                </div>
            </td>
        </tr>
    </template>

    <!-- Toasts -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100"></div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script src="~/js/orders-admin.js" asp-append-version="true"></script>

    <script>
        window.__ORDERS_ADMIN__.boot({
            tableUrl: '@tableUrl',
            highlightFromQueryString: true
        });
    </script>
}
