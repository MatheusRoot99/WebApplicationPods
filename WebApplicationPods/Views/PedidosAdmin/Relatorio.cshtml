@model WebApplicationPods.DTO.ReportsDTO.AdminReportViewModel
@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Relatório de Vendas";

    // dados p/ JS
    var serieJson = JsonSerializer.Serialize(Model.SeriePorDia.Select(s => new { dia = s.Dia.ToString("yyyy-MM-dd"), qtd = s.Quantidade, total = s.Total }));
    var metodosJson = JsonSerializer.Serialize(Model.Metodos.Select(m => new { metodo = m.Metodo, qtd = m.Quantidade, total = m.Total }));
    var topJson = JsonSerializer.Serialize(Model.TopClientes.Select(c => new { nome = c.Nome ?? ("#" + c.ClienteId), qtd = c.Quantidade, total = c.Total }));

    // filtros atuais
    var qs = ViewContext.HttpContext.Request.Query;
    var hoje = DateTime.Today;
    var modoSel = (qs["modo"].ToString() ?? "dia").ToLowerInvariant();
    var dataSel = qs["data"].ToString();
    var anoSel = qs["ano"].ToString();
    var mesSel = qs["mes"].ToString();
}

@section Styles {
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
}

<div class="container py-3 page-pad">
    <div class="toolbar d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
        <h2>Relatório — @Model.PeriodoDescricao</h2>

        <form method="get" class="row gx-2 gy-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">Modo</label>
                <select class="form-select" name="modo" id="selModo">
                    @if (modoSel == "dia")
                    {
                        <option value="dia" selected>Dia</option>
                        <option value="mes">Mês</option>
                    }
                    else
                    {
                        <option value="dia">Dia</option>
                        <option value="mes" selected>Mês</option>
                    }
                </select>
            </div>

            <div class="col-auto" id="grpDia" style="display:@(modoSel == "dia" ? "block" : "none")">
                <label class="form-label">Data</label>
                <input class="form-control" type="date" name="data"
                       value="@(string.IsNullOrEmpty(dataSel) ? DateTime.Today.ToString("yyyy-MM-dd") : dataSel)" />
            </div>

            <div class="col-auto" id="grpMes" style="display:@(modoSel == "mes" ? "block" : "none")">
                <label class="form-label">Ano</label>
                <input class="form-control" type="number" name="ano" min="2000" max="2100"
                       value="@(string.IsNullOrEmpty(anoSel) ? hoje.Year.ToString() : anoSel)" />
            </div>

            <div class="col-auto" id="grpMes2" style="display:@(modoSel == "mes" ? "block" : "none")">
                <label class="form-label">Mês</label>
                <input class="form-control" type="number" name="mes" min="1" max="12"
                       value="@(string.IsNullOrEmpty(mesSel) ? hoje.Month.ToString() : mesSel)" />
            </div>

            <div class="col-auto">
                <button class="btn btn-brand">Aplicar</button>
            </div>
        </form>
    </div>

    <!-- KPIs -->
    <div class="row g-3">
        <div class="col-md-3 kpi">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Pedidos Recebidos</div>
                    <div class="h3 mb-0">@Model.Resumo.Recebidos</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 kpi">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Pedidos Pagos</div>
                    <div class="h3 mb-0">@Model.Resumo.Pagos</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 kpi">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Taxa de Conversão</div>
                    @{
                        var conv = Model.Resumo.Recebidos > 0
                        ? (decimal)Model.Resumo.Pagos / Model.Resumo.Recebidos * 100m
                        : 0m;
                    }
                    <div class="h3 mb-0">@conv.ToString("0.0")%</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 kpi">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Total Vendido</div>
                    <div class="h3 mb-0">@Model.Resumo.TotalVendido.ToString("C")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row g-3 mt-1">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Pedidos e Faturamento por Dia</div>
                <div class="card-body">
                    <div class="chart-wrap h320">
                        <canvas id="chartSerie"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Formas de Pagamento</div>
                <div class="card-body">
                    <div class="chart-wrap h260">
                        <canvas id="chartMetodos"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Clientes -->
    <div class="card mt-3">
        <div class="card-header">Top Clientes</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Cliente</th>
                            <th class="text-end">Pedidos</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.TopClientes)
                        {
                            <tr>
                                <td>@(string.IsNullOrWhiteSpace(c.Nome) ? ("#" + c.ClienteId) : c.Nome)</td>
                                <td class="text-end">@c.Quantidade</td>
                                <td class="text-end">@c.Total.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
          // ==============================
          // Alterna campos do filtro (Dia/Mês)
          // ==============================
          const sel = document.getElementById('selModo');
          if (sel) {
            sel.addEventListener('change', function () {
              const isMes = this.value === 'mes';
              const grpDia = document.getElementById('grpDia');
              const grpMes = document.getElementById('grpMes');
              const grpMes2 = document.getElementById('grpMes2');

              if (grpDia)  grpDia.style.display  = isMes ? 'none'  : 'block';
              if (grpMes)  grpMes.style.display  = isMes ? 'block' : 'none';
              if (grpMes2) grpMes2.style.display = isMes ? 'block' : 'none';
            });
          }

          // ==============================
          // Detecta tema (dark/light)
          // - funciona com data-theme no html OU classe no body
          // ==============================
          function isDarkMode() {
            const html = document.documentElement;
            const body = document.body;
            return (html && html.getAttribute('data-theme') === 'dark')
                || (body && body.classList.contains('theme-dark'))
                || (body && body.classList.contains('dark'))
                || false;
          }

          // ==============================
          // Lê tokens do CSS (site.css)
          // ==============================
          function cssVar(name, fallback) {
            const v = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
            return v || fallback;
          }

          function buildTheme() {
            const dark = isDarkMode();

            const primary = cssVar('--primary', '#2575fc');
            const text    = cssVar('--text', dark ? 'rgba(255,255,255,.88)' : 'rgba(17,24,39,.88)');
            const muted   = cssVar('--muted', dark ? 'rgba(255,255,255,.65)' : 'rgba(17,24,39,.60)');

            // grid/axis
            const grid = dark ? 'rgba(255,255,255,.10)' : 'rgba(17,24,39,.10)';
            const tick = muted;

            // tooltip
            const tooltipBg = dark ? 'rgba(17,24,39,.92)' : 'rgba(255,255,255,.96)';
            const tooltipBorder = dark ? 'rgba(255,255,255,.10)' : 'rgba(17,24,39,.12)';
            const tooltipTitle = dark ? 'rgba(255,255,255,.92)' : 'rgba(17,24,39,.92)';
            const tooltipBody  = dark ? 'rgba(255,255,255,.80)' : 'rgba(17,24,39,.75)';

            return { dark, primary, text, muted, grid, tick, tooltipBg, tooltipBorder, tooltipTitle, tooltipBody };
          }

          // ==============================
          // Dados vindos do Razor
          // ==============================
          const serie   = @Html.Raw(serieJson);
          const metodos = @Html.Raw(metodosJson);

          // ==============================
          // Helpers
          // ==============================
          function fmtBRL(n) {
            try {
              return (Number(n) || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            } catch {
              return 'R$ ' + (Number(n) || 0).toFixed(2);
            }
          }

          function applyChartDefaults(theme) {
            // defaults globais (Chart.js)
            Chart.defaults.color = theme.tick;
            Chart.defaults.font.family = 'system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';

            Chart.defaults.plugins.legend.labels.color = theme.tick;

            Chart.defaults.plugins.tooltip.backgroundColor = theme.tooltipBg;
            Chart.defaults.plugins.tooltip.borderColor = theme.tooltipBorder;
            Chart.defaults.plugins.tooltip.borderWidth = 1;
            Chart.defaults.plugins.tooltip.titleColor = theme.tooltipTitle;
            Chart.defaults.plugins.tooltip.bodyColor = theme.tooltipBody;
            Chart.defaults.plugins.tooltip.displayColors = true;
          }

          function makeLineChart(ctx, theme, labels, qtds, totais) {
            return new Chart(ctx, {
              type: 'line',
              data: {
                labels,
                datasets: [
                  {
                    label: 'Pedidos',
                    data: qtds,
                    yAxisID: 'y1',
                    tension: 0.25,
                    borderWidth: 2,
                    pointRadius: 2,
                    pointHoverRadius: 4
                  },
                  {
                    label: 'Faturamento',
                    data: totais,
                    yAxisID: 'y2',
                    tension: 0.25,
                    borderWidth: 2,
                    pointRadius: 2,
                    pointHoverRadius: 4
                  }
                ]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                  legend: { position: 'top' },
                  tooltip: {
                    callbacks: {
                      label: function (ctx) {
                        const label = ctx.dataset.label || '';
                        const v = ctx.parsed.y;

                        if (label.toLowerCase().includes('fatur')) {
                          return `${label}: ${fmtBRL(v)}`;
                        }
                        return `${label}: ${v}`;
                      }
                    }
                  }
                },
                scales: {
                  x: {
                    ticks: { autoSkip: true, maxRotation: 0, minRotation: 0, color: theme.tick },
                    grid: { color: theme.grid }
                  },
                  y1: {
                    type: 'linear',
                    position: 'left',
                    title: { display: true, text: 'Qtd', color: theme.tick },
                    ticks: { color: theme.tick, precision: 0 },
                    grid: { color: theme.grid }
                  },
                  y2: {
                    type: 'linear',
                    position: 'right',
                    title: { display: true, text: 'R$', color: theme.tick },
                    ticks: {
                      color: theme.tick,
                      callback: (v) => fmtBRL(v)
                    },
                    grid: { drawOnChartArea: false, color: theme.grid }
                  }
                }
              }
            });
          }

          function makeBarChart(ctx, theme, labels, qtds) {
            return new Chart(ctx, {
              type: 'bar',
              data: {
                labels,
                datasets: [
                  {
                    label: 'Pedidos',
                    data: qtds,
                    borderWidth: 1
                  }
                ]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                  legend: { display: true },
                  tooltip: {
                    callbacks: {
                      label: function (ctx) {
                        return `${ctx.dataset.label}: ${ctx.parsed.y}`;
                      }
                    }
                  }
                },
                scales: {
                  x: {
                    ticks: {
                      color: theme.tick,
                      autoSkip: true,
                      maxRotation: 0,
                      minRotation: 0,
                      callback: (v) => {
                        const t = labels[v] || '';
                        return t.length > 14 ? (t.slice(0, 14) + '…') : t;
                      }
                    },
                    grid: { color: theme.grid }
                  },
                  y: {
                    ticks: { color: theme.tick, precision: 0 },
                    grid: { color: theme.grid }
                  }
                }
              }
            });
          }

          // ==============================
          // Render
          // ==============================
          let theme = buildTheme();
          applyChartDefaults(theme);

          const serieLabels = serie.map(x => x.dia);
          const qtds = serie.map(x => x.qtd);
          const totais = serie.map(x => x.total);

          const metLabels = metodos.map(x => x.metodo);
          const metQtds = metodos.map(x => x.qtd);

          const elSerie = document.getElementById('chartSerie');
          const elMet   = document.getElementById('chartMetodos');

          let chartSerie = null;
          let chartMet   = null;

          if (elSerie) chartSerie = makeLineChart(elSerie, theme, serieLabels, qtds, totais);
          if (elMet)   chartMet   = makeBarChart(elMet, theme, metLabels, metQtds);

          // ==============================
          // Se o usuário trocar o tema, refaz os charts
          // (você pode disparar esse event quando alternar o modo)
          // document.dispatchEvent(new Event('theme:changed'));
          // ==============================
          function rebuild() {
            theme = buildTheme();
            applyChartDefaults(theme);

            if (chartSerie) { chartSerie.destroy(); chartSerie = null; }
            if (chartMet)   { chartMet.destroy(); chartMet = null; }

            if (elSerie) chartSerie = makeLineChart(elSerie, theme, serieLabels, qtds, totais);
            if (elMet)   chartMet   = makeBarChart(elMet, theme, metLabels, metQtds);
          }

          document.addEventListener('theme:changed', rebuild);

          // fallback: se você alterna tema apenas trocando atributo/classe
          // isso captura mudanças via MutationObserver
          const obs = new MutationObserver(() => {
            // reconstrói se realmente mudou
            const nowDark = isDarkMode();
            if (nowDark !== theme.dark) rebuild();
          });
          obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });
          if (document.body) obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });

        })();
    </script>
}

