@model WebApplicationPods.Models.PedidoAtribuirEntregadorViewModel

@{
    ViewData["Title"] = "Atribuir entregador";
}

<div class="container py-3">
    <div class="mb-3">
        <h2 class="mb-1">Atribuir entregador</h2>
        <p class="text-muted mb-0">Selecione quem ficará responsável pela entrega do pedido.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="AtribuirEntregador" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="PedidoId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Pedido</label>
                        <input class="form-control" value="@Model.PedidoId" disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Cliente</label>
                        <input class="form-control" value="@Model.ClienteNome" disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Status atual</label>
                        <input class="form-control" value="@Model.StatusAtual" disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Valor total</label>
                        <input class="form-control" value="@Model.ValorTotal.ToString("C")" disabled />
                    </div>

                    <div class="col-md-8">
                        <label asp-for="EntregadorId" class="form-label"></label>
                        <select asp-for="EntregadorId" asp-items="Model.Entregadores" class="form-select">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="EntregadorId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a asp-action="Detalhes" asp-route-id="@Model.PedidoId" class="btn btn-outline-secondary">Voltar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}