@model WebApplicationPods.Models.ClienteModel

@{
    ViewData["Title"] = "Cadastro Rápido";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="text-center">Complete seu cadastro</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CadastroRapido" method="post">
                        <input type="hidden" asp-for="Telefone" />
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div class="form-group">
                            <label asp-for="Nome"></label>
                            <input asp-for="Nome" class="form-control" required />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" type="email" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block mt-4">
                            Finalizar Cadastro
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>