@model WebApplicationPods.Models.CadastroRapidoViewModel

@{
    ViewData["Title"] = "Cadastro Rápido";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cadastro.css" asp-append-version="true" />
    <style>
        /* Apenas ajustes específicos de cor se necessário */
        :root {
            --brand-start: #6a11cb;
            --brand-end: #2575fc;
            --brand-end-25: rgba(37,117,252,.25);
        }
    </style>
}

<div class="cadastro-container">
    <div class="cadastro-card">
        <div class="card-header">
            <h1 class="card-title">Complete seu cadastro</h1>
            <p class="card-subtitle">Preencha os campos abaixo para finalizar seu cadastro</p>
        </div>

        <div class="card-body">
            <form asp-action="CadastroRapido" method="post" class="cadastro-form">
                <input type="hidden" asp-for="Telefone" />
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <!-- Seção de Dados Pessoais -->
                <fieldset class="form-section">
                    <legend class="section-title">Dados Pessoais</legend>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Nome" class="form-label"></label>
                            <input asp-for="Nome" class="form-control" required placeholder="Digite seu nome completo" />
                            <span asp-validation-for="Nome" class="validation-message"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="CPF" class="form-label"></label>
                            <input asp-for="CPF" id="cpf" class="form-control" placeholder="000.000.000-00" />
                            <span asp-validation-for="CPF" class="validation-message"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DataNascimento" class="form-label"></label>
                            <input asp-for="DataNascimento" id="dob" class="form-control" type="date" />
                            <span asp-validation-for="DataNascimento" class="validation-message"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" type="email" required placeholder="exemplo@email.com" />
                            <span asp-validation-for="Email" class="validation-message"></span>
                        </div>
                    </div>
                </fieldset>

                <!-- Seção de Endereço -->
                <fieldset class="form-section">
                    <legend class="section-title">Endereço Principal</legend>

                    <div class="form-row">
                        <div class="form-group cep-group">
                            <label asp-for="CEP" class="form-label"></label>
                            <div class="input-with-feedback">
                                <input asp-for="CEP" id="cep" class="form-control" placeholder="00000-000" />
                                <div class="loading-spinner"></div>
                            </div>
                            <span asp-validation-for="CEP" class="validation-message"></span>
                            <small class="form-hint">Digite o CEP e aguarde o preenchimento automático</small>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group address-main">
                            <label asp-for="Logradouro" class="form-label"></label>
                            <input asp-for="Logradouro" id="logradouro" class="form-control" placeholder="Rua, Avenida, etc." />
                            <span asp-validation-for="Logradouro" class="validation-message"></span>
                        </div>

                        <div class="form-group address-number">
                            <label asp-for="Numero" class="form-label"></label>
                            <input asp-for="Numero" id="numero" class="form-control" placeholder="Nº" />
                            <span asp-validation-for="Numero" class="validation-message"></span>
                        </div>

                        <div class="form-group address-complement">
                            <label asp-for="Complemento" class="form-label"></label>
                            <input asp-for="Complemento" id="complemento" class="form-control" placeholder="Apto, Bloco, etc." />
                            <span asp-validation-for="Complemento" class="validation-message"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group neighborhood">
                            <label asp-for="Bairro" class="form-label"></label>
                            <input asp-for="Bairro" id="bairro" class="form-control" placeholder="Seu bairro" />
                            <span asp-validation-for="Bairro" class="validation-message"></span>
                        </div>

                        <div class="form-group city">
                            <label asp-for="Cidade" class="form-label"></label>
                            <input asp-for="Cidade" id="cidade" class="form-control" placeholder="Sua cidade" />
                            <span asp-validation-for="Cidade" class="validation-message"></span>
                        </div>

                        <div class="form-group state">
                            <label asp-for="Estado" class="form-label"></label>
                            <input asp-for="Estado" id="estado" class="form-control" placeholder="UF" maxlength="2" />
                            <span asp-validation-for="Estado" class="validation-message"></span>
                        </div>
                    </div>

                    <div class="form-checkbox">
                        <input type="checkbox" id="mainAddress" class="form-check-input" checked disabled />
                        <label for="mainAddress" class="form-check-label">Definir como endereço principal</label>
                    </div>
                </fieldset>

                <div class="form-actions">
                    <button id="btnSubmit"
                            type="submit"
                            class="btn btn-primary btn-submit"
                            aria-live="polite"
                            aria-busy="false"
                            data-text-default="Finalizar Cadastro"
                            data-text-loading="Enviando..."
                            data-text-success="Pronto!">
                        <i class="fas fa-check-circle btn-icon" aria-hidden="true"></i>
                        <span class="btn-text">Finalizar Cadastro</span>
                        <span class="btn-spinner" aria-hidden="true"></span>
                    </button>

                    <a href="@(!string.IsNullOrEmpty(ViewBag.ReturnUrl) ? (string)ViewBag.ReturnUrl : Url.Action("Index", "Carrinho"))"
                       class="btn btn-outline-secondary"
                       onclick="if (history.length > 1) { history.back(); return false; }">
                        <i class="fas fa-times"></i> Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cep.js" asp-append-version="true"></script>

    <!-- CDN confiável do InputMask -->
    <script src="https://cdn.jsdelivr.net/npm/inputmask@5.0.8/dist/jquery.inputmask.min.js"></script>

    <!-- Fallback local caso o CDN falhe -->
    <script>
        (function() {
            function loadInputMask() {
                if (typeof window.Inputmask === 'undefined') {
                    console.log('Carregando InputMask localmente...');
                    var script = document.createElement('script');
                    script.src = '/lib/inputmask/jquery.inputmask.min.js';
                    script.onload = initMasks;
                    document.head.appendChild(script);
                } else {
                    initMasks();
                }
            }

            function initMasks() {
                if (typeof window.jQuery === 'undefined') {
                    console.error('jQuery não está disponível');
                    return;
                }
                var $ = window.jQuery;

                try {
                    if ($('#cep').length) $('#cep').inputmask('99999-999');
                    if ($('#estado').length) {
                        $('#estado').inputmask('AA', { placeholder: 'SP', casing: 'upper' });
                    }
                    if ($('#cpf').length) {
                        $('#cpf').inputmask('999.999.999-99', {
                            showMaskOnHover: false,
                            clearIncomplete: true
                        });
                    }
                    console.log('Máscaras aplicadas com sucesso');
                } catch (error) {
                    console.error('Erro ao aplicar máscaras:', error);
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadInputMask);
            } else {
                loadInputMask();
            }
        })();
    </script>

    <!-- Submit: evita duplo clique e mostra “carregando” -->
    <script>
        (function () {
          const form = document.querySelector('form.cadastro-form');
          const btn  = document.getElementById('btnSubmit');
          if (!form || !btn) return;

          const setState = (state) => {
            // state: "default" | "loading" | "success"
            btn.classList.toggle('is-loading', state === 'loading');
            btn.classList.toggle('is-success', state === 'success');
            btn.setAttribute('aria-busy', state === 'loading' ? 'true' : 'false');

            const txt = btn.querySelector('.btn-text');
            if (!txt) return;

            if (state === 'loading') txt.textContent = btn.dataset.textLoading || 'Enviando...';
            else if (state === 'success') txt.textContent = btn.dataset.textSuccess || 'Pronto!';
            else txt.textContent = btn.dataset.textDefault || 'Finalizar Cadastro';
          };

          let submitted = false;

          form.addEventListener('submit', function (e) {
            if (submitted) { e.preventDefault(); return false; }

            if (!form.checkValidity()) return;

            submitted = true;
            setState('loading');

            try {
              const fields = form.querySelectorAll('input, select, textarea, button');
              fields.forEach(el => el.disabled = (el !== btn) ? true : false);
              btn.disabled = true;
            } catch {}

            setTimeout(() => {
              if (document.visibilityState === 'visible') {
                submitted = false;
                btn.disabled = false;
                setState('default');
                const fields = form.querySelectorAll('input, select, textarea, button');
                fields.forEach(el => el.disabled = false);
              }
            }, 8000);
          });
        })();
    </script>

    <partial name="_ValidationScriptsPartial" />
}
