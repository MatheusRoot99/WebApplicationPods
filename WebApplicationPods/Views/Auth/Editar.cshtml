@model WebApplicationPods.Models.EditarInfoViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Editar informações";
}
@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-head d-flex align-items-center gap-2">
            <i class="fa-solid fa-id-card"></i>
            <h2 class="h5 mb-0">Editar informações</h2>
        </div>

        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <form asp-action="Editar" method="post" class="login-form" asp-antiforgery="true" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="form-group mb-3">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Telefone" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                        <input asp-for="Telefone"
                               class="form-control border-start-0"
                               inputmode="numeric"
                               autocomplete="tel-national"
                               placeholder="(11) 98765-4321" />
                    </div>
                    <small class="form-text text-muted">WhatsApp com DDD</small>
                    <span asp-validation-for="Telefone" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="voce@email.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-brand w-100">
                    Salvar alterações <i class="fas fa-check ms-2"></i>
                </button>

                <a href="@(Model.ReturnUrl ?? Url.Action("Resumo", "Carrinho"))" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="fas fa-arrow-left me-2"></i> Voltar
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.6/jquery.inputmask.min.js"></script>
    <script>
        (function () {
            const $tel = window.jQuery && jQuery('[name="Telefone"]');
            if ($tel && $tel.inputmask) $tel.inputmask({ mask: '(99) 99999-9999' });
        })();
    </script>
}
