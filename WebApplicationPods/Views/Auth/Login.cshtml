@model WebApplicationPods.Models.AuthLoginViewModel

@{
    ViewData["Title"] = "Acesse sua conta";
}

@section Styles {
    <!-- Se já tem um login.css seu, mantenha. Abaixo complemento leve pro bottom-sheet -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <style>
        /* Bottom sheet simples (seu login.css pode assumir depois) */
        .sheet-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.35);
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
            z-index: 1098;
        }

            .sheet-backdrop.show {
                opacity: 1;
                pointer-events: auto;
            }

        .sheet {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 1099;
            background: #fff;
            border-top-left-radius: 16px;
            border-top-right-radius: 16px;
            box-shadow: 0 -12px 28px rgba(0,0,0,.18);
            transform: translateY(100%);
            transition: transform .22s ease-out;
            padding: 16px;
        }

            .sheet.show {
                transform: translateY(0);
            }

        .sheet-title {
            text-align: center;
            font-weight: 800;
            font-size: 1.05rem;
            margin-bottom: 10px;
        }

        .sheet-row {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .5rem 0;
            border-bottom: 1px solid rgba(0,0,0,.06);
        }

            .sheet-row:last-child {
                border-bottom: 0;
            }

        .sheet-ico {
            width: 38px;
            height: 38px;
            border-radius: 999px;
            background: #f2f4f7;
            display: grid;
            place-items: center;
            color: #475467;
        }

        .sheet-lab {
            font-size: .85rem;
            color: #667085;
        }

        .sheet-val {
            font-size: 1.05rem;
        }

            .sheet-val.underline {
                text-decoration: underline;
                text-underline-offset: 2px;
            }

        .btn-brand {
            background: linear-gradient(90deg, #6d28d9, #2563eb);
            border: 0;
            color: #fff;
        }

            .btn-brand:hover {
                filter: brightness(1.03);
                color: #fff;
            }

        .auth-shell {
            min-height: calc(100vh - 120px);
            display: grid;
            place-items: center;
            background: #f5f6f8;
            padding: 24px 12px;
        }

        .auth-card {
            width: min(760px, 92vw);
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }

        .auth-head {
            background: linear-gradient(90deg, #6d28d9, #2563eb);
            color: #fff;
            padding: 14px 18px;
            font-weight: 800;
        }

        .auth-body {
            padding: 18px;
        }
    </style>
}

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-head d-flex align-items-center gap-2">
            <i class="fa-solid fa-mobile-screen"></i>
            <h2 class="h5 mb-0">Acesse sua conta</h2>
        </div>

        <div class="auth-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- FORM PRINCIPAL: digita o telefone e vai -->
            <form asp-action="Login" method="post" class="login-form" asp-antiforgery="true" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="form-group mb-4">
                    <label asp-for="Telefone" class="form-label">Telefone</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                        <input asp-for="Telefone"
                               id="telefone"
                               class="form-control border-start-0"
                               placeholder="(11) 98765-4321"
                               inputmode="numeric"
                               autocomplete="tel-national"
                               required />
                    </div>
                    <small class="form-text text-muted">Informe seu Telefone com DDD</small>
                    <span class="text-danger" asp-validation-for="Telefone"></span>
                </div>

                <button type="submit" class="btn btn-brand w-100">
                    Continuar <i class="fas fa-arrow-right ms-2"></i>
                </button>

                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="fas fa-arrow-left me-2"></i> Voltar para a loja
                </a>
            </form>
        </div>
    </div>
</div>

