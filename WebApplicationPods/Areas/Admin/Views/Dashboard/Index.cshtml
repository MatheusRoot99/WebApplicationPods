@model WebApplicationPods.ViewModels.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard Administrativo";
}

<div class="admin-page-header">
    <h1>Dashboard Administrativo</h1>
    <p>Visão geral da plataforma</p>
</div>

<!-- Cards de topo -->
<div class="row g-3 mb-3">
    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Lojas ativas</span>
                <div class="admin-stat-icon purple">
                    <i class="fa-solid fa-store"></i>
                </div>
            </div>
            <div class="admin-stat-value">@Model.LojasAtivas</div>
            <div class="admin-stat-caption">+@Model.LojasCriadasMes este mês</div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Usuários lojistas</span>
                <div class="admin-stat-icon pink">
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
            <div class="admin-stat-value">@Model.LojistasAtivos</div>
            <div class="admin-stat-caption">contas ativas</div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Receita (placeholder)</span>
                <div class="admin-stat-icon orange">
                    <i class="fa-solid fa-coins"></i>
                </div>
            </div>
            <div class="admin-stat-value">@Model.ReceitaTotal.ToString("C")</div>
            <div class="admin-stat-caption">mês atual: @Model.ReceitaMesAtual.ToString("C")</div>
        </div>
    </div>
</div>

<!-- Lojas recentes -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card admin-card p-3">
            <div class="admin-section-title">Lojas recentes</div>
            <div class="admin-section-subtitle">Últimas lojas criadas</div>

            @if (Model.LojasRecentes != null && Model.LojasRecentes.Any())
            {
                <div class="admin-list">
                    @foreach (var loja in Model.LojasRecentes)
                    {
                        <div class="item">
                            <div class="item-main">
                                <div class="admin-list-avatar">@loja.Nome.Substring(0, 1).ToUpper()</div>
                                <div>
                                    <div class="admin-list-title">@loja.Nome</div>
                                    <div class="admin-list-sub">
                                        @(string.IsNullOrWhiteSpace(loja.DonoNome) ? "Sem dono" : loja.DonoNome)
                                        • @loja.CriadaEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            </div>

                            @if (loja.Ativa)
                            {
                                <span class="badge-status active">Ativa</span>
                            }
                            else
                            {
                                <span class="badge-status">Inativa</span>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted">Nenhuma loja encontrada.</div>
            }
        </div>
    </div>
</div>
