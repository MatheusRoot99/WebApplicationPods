@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard Administrativo";
}

<div class="admin-page-header">
    <h1>Dashboard Administrativo</h1>
    <p>Visão geral da plataforma</p>
</div>

<!-- Cards de topo: Lojas, Usuários, Receita -->
<div class="row g-3 mb-3">
    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Lojas ativas</span>
                <div class="admin-stat-icon purple">
                    <i class="fa-solid fa-store"></i>
                </div>
            </div>
            <div class="admin-stat-value">2</div>
            <div class="admin-stat-caption">+2 este mês</div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Usuários lojistas</span>
                <div class="admin-stat-icon pink">
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
            <div class="admin-stat-value">5</div>
            <div class="admin-stat-caption">contas ativas</div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-6">
        <div class="card admin-card admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">Receita total</span>
                <div class="admin-stat-icon orange">
                    <i class="fa-solid fa-coins"></i>
                </div>
            </div>
            <div class="admin-stat-value">R$ 0,00</div>
            <div class="admin-stat-caption">+0% vs mês anterior</div>
        </div>
    </div>
</div>

<!-- Lojas recentes (full width) -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card admin-card p-3">
            <div class="admin-section-title">Lojas recentes</div>
            <div class="admin-section-subtitle">Últimas lojas criadas / acessadas</div>

            <div class="admin-list">
                <div class="item">
                    <div class="item-main">
                        <div class="admin-list-avatar">C</div>
                        <div>
                            <div class="admin-list-title">ConveniShop Centro</div>
                            <div class="admin-list-sub">João Silva</div>
                        </div>
                    </div>
                    <span class="badge-status active">Ativa</span>
                </div>

                <div class="item">
                    <div class="item-main">
                        <div class="admin-list-avatar">S</div>
                        <div>
                            <div class="admin-list-title">ConveniShop Shopping</div>
                            <div class="admin-list-sub">Maria Santos</div>
                        </div>
                    </div>
                    <span class="badge-status active">Ativa</span>
                </div>
            </div>
        </div>
    </div>
</div>

