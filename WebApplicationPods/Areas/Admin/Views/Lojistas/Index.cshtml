@using WebApplicationPods.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Lojistas";
}

<h2 class="mb-3">Lojistas</h2>

<p>
    <a asp-area="Admin"
       asp-controller="Lojistas"
       asp-action="Create"
       class="btn btn-primary">
        + Novo lojista
    </a>
</p>

@if (TempData["Sucesso"] is string okMsg)
{
    <div class="alert alert-success">@okMsg</div>
}
@if (TempData["Erro"] is string errMsg)
{
    <div class="alert alert-danger">@errMsg</div>
}

<table class="table table-striped table-bordered table-sm align-middle">
    <thead class="table-light">
        <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>E-mail</th>
            <th style="width: 260px;">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Nome</td>
                <td>@u.CPF</td>
                <td>@u.PhoneNumber</td>
                <td>@u.Email</td>
                <td>
                    <div class="d-flex flex-wrap gap-1">
                        <a asp-area="Admin"
                           asp-controller="Lojistas"
                           asp-action="Edit"
                           asp-route-id="@u.Id"
                           class="btn btn-sm btn-secondary">
                            Editar
                        </a>

                        <!-- Reset de senha -->
                        <form asp-area="Admin"
                              asp-controller="Lojistas"
                              asp-action="ResetSenha"
                              method="post"
                              class="d-flex align-items-center gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <input type="password"
                                   name="novaSenha"
                                   class="form-control form-control-sm"
                                   placeholder="Nova senha" />
                            <button type="submit" class="btn btn-sm btn-warning">
                                Resetar
                            </button>
                        </form>

                        <!-- Delete -->
                        <form asp-area="Admin"
                              asp-controller="Lojistas"
                              asp-action="Delete"
                              method="post"
                              onsubmit="return confirm('Remover este lojista?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">
                                Excluir
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
