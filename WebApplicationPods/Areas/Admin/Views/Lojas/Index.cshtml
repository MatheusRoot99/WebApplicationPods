@model IEnumerable<WebApplicationPods.Models.LojaModel>
@inject WebApplicationPods.Services.Interface.IStoreUrlBuilder StoreUrlBuilder

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Lojas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/lojas-index.css" asp-append-version="true" />
}

<div class="admin-page-header">
    <h1>Lojas</h1>
    <p>Gerencie as lojas da plataforma</p>
</div>

<div class="mb-3">
    <a asp-area="Admin" asp-controller="Lojas" asp-action="Create" class="btn btn-primary">
        <i class="fa fa-plus"></i> Nova loja
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<div class="card admin-card p-3 admin-table-wrap">
    <table class="table table-striped align-middle mb-0">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Subdomínio</th>
                <th>Link público (cliente)</th>
                <th>Plano</th>
                <th>Dono / Lojista</th>
                <th>Status</th>
                <th>Criada em</th>
                <th style="width: 140px; text-align:right;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loja in Model)
            {
                var publicUrl = StoreUrlBuilder.BuildPublicStoreUrl(loja.Subdominio);

                <tr>
                    <td>@loja.Nome</td>
                    <td><code>@loja.Subdominio</code></td>
                    <td>
                        <a class="admin-link" href="@publicUrl" target="_blank" rel="noopener">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i>
                            <span>@publicUrl</span>
                        </a>
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(loja.Plano) ? "-" : loja.Plano)</td>
                    <td>
                        @(loja.Dono != null ? loja.Dono.Nome : "Sem dono")
                    </td>
                    <td>
                        @if (loja.Ativa)
                        {
                            <span class="badge-soft green">Ativa</span>
                        }
                        else
                        {
                            <span class="badge-soft gray">Inativa</span>
                        }
                    </td>
                    <td>@loja.CriadaEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td style="text-align:right;">
                        <div class="admin-actions">
                            <a asp-area="Admin" asp-controller="Lojas" asp-action="Edit" asp-route-id="@loja.Id"
                               class="btn btn-sm btn-outline-primary" title="Editar">
                                <i class="fa fa-edit"></i>
                            </a>

                            <form asp-area="Admin" asp-controller="Lojas" asp-action="Delete" asp-route-id="@loja.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Confirma excluir esta loja? Esta ação não pode ser desfeita?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
