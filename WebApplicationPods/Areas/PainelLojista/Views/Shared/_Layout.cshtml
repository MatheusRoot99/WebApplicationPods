@using Microsoft.AspNetCore.Identity
@using WebApplicationPods.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var userName = User?.Identity?.Name ?? "Lojista";
    ViewData["Title"] ??= "Painel do Lojista";

    string currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string ActiveLink(string area, string controller, string? action = null)
    {
        bool sameArea = string.Equals(currentArea, area ?? "", StringComparison.OrdinalIgnoreCase);
        bool sameController = string.Equals(currentController, controller ?? "", StringComparison.OrdinalIgnoreCase);
        bool sameAction = string.IsNullOrWhiteSpace(action)
            || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return (sameArea && sameController && sameAction) ? "active" : "";
    }

    bool isProdutoMenuOpen =
        string.Equals(currentController, "Produto", StringComparison.OrdinalIgnoreCase);

    string produtoExpanded = isProdutoMenuOpen ? "true" : "false";
    string produtoSubmenuClass = isProdutoMenuOpen ? "pl-submenu open" : "pl-submenu";
    string produtoParentClass = isProdutoMenuOpen ? "active has-children open" : "has-children";

    bool isCatalogoActive =
        string.Equals(currentController, "Produto", StringComparison.OrdinalIgnoreCase) &&
        (
            string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentAction, "Detalhes", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentAction, "Editar", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentAction, "Excluir", StringComparison.OrdinalIgnoreCase)
        );

    bool isNovoPadraoActive =
        string.Equals(currentController, "Produto", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, "CriarPadrao", StringComparison.OrdinalIgnoreCase);

    bool isNovaBebidaActive =
        string.Equals(currentController, "Produto", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, "CriarBebida", StringComparison.OrdinalIgnoreCase);

    bool isNovoPodActive =
        string.Equals(currentController, "Produto", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, "CriarPod", StringComparison.OrdinalIgnoreCase);

    bool isPerfilActive =
        string.Equals(currentController, "Cliente", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, "Perfil", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="pt-br" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - Painel do Lojista</title>

    <script>
        (function () {
            try {
                var saved = localStorage.getItem('theme');
                if (!saved) {
                    saved = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
                        ? 'dark'
                        : 'light';
                }
                document.documentElement.setAttribute('data-theme', saved);
            } catch { }
        })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/painel-lojista.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --mbn-height: 70px;
            --kb-shift: 0px;
        }

        html, body {
            height: 100%;
        }

        .pl-menu-group {
            margin-top: 1rem;
        }

        .pl-menu-label {
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            opacity: .65;
            margin: 1rem 0 .7rem;
            padding: 0 .25rem;
        }

        .pl-menu a.has-children {
            justify-content: space-between;
        }

        .pl-menu a .pl-link-left {
            display: inline-flex;
            align-items: center;
            gap: .6rem;
        }

        .pl-menu a .pl-chevron {
            transition: transform .2s ease;
            font-size: .85rem;
            opacity: .85;
        }

        .pl-menu a.open .pl-chevron {
            transform: rotate(180deg);
        }

        .pl-submenu {
            display: none;
            margin: .35rem 0 .4rem 1.1rem;
            padding-left: .95rem;
            border-left: 1px dashed rgba(255,255,255,.14);
        }

            .pl-submenu.open {
                display: block;
            }

            .pl-submenu a {
                display: flex;
                align-items: center;
                gap: .65rem;
                padding: .62rem .8rem;
                margin: .15rem 0;
                border-radius: 12px;
                color: inherit;
                text-decoration: none;
                font-size: .95rem;
            }

                .pl-submenu a.active {
                    background: rgba(255,255,255,.08);
                    border: 1px solid rgba(255,255,255,.08);
                }
    </style>
</head>

<body class="has-bottom-nav">
    <div class="pl-shell">

        <aside class="pl-sidebar">
            <div class="pl-brand">
                <div class="pl-brand-logo">
                    <i class="fa-solid fa-store"></i>
                </div>
                <div class="pl-brand-text">
                    <div class="pl-brand-name">Pods Eletrônicos</div>
                    <div class="pl-brand-sub">Painel do Lojista</div>
                </div>
            </div>

            <div class="pl-user">
                <div class="pl-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div class="pl-user-meta">
                    <div class="pl-user-name">@userName</div>
                    <div class="pl-user-role">Lojista</div>
                </div>
            </div>

            <nav class="pl-menu">

                <div class="pl-menu-group">
                    <div class="pl-menu-label">Navegação</div>

                    <a asp-area="" asp-controller="Home" asp-action="Index"
                       class="@ActiveLink("", "Home", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-house"></i> Home
                        </span>
                    </a>
                </div>

                <div class="pl-menu-group">
                    <div class="pl-menu-label">Lojista</div>

                    <a asp-area="PainelLojista" asp-controller="Dashboard" asp-action="Index"
                       class="@ActiveLink("PainelLojista", "Dashboard", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-gauge-high"></i> Dashboard
                        </span>
                    </a>

                    <a asp-area="" asp-controller="PedidosAdmin" asp-action="Relatorio"
                       class="@ActiveLink("", "PedidosAdmin", "Relatorio")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-chart-line"></i> Relatórios
                        </span>
                    </a>

                    <a asp-area="" asp-controller="Estoque" asp-action="Index"
                       class="@ActiveLink("", "Estoque", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-boxes-stacked"></i> Estoque
                        </span>
                    </a>

                    <a asp-area="" asp-controller="PedidosAdmin" asp-action="Index"
                       class="@ActiveLink("", "PedidosAdmin", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-clipboard-list"></i> Pedidos
                        </span>
                    </a>

                    <a asp-area="PainelLojista" asp-controller="Entregadores" asp-action="Index"
                       class="@ActiveLink("PainelLojista", "Entregadores", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-motorcycle"></i> Entregadores
                        </span>
                    </a>

                    <a asp-area="" asp-controller="Categoria" asp-action="Index"
                       class="@ActiveLink("", "Categoria", "Index")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-tags"></i> Categorias
                        </span>
                    </a>

                    <a href="#"
                       class="@produtoParentClass"
                       data-pl-submenu-toggle="produtos"
                       aria-expanded="@produtoExpanded">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-box-open"></i> Produtos
                        </span>
                        <i class="fa-solid fa-chevron-down pl-chevron"></i>
                    </a>

                    <div id="pl-submenu-produtos" class="@produtoSubmenuClass">
                        <a asp-area="" asp-controller="Produto" asp-action="Index"
                           class="@(isCatalogoActive ? "active" : "")">
                            <i class="fa-solid fa-list"></i> Catálogo
                        </a>

                        <a asp-area="" asp-controller="Produto" asp-action="CriarPadrao"
                           class="@(isNovoPadraoActive ? "active" : "")">
                            <i class="fa-solid fa-plus"></i> Novo Padrão
                        </a>

                        <a asp-area="" asp-controller="Produto" asp-action="CriarBebida"
                           class="@(isNovaBebidaActive ? "active" : "")">
                            <i class="fa-solid fa-wine-bottle"></i> Nova Bebida
                        </a>

                        <a asp-area="" asp-controller="Produto" asp-action="CriarPod"
                           class="@(isNovoPodActive ? "active" : "")">
                            <i class="fa-solid fa-smoking"></i> Novo Pod
                        </a>
                    </div>

                    <a asp-area="" asp-controller="PaymentConfig" asp-action="Edit" asp-route-provider="Stripe"
                       class="@ActiveLink("", "PaymentConfig")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-credit-card"></i> Pagamento
                        </span>
                    </a>

                    <a asp-area="PainelLojista" asp-controller="Loja" asp-action="Editar"
                       class="@ActiveLink("PainelLojista", "Loja", "Editar")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-store"></i> Configurações da Loja
                        </span>
                    </a>
                </div>

                <div class="pl-menu-group">
                    <div class="pl-menu-label">Usuário</div>

                    <a asp-area="" asp-controller="Cliente" asp-action="Perfil"
                       class="@(isPerfilActive ? "active" : "")">
                        <span class="pl-link-left">
                            <i class="fa-solid fa-user-circle"></i> Perfil
                        </span>
                    </a>
                </div>
            </nav>

            <div class="pl-sidebar-footer">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form asp-area="" asp-controller="Conta" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-light w-100 btn-sm" type="submit">
                            <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Sair
                        </button>
                    </form>
                }
            </div>
        </aside>

        <div class="pl-main">
            <header class="pl-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="pl-menu-btn d-lg-none" data-pl-toggle="sidebar" aria-label="Abrir menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="pl-topbar-title text-truncate">
                        @ViewData["Title"]
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="theme-toggle" id="btnThemePanel" title="Alternar tema">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </header>

            <main class="pl-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            function currentTheme() {
                return document.documentElement.getAttribute('data-theme') || 'light';
            }

            function setIcon() {
                var t = currentTheme();
                var iconClass = (t === 'dark') ? 'fa-sun' : 'fa-moon';
                var btn = document.getElementById('btnThemePanel');
                if (!btn) return;
                var i = btn.querySelector('i');
                if (i) i.className = 'fas ' + iconClass;
            }

            function toggleTheme() {
                var t = currentTheme();
                var next = (t === 'dark') ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                try { localStorage.setItem('theme', next); } catch { }
                setIcon();
            }

            document.getElementById('btnThemePanel')?.addEventListener('click', toggleTheme);
            setIcon();
        })();
    </script>

    <script>
        (function () {
            const shell = document.querySelector('.pl-shell');

            document.querySelectorAll('[data-pl-toggle="sidebar"]').forEach(btn => {
                btn.addEventListener('click', () => shell?.classList.toggle('pl-sidebar-open'));
            });

            document.querySelectorAll('[data-pl-submenu-toggle]').forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    const key = this.getAttribute('data-pl-submenu-toggle');
                    const submenu = document.getElementById('pl-submenu-' + key);
                    if (!submenu) return;

                    const isOpen = submenu.classList.contains('open');
                    submenu.classList.toggle('open', !isOpen);
                    this.classList.toggle('open', !isOpen);
                    this.setAttribute('aria-expanded', (!isOpen).toString());
                });
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>