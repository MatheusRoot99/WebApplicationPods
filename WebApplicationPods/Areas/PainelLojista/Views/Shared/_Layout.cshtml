@using Microsoft.AspNetCore.Identity
@using WebApplicationPods.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var userName = User?.Identity?.Name ?? "Lojista";
    ViewData["Title"] ??= "Painel do Lojista";

    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="pt-br" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - Painel do Lojista</title>

    <!-- aplica tema antes de pintar -->
    <script>
        (function () {
            try {
                var saved = localStorage.getItem('theme');
                if (!saved) {
                    saved = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
                }
                document.documentElement.setAttribute('data-theme', saved);
            } catch { }
        })();
    </script>

    <!-- libs -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- css global -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- css específico do painel (layout/shell) -->
    <link rel="stylesheet" href="~/css/painel-lojista.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* fallback pra garantir espaçamento */
        :root {
            --mbn-height: 70px;
            --kb-shift: 0px;
        }

        html, body {
            height: 100%;
        }
    </style>
</head>

<body class="has-bottom-nav">
    <div class="pl-shell">

        <!-- SIDEBAR -->
        <aside class="pl-sidebar">
            <div class="pl-brand">
                <div class="pl-brand-logo">
                    <i class="fa-solid fa-store"></i>
                </div>
                <div class="pl-brand-text">
                    <div class="pl-brand-name">Pods Eletrônicos</div>
                    <div class="pl-brand-sub">Painel do Lojista</div>
                </div>
            </div>

            <div class="pl-user">
                <div class="pl-avatar"><i class="fa-solid fa-user"></i></div>
                <div class="pl-user-meta">
                    <div class="pl-user-name">@userName</div>
                    <div class="pl-user-role">Lojista</div>
                </div>
            </div>

            <div class="pl-menu-title">Menu</div>

            <nav class="pl-menu">
                <a asp-area="PainelLojista" asp-controller="Dashboard" asp-action="Index"
                   class="@(currentController == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high me-2"></i> Dashboard
                </a>

                <a asp-area="PainelLojista" asp-controller="Entregadores" asp-action="Index"
                   class="@(currentController == "Entregadores" ? "active" : "")">
                    <i class="fa-solid fa-motorcycle me-2"></i> Entregadores
                </a>

                <a asp-controller="PedidosAdmin"
                   asp-action="AtribuirEntregador"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-info btn-sm">
                    Atribuir entregador
                </a>

                <a asp-area="PainelLojista" asp-controller="Loja" asp-action="Editar"
                   class="@(currentController == "Loja" ? "active" : "")">
                    <i class="fa-solid fa-gear me-2"></i> Configurações da Loja
                </a>

                <!-- Se esses controllers ainda estão fora da Area, mantenha asp-area="" -->
                <a asp-area="" asp-controller="Produto" asp-action="Index">
                    <i class="fa-solid fa-boxes-stacked me-2"></i> Produtos
                </a>

                <a asp-area="" asp-controller="Pedido" asp-action="Index">
                    <i class="fa-solid fa-receipt me-2"></i> Pedidos
                </a>



                <a asp-area="" asp-controller="Categoria" asp-action="Index">
                    <i class="fa-solid fa-tags me-2"></i> Categorias
                </a>

                <a asp-area="" asp-controller="PaymentConfig" asp-action="Index">
                    <i class="fa-solid fa-credit-card me-2"></i> Pagamentos
                </a>
            </nav>

            <div class="pl-sidebar-footer">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form asp-area="" asp-controller="Conta" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-light w-100 btn-sm" type="submit">
                            <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Sair
                        </button>
                    </form>
                }
            </div>
        </aside>

        <!-- MAIN -->
        <div class="pl-main">
            <header class="pl-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="pl-menu-btn d-lg-none" data-pl-toggle="sidebar" aria-label="Abrir menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="pl-topbar-title text-truncate">
                        @ViewData["Title"]
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="theme-toggle" id="btnThemePanel" title="Alternar tema">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </header>

            <main class="pl-content">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- theme toggle -->
    <script>
        (function () {
            function currentTheme() {
                return document.documentElement.getAttribute('data-theme') || 'light';
            }
            function setIcon() {
                var t = currentTheme();
                var iconClass = (t === 'dark') ? 'fa-sun' : 'fa-moon';
                var btn = document.getElementById('btnThemePanel');
                if (!btn) return;
                var i = btn.querySelector('i');
                if (i) i.className = 'fas ' + iconClass;
            }
            function toggleTheme() {
                var t = currentTheme();
                var next = (t === 'dark') ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                try { localStorage.setItem('theme', next); } catch { }
                setIcon();
            }
            document.getElementById('btnThemePanel')?.addEventListener('click', toggleTheme);
            setIcon();
        })();
    </script>

    <!-- mobile sidebar toggle -->
    <script>
        (function () {
            const shell = document.querySelector('.pl-shell');
            document.querySelectorAll('[data-pl-toggle="sidebar"]').forEach(btn => {
                btn.addEventListener('click', () => shell?.classList.toggle('pl-sidebar-open'));
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
