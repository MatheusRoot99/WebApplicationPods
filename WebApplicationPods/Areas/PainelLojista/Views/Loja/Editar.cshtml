@using Microsoft.AspNetCore.Authorization
@using WebApplicationPods.Models
@model WebApplicationPods.Models.LojaConfig
@inject IAuthorizationService Authz

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Configurações da Loja";
    var authResult = await Authz.AuthorizeAsync(User, policyName: "Admin");
    var isAdmin = authResult.Succeeded || (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"));
}

@section Styles {
    <style>
        /* ===========================
           Loja Settings — Clean Modern + Dark
           (Inline/Scoped)
           =========================== */

        :root {
            /* Light */
            --bg: #F6F8FC;
            --card: #FFFFFF;
            --card-2: rgba(255,255,255,.72);
            --text: #0F172A;
            --muted: #64748B;
            --border: #E6ECF5;
            --brand-500: #2F6BFF;
            --brand-600: #2458E6;
            --brand-50: #EEF4FF;
            --success-500: #22C55E;
            --success-600: #16A34A;
            --danger-500: #EF4444;
            --shadow: 0 18px 55px rgba(15,23,42,.10);
            --shadow-soft: 0 10px 28px rgba(15,23,42,.08);
            --radius-xl: 26px;
            --radius-lg: 20px;
            --radius-md: 16px;
            --radius-sm: 12px;
            --ring-brand: rgba(47,107,255,.22);
            --ring-success: rgba(34,197,94,.22);
            --mbn-h: 68px;
            --page-safe-bottom: calc(var(--mbn-h) + 16px);
        }

        /* Dark overrides (activated by #loja-settings[data-theme="dark"]) */
        #loja-settings[data-theme="dark"] {
            --bg: #0B1220;
            --card: rgba(14, 22, 39, .82);
            --card-2: rgba(14, 22, 39, .58);
            --text: #EAF0FF;
            --muted: rgba(234,240,255,.68);
            --border: rgba(234,240,255,.12);
            --brand-50: rgba(47,107,255,.10);
            --shadow: 0 20px 60px rgba(0,0,0,.45);
            --shadow-soft: 0 14px 34px rgba(0,0,0,.35);
            --ring-brand: rgba(47,107,255,.30);
            --ring-success: rgba(34,197,94,.30);
        }

        /* Page background */
        body {
            background: radial-gradient(1100px 560px at 12% -10%, rgba(47,107,255,.10), transparent 62%), radial-gradient(1100px 560px at 100% 0%, rgba(34,197,94,.08), transparent 62%), var(--bg);
        }

        /* Outer “glass” container */
        #loja-settings {
            border-radius: var(--radius-xl);
            padding: 22px;
            border: 1px solid rgba(15,23,42,.06);
            background: linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,255,255,.55));
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
        }

            /* dark background inside container */
            #loja-settings[data-theme="dark"] {
                background: radial-gradient(900px 420px at 20% -10%, rgba(47,107,255,.18), transparent 60%), radial-gradient(900px 420px at 100% 0%, rgba(34,197,94,.10), transparent 60%), rgba(10, 16, 30, .55);
                border-color: rgba(234,240,255,.10);
            }

            /* Subtle grain highlight */
            #loja-settings::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(900px 340px at 20% 0%, rgba(255,255,255,.25), transparent 60%);
                pointer-events: none;
                opacity: .55;
            }

            #loja-settings[data-theme="dark"]::before {
                opacity: .18;
            }

            /* Header (title + toggle) */
            #loja-settings .page-head {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 16px;
                padding: 6px 0 16px 0;
                border-bottom: 1px dashed var(--border);
                margin-bottom: 16px;
                position: relative;
                z-index: 2;
            }

            #loja-settings .head-left {
                display: flex;
                align-items: center;
                gap: 14px;
                min-width: 0;
            }

            #loja-settings .icon-wrap {
                width: 54px;
                height: 54px;
                border-radius: 18px;
                display: grid;
                place-items: center;
                background: linear-gradient(135deg, var(--brand-50), rgba(255,255,255,.65));
                border: 1px solid rgba(15,23,42,.06);
                box-shadow: var(--shadow-soft);
                flex: 0 0 auto;
            }

            #loja-settings[data-theme="dark"] .icon-wrap {
                background: linear-gradient(135deg, rgba(47,107,255,.16), rgba(14,22,39,.62));
                border-color: rgba(234,240,255,.10);
            }

            #loja-settings .icon-wrap i {
                font-size: 1.2rem;
                color: var(--brand-600);
            }

            #loja-settings[data-theme="dark"] .icon-wrap i {
                color: #8FB0FF;
            }

            #loja-settings .title {
                margin: 0;
                font-size: 1.32rem;
                font-weight: 900;
                color: var(--text);
                letter-spacing: -0.02em;
                line-height: 1.15;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            #loja-settings .subtitle {
                margin: .25rem 0 0 0;
                color: var(--muted);
                font-size: .95rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        .brand-gradient {
            background: linear-gradient(135deg, var(--brand-600), var(--success-500));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        /* Theme toggle pill */
        #loja-settings .theme-toggle {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--card-2);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 8px 10px;
            box-shadow: var(--shadow-soft);
            user-select: none;
        }

        #loja-settings[data-theme="dark"] .theme-toggle {
            border-color: rgba(234,240,255,.12);
        }

        #loja-settings .theme-toggle .label {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--muted);
            font-weight: 800;
            font-size: .86rem;
        }

            #loja-settings .theme-toggle .label i {
                opacity: .9;
            }

        /* Switch */
        #loja-settings .switch {
            width: 46px;
            height: 26px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(148,163,184,.30);
            position: relative;
            cursor: pointer;
            transition: all .2s ease;
        }

        #loja-settings[data-theme="dark"] .switch {
            background: rgba(148,163,184,.18);
            border-color: rgba(234,240,255,.14);
        }

        #loja-settings .switch::after {
            content: "";
            width: 20px;
            height: 20px;
            border-radius: 999px;
            position: absolute;
            top: 50%;
            left: 3px;
            transform: translateY(-50%);
            background: #fff;
            box-shadow: 0 8px 18px rgba(15,23,42,.16);
            transition: all .2s ease;
        }

        #loja-settings[data-theme="dark"] .switch::after {
            background: rgba(234,240,255,.92);
        }

        #loja-settings .switch.on {
            background: linear-gradient(135deg, var(--brand-500), var(--brand-600));
            border-color: rgba(47,107,255,.55);
        }

            #loja-settings .switch.on::after {
                left: calc(100% - 23px);
            }

        /* Main card */
        #loja-settings .main-card {
            border: 1px solid rgba(15,23,42,.06);
            border-radius: var(--radius-lg);
            background: var(--card);
            box-shadow: var(--shadow-soft);
            position: relative;
            z-index: 2;
            overflow: hidden;
        }

        #loja-settings[data-theme="dark"] .main-card {
            border-color: rgba(234,240,255,.10);
        }

        /* Section title */
        #loja-settings .section-title {
            display: flex;
            align-items: center;
            gap: .55rem;
            font-size: 1.02rem;
            font-weight: 900;
            color: var(--text);
            margin: .25rem 0 .85rem;
        }

            #loja-settings .section-title i {
                color: var(--brand-600);
            }

        #loja-settings[data-theme="dark"] .section-title i {
            color: #8FB0FF;
        }

        /* Labels/inputs */
        #loja-settings .form-label {
            font-weight: 800;
            color: color-mix(in srgb, var(--text) 80%, #334155 20%);
        }

        #loja-settings[data-theme="dark"] .form-label {
            color: rgba(234,240,255,.82);
        }

        #loja-settings .form-control,
        #loja-settings .form-select {
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: rgba(255,255,255,.92);
            color: var(--text);
            padding-top: .62rem;
            padding-bottom: .62rem;
            transition: box-shadow .15s ease, border-color .15s ease, background .15s ease;
        }

        #loja-settings[data-theme="dark"] .form-control,
        #loja-settings[data-theme="dark"] .form-select {
            background: rgba(10,16,30,.55);
            border-color: rgba(234,240,255,.12);
            color: var(--text);
        }

        #loja-settings .form-control::placeholder {
            color: #94A3B8;
        }

        #loja-settings[data-theme="dark"] .form-control::placeholder {
            color: rgba(234,240,255,.35);
        }

        #loja-settings .form-control:focus,
        #loja-settings .form-select:focus {
            border-color: rgba(47,107,255,.70);
            box-shadow: 0 0 0 .22rem var(--ring-brand);
            background: #fff;
        }

        #loja-settings[data-theme="dark"] .form-control:focus,
        #loja-settings[data-theme="dark"] .form-select:focus {
            background: rgba(10,16,30,.75);
        }

        #loja-settings .form-text {
            color: var(--muted);
            font-size: .86rem;
        }

        /* Checkboxes */
        #loja-settings .form-check-input {
            width: 1.08rem;
            height: 1.08rem;
            border-color: var(--border);
        }

        #loja-settings[data-theme="dark"] .form-check-input {
            border-color: rgba(234,240,255,.16);
            background-color: rgba(10,16,30,.55);
        }

        #loja-settings .form-check-input:checked {
            background: linear-gradient(135deg, var(--brand-600), var(--brand-500));
            border-color: var(--brand-600);
        }

        #loja-settings .form-check-label {
            color: color-mix(in srgb, var(--text) 80%, #334155 20%);
        }

        #loja-settings[data-theme="dark"] .form-check-label {
            color: rgba(234,240,255,.80);
        }

        #loja-settings hr {
            border-color: var(--border);
            opacity: .75;
        }

        /* Buttons */
        #loja-settings .btn {
            border-radius: 12px;
            padding: .62rem 1rem;
            font-weight: 900;
            letter-spacing: -0.01em;
        }

        #loja-settings .btn-success {
            background: linear-gradient(135deg, var(--success-500), var(--success-600));
            border: none;
            color: #fff;
            box-shadow: 0 12px 26px rgba(34,197,94,.18);
        }

            #loja-settings .btn-success:focus {
                box-shadow: 0 0 0 .22rem var(--ring-success), 0 12px 26px rgba(34,197,94,.18);
            }

        #loja-settings .btn-primary {
            background: linear-gradient(135deg, var(--brand-500), var(--brand-600));
            border: none;
            color: #fff;
        }

        #loja-settings .btn-outline-secondary {
            border: 1px solid var(--border);
            color: color-mix(in srgb, var(--text) 70%, #334155 30%);
            background: rgba(255,255,255,.85);
        }

        #loja-settings[data-theme="dark"] .btn-outline-secondary {
            background: rgba(10,16,30,.45);
            border-color: rgba(234,240,255,.12);
            color: rgba(234,240,255,.82);
        }

        /* Alerts */
        #loja-settings .alert-success {
            background: linear-gradient(135deg, rgba(34,197,94,.10), rgba(255,255,255,.85));
            border: 1px solid rgba(34,197,94,.25);
            color: var(--text);
            border-left: 4px solid var(--success-500);
        }

        #loja-settings[data-theme="dark"] .alert-success {
            background: linear-gradient(135deg, rgba(34,197,94,.14), rgba(10,16,30,.65));
        }

        #loja-settings .alert-danger {
            background: linear-gradient(135deg, rgba(239,68,68,.10), rgba(255,255,255,.85));
            border: 1px solid rgba(239,68,68,.22);
            color: color-mix(in srgb, var(--text) 15%, #991B1B 85%);
            border-left: 4px solid var(--danger-500);
        }

        #loja-settings[data-theme="dark"] .alert-danger {
            background: linear-gradient(135deg, rgba(239,68,68,.16), rgba(10,16,30,.65));
            color: rgba(255,220,220,.90);
        }

        /* Logo thumb */
        #loja-settings .logo-thumb {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: 999px;
            border: 1px solid rgba(15,23,42,.08);
            box-shadow: 0 6px 16px rgba(15,23,42,.12);
        }

        #loja-settings[data-theme="dark"] .logo-thumb {
            border-color: rgba(234,240,255,.14);
            box-shadow: 0 10px 26px rgba(0,0,0,.35);
        }

        /* Maps block */
        #loja-settings .bg-light {
            background: color-mix(in srgb, var(--card) 75%, #EEF4FF 25%) !important;
        }

        #loja-settings[data-theme="dark"] .bg-light {
            background: rgba(10,16,30,.42) !important;
        }

        #loja-settings .border {
            border-color: var(--border) !important;
        }

        #loja-settings #enderecoPreview {
            padding: .65rem .85rem;
            background: rgba(255,255,255,.90);
            border: 1px dashed rgba(100,116,139,.35);
            border-radius: var(--radius-sm);
            color: var(--text);
        }

        #loja-settings[data-theme="dark"] #enderecoPreview {
            background: rgba(10,16,30,.55);
            border-color: rgba(234,240,255,.16);
        }

        #loja-settings #mapsUrlPreview {
            font-family: ui-monospace,SFMono-Regular,Menlo,Consolas,"Liberation Mono",monospace;
            background: rgba(255,255,255,.90);
        }

        #loja-settings[data-theme="dark"] #mapsUrlPreview {
            background: rgba(10,16,30,.55);
        }

        /* Validation */
        #loja-settings span.text-danger {
            font-size: .86rem;
            color: #B91C1C !important;
        }

        #loja-settings[data-theme="dark"] span.text-danger {
            color: #FFB4B4 !important;
        }

        /* Actions */
        #loja-settings .form-actions .btn {
            min-height: 44px;
        }

        /* Mobile safe */
        @@media (max-width: 991.98px) {
            #page-content-wrapper,
            #page-content-wrapper .container,
            #page-content-wrapper {
                padding-bottom: var(--page-safe-bottom);
            }
        }

        /* Tighten on very small screens */
        @@media (max-width: 575.98px) {
            #loja-settings {
                padding: 16px;
                border-radius: 22px;
            }

                #loja-settings .theme-toggle .label span {
                    display: none;
                }
        }
    </style>
}

<div class="container py-4">
    <div id="loja-settings" class="loja-settings" data-theme="light">

        <header class="page-head">
            <div class="head-left">
                <div class="icon-wrap">
                    <i class="fas fa-store"></i>
                </div>
                <div class="min-w-0">
                    <h1 class="title"><span class="brand-gradient">Configurações da Loja</span></h1>
                    <p class="subtitle">Edite identidade, funcionamento e endereço para retirada no local.</p>
                </div>
            </div>

            <div class="theme-toggle" role="group" aria-label="Alternar tema">
                <div class="label" id="themeLabel">
                    <i class="fa-solid fa-sun"></i>
                    <span>Light</span>
                </div>
                <div class="switch" id="themeSwitch" role="switch" aria-checked="false" tabindex="0" title="Alternar tema"></div>
            </div>
        </header>

        @if (TempData["Sucesso"] is string okMsg)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3">
                <i class="bi bi-check2-circle me-2"></i>@okMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                <strong>Corrija os campos abaixo.</strong>
            </div>
        }

        <form asp-action="Editar" method="post" enctype="multipart/form-data" class="card main-card p-3 p-md-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <section class="section">
                <h2 class="section-title"><i class="bi bi-person-badge me-2"></i>Identidade</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nome" class="form-label">Nome do Estabelecimento</label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Logo (PNG/JPG/WEBP)</label>
                        <input type="file" name="logoFile" class="form-control" accept=".png,.jpg,.jpeg,.webp" />
                        @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
                        {
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <img src="@Model.LogoPath" alt="Logo atual" class="logo-thumb" />
                                <span class="text-muted small text-truncate">@Model.LogoPath</span>
                            </div>
                        }
                        <span asp-validation-for="LogoPath" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <hr class="my-3 my-md-4" />

            <section class="section">
                <h2 class="section-title"><i class="bi bi-clock-history me-2"></i>Funcionamento</h2>
                <div class="row g-3">
                    <div class="col-sm-6 col-md-3">
                        <label class="form-label">Abre às</label>
                        <input asp-for="HorarioAbertura" type="time" class="form-control" />
                        <span asp-validation-for="HorarioAbertura" class="text-danger"></span>
                    </div>

                    <div class="col-sm-6 col-md-3">
                        <label class="form-label">Fecha às</label>
                        <input asp-for="HorarioFechamento" type="time" class="form-control" />
                        <span asp-validation-for="HorarioFechamento" class="text-danger"></span>
                        <div class="form-text">Suporta virar o dia (ex.: 18:00 → 02:00)</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label d-block">Dias abertos</label>
                        @foreach (DiasSemanaFlags d in Enum.GetValues(typeof(DiasSemanaFlags)))
                        {
                            if (d == DiasSemanaFlags.Nenhum || d == DiasSemanaFlags.Todos) { continue; }
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox"
                                       name="DiasAbertosSelecionados"
                                       value="@((int)d)"
                                       @(Model.DiasAbertos.HasFlag(d) ? "checked" : "") />
                                <label class="form-check-label">@d</label>
                            </div>
                        }
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" asp-for="Ativo" />
                            <label class="form-check-label" asp-for="Ativo">Loja ativa</label>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" asp-for="ForcarFechado" />
                            <label class="form-check-label" asp-for="ForcarFechado">Forçar fechado</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="MensagemStatus" class="form-label">Mensagem (opcional)</label>
                        <input asp-for="MensagemStatus" class="form-control" placeholder="Ex.: Voltamos às 19h" />
                        <span asp-validation-for="MensagemStatus" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <hr class="my-3 my-md-4" />

            <section class="section">
                <h2 class="section-title"><i class="bi bi-geo-alt-fill me-2"></i>Endereço da Loja (Retirada no local)</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Logradouro" class="form-label">Logradouro</label>
                        <input asp-for="Logradouro" class="form-control" />
                        <span asp-validation-for="Logradouro" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Numero" class="form-label">Número</label>
                        <input asp-for="Numero" class="form-control" />
                        <span asp-validation-for="Numero" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Complemento" class="form-label">Complemento</label>
                        <input asp-for="Complemento" class="form-control" />
                        <span asp-validation-for="Complemento" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Bairro" class="form-label">Bairro</label>
                        <input asp-for="Bairro" class="form-control" />
                        <span asp-validation-for="Bairro" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Cidade" class="form-label">Cidade</label>
                        <input asp-for="Cidade" class="form-control" />
                        <span asp-validation-for="Cidade" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Estado" class="form-label">UF</label>
                        <input asp-for="Estado" class="form-control text-uppercase" maxlength="2" />
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Cep" class="form-label">CEP</label>
                        <input asp-for="Cep" class="form-control" placeholder="00000-000" />
                        <span asp-validation-for="Cep" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <section class="section mt-3">
                <h2 class="section-title"><i class="bi bi-map me-2"></i>Localização para o Google Maps</h2>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Latitude" class="form-label">Latitude</label>
                        <input asp-for="Latitude" class="form-control" step="any" />
                        <span asp-validation-for="Latitude" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Longitude" class="form-label">Longitude</label>
                        <input asp-for="Longitude" class="form-control" step="any" />
                        <span asp-validation-for="Longitude" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MapsPlaceUrl" class="form-label">URL do Google Maps (opcional)</label>
                        <input asp-for="MapsPlaceUrl" class="form-control" placeholder="Cole a URL do place se já tiver" />
                        <span class="form-text">Se preencher, tem prioridade sobre endereço. Se também informar lat/lng, lat/lng têm prioridade máxima.</span>
                        <span asp-validation-for="MapsPlaceUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 p-3 border rounded bg-light">
                    <div class="small text-muted">Endereço completo (visual):</div>
                    <div id="enderecoPreview" class="fw-semibold">@Model.EnderecoTexto</div>

                    <div class="small text-muted mt-2">URL de rotas (preview):</div>
                    <div class="d-flex flex-column flex-md-row gap-2 align-items-stretch align-items-md-center">
                        <input id="mapsUrlPreview" class="form-control" readonly value="@Model.MapsUrl" />
                        <div class="d-flex gap-2">
                            <a id="btnAbrirMaps" class="btn btn-primary" target="_blank" rel="noopener">
                                <i class="bi bi-geo-alt"></i> Abrir no Maps
                            </a>
                            <button type="button" id="btnCopyMaps" class="btn btn-outline-secondary">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <div class="form-actions mt-3 d-flex flex-column flex-md-row gap-2">
                <button class="btn btn-success"><i class="fas fa-save me-2"></i>Salvar</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
            </div>
        </form>

        @if (isAdmin)
        {
            <form asp-action="LimparDuplicatas" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger" onclick="return confirm('Tem certeza?');">
                    <i class="fas fa-broom me-2"></i>Limpar duplicatas
                </button>
            </form>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const qs = (q) => document.querySelector(q);

          // ===== THEME TOGGLE =====
          const root = qs('#loja-settings');
          const sw = qs('#themeSwitch');
          const label = qs('#themeLabel');

          function setTheme(theme) {
            if (!root || !sw || !label) return;
            root.setAttribute('data-theme', theme);

            const isDark = theme === 'dark';
            sw.classList.toggle('on', isDark);
            sw.setAttribute('aria-checked', isDark ? 'true' : 'false');

            label.innerHTML = isDark
              ? '<i class="fa-solid fa-moon"></i><span>Dark</span>'
              : '<i class="fa-solid fa-sun"></i><span>Light</span>';

            try { localStorage.setItem('loja_settings_theme', theme); } catch {}
          }

          function toggleTheme() {
            const current = root?.getAttribute('data-theme') || 'light';
            setTheme(current === 'dark' ? 'light' : 'dark');
          }

          // init theme
          let saved = null;
          try { saved = localStorage.getItem('loja_settings_theme'); } catch {}
          if (!saved) {
            // fallback: prefer system
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            saved = prefersDark ? 'dark' : 'light';
          }
          setTheme(saved);

          sw?.addEventListener('click', toggleTheme);
          sw?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleTheme(); }
          });

          // ===== MAP PREVIEW =====
          function montaEndereco() {
            const log = qs('#Logradouro')?.value?.trim() || '';
            const num = qs('#Numero')?.value?.trim() || '';
            const comp = qs('#Complemento')?.value?.trim() || '';
            const bai = qs('#Bairro')?.value?.trim() || '';
            const cid = qs('#Cidade')?.value?.trim() || '';
            const uf  = (qs('#Estado')?.value || '').trim().toUpperCase();
            const cep = qs('#Cep')?.value?.trim() || '';

            let p1 = log && num ? `${log}, ${num}` : (log || num);
            let p2 = comp;
            let cidadeUf = cid && uf ? `${cid}/${uf}` : (cid || uf);
            let p3 = bai && cidadeUf ? `${bai} - ${cidadeUf}` : (bai || cidadeUf);
            return [p1, p2, p3, cep].filter(Boolean).join(', ');
          }

          function montaMapsUrl() {
            const lat = parseFloat(qs('#Latitude')?.value);
            const lng = parseFloat(qs('#Longitude')?.value);
            const placeUrl = qs('#MapsPlaceUrl')?.value?.trim();

            if (!isNaN(lat) && !isNaN(lng)) return `https://www.google.com/maps/dir/?api=1&destination=${lat}%2C${lng}`;
            if (placeUrl) return placeUrl;

            const end = montaEndereco();
            return `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(end)}`;
          }

          function atualizarPreviews() {
            const endPrev = qs('#enderecoPreview');
            const urlPrev = qs('#mapsUrlPreview');
            const btnMaps = qs('#btnAbrirMaps');

            if (endPrev) endPrev.textContent = montaEndereco();
            const url = montaMapsUrl();
            if (urlPrev) urlPrev.value = url;
            if (btnMaps) btnMaps.setAttribute('href', url);
          }

          ['#Logradouro','#Numero','#Complemento','#Bairro','#Cidade','#Estado','#Cep','#Latitude','#Longitude','#MapsPlaceUrl']
            .forEach(sel => qs(sel)?.addEventListener('input', atualizarPreviews));

          qs('#Cep')?.addEventListener('input', (e) => {
            let v = e.target.value.replace(/\D/g,'').slice(0,8);
            if (v.length > 5) v = v.slice(0,5) + '-' + v.slice(5);
            e.target.value = v;
          });

          qs('#Estado')?.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/[^A-Za-z]/g,'').slice(0,2).toUpperCase();
          });

          qs('#btnCopyMaps')?.addEventListener('click', async () => {
            try { await navigator.clipboard.writeText(qs('#mapsUrlPreview')?.value || ''); } catch {}
          });

          atualizarPreviews();
        });
    </script>
}
