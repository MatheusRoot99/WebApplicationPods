@model IEnumerable<WebApplicationPods.Models.EntregadorModel>

@{
    ViewData["Title"] = "Entregadores";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-1">Entregadores</h2>
        <p class="text-muted mb-0">Gerencie os entregadores da sua loja.</p>
    </div>

    <a asp-area="PainelLojista"
       asp-controller="Entregadores"
       asp-action="Create"
       class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i> Novo entregador
    </a>
</div>

@if (TempData["Sucesso"] is string okMsg)
{
    <div class="alert alert-success">@okMsg</div>
}
@if (TempData["Erro"] is string errMsg)
{
    <div class="alert alert-danger">@errMsg</div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Veículo</th>
                        <th>Status</th>
                        <th style="width:260px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Nenhum entregador cadastrado.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.Nome</div>
                                    @if (!string.IsNullOrWhiteSpace(item.PlacaVeiculo))
                                    {
                                        <div class="small text-muted">Placa: @item.PlacaVeiculo</div>
                                    }
                                </td>
                                <td>@item.Telefone</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Veiculo) ? "-" : item.Veiculo)</td>
                                <td>
                                    @if (item.Ativo)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a asp-area="PainelLojista"
                                           asp-controller="Entregadores"
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        <form asp-area="PainelLojista"
                                              asp-controller="Entregadores"
                                              asp-action="ToggleAtivo"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                                @(item.Ativo ? "Inativar" : "Ativar")
                                            </button>
                                        </form>

                                        <form asp-area="PainelLojista"
                                              asp-controller="Entregadores"
                                              asp-action="Delete"
                                              method="post"
                                              onsubmit="return confirm('Deseja remover este entregador?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Excluir
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>